pipeline {
    parameters {
        string(name: 'BUILD_CONTAINER_IMAGE', defaultValue: 'netsdk10:latest', description: 'Image for the build container')
        string(name: 'BUILD_CONTAINER_ARGS', defaultValue: '-v /tmp/nuget:/tmp/nuget -e DOTNET_CLI_TELEMETRY_OPTOUT=1 --net=cicd-net -u root -v /var/run/docker.sock:/var/run/docker.sock -v /tmp/trivy-cache:/root/.cache/trivy --group-add 0', description: 'Arguments for the build container')
        string(name: 'BUILD_FILE', defaultValue: 'src/app/cicd.sln', description: 'File to build (sln or csproj)')
        string(name: 'BASE_VER', defaultValue: '1.0.0', description: 'Base version (Major.Minor.Patch) used to derive PackageVersion / FileVersion / AssemblyVersion / InformationalVersion in build-info.json')
        string(name: 'CYCLONEDX_TOOL_VERSION', defaultValue: '5.4.0', description: 'Version of the dotnet CycloneDX global tool to install (CycloneDX/cyclonedx-dotnet)')
        string(name: 'TRIVY_VERSION', defaultValue: 'v0.55.0', description: 'Trivy release tag used to enrich the CycloneDX SBOM with vulnerability data (produces bom-vex.json)')
        choice(name: 'FAIL_ON_SEVERITY', choices: ['none', 'high', 'critical'], description: 'Fail the build when vulnerabilities at this severity (or worse) are present. Default: do not fail.')
    }

    options {
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    agent {
        docker {
            image "${params.BUILD_CONTAINER_IMAGE}"
            args "${params.BUILD_CONTAINER_ARGS}"
            reuseNode true
        }
    }

    stages {
        stage ('Init') {
            steps {
                script {
                    sh "git config --global --add safe.directory '*'"

                    println "Initializing build for ${params.BUILD_FILE}"
                    println "Using build container image: ${params.BUILD_CONTAINER_IMAGE}"
                    println "Build container arguments: ${params.BUILD_CONTAINER_ARGS}"
                    println "Build #${BUILD_NUMBER} started at ${new Date().format("yyyy-MM-dd HH:mm:ss")}"

                    GIT_COMMIT_HASH = sh(script: "git log -n 1 --pretty=format:%H", returnStdout: true).trim()
                    GIT_COMMIT_SHORT = GIT_COMMIT_HASH.take(7)
                    println "Git commit hash: ${GIT_COMMIT_HASH}"
                    println "Git commit short: ${GIT_COMMIT_SHORT}"

                    PACKAGE_VERSION  = "${params.BASE_VER}-ci.${env.BUILD_NUMBER}.g${GIT_COMMIT_SHORT}"
                    FILE_VERSION     = "${params.BASE_VER}.${env.BUILD_NUMBER}"
                    ASSEMBLY_VERSION = "${params.BASE_VER}.0"
                    INFO_VERSION     = "${PACKAGE_VERSION}+${GIT_COMMIT_SHORT}"

                    println "PackageVersion:  ${PACKAGE_VERSION}"
                    println "AssemblyVersion: ${ASSEMBLY_VERSION}"
                    println "FileVersion:     ${FILE_VERSION}"
                    println "InfoVersion:     ${INFO_VERSION}"
                }
            }
        }

        stage ('Restore') {
            steps {
                sh "dotnet restore ${params.BUILD_FILE}"
            }
        }

        stage ('Build') {
            steps {
                sh "dotnet build --no-restore -c Release ${params.BUILD_FILE}"
            }
        }

        stage ('Test') {
            steps {
                //  sh "dotnet test --no-restore --no-build -c Release ${params.BUILD_FILE} --logger trx"
                echo "Skipping tests for now"
            }
        }

        stage ('SBOM') {
            steps {
                // Installs the CycloneDX dotnet global tool into a workspace-local tools dir
                // (avoids polluting the build container's user profile) and emits bom.json
                // describing every direct + transitive package reference in the solution.
                sh """
                    set -e
                    export PATH="\$PATH:${env.WORKSPACE}/.dotnet/tools"
                    dotnet tool install --tool-path ${env.WORKSPACE}/.dotnet/tools \\
                        CycloneDX --version ${params.CYCLONEDX_TOOL_VERSION}
                    dotnet-CycloneDX ${params.BUILD_FILE} \\
                        --output ${env.WORKSPACE} \\
                        --filename bom.json \\
                        --json
                    ls -l ${env.WORKSPACE}/bom.json
                """
            }
        }

        stage ('Vulnerabilities') {
            steps {
                script {
                    // dotnet list package --vulnerable queries the NuGet advisory DB and
                    // returns a non-zero exit code when vulnerabilities are present. We
                    // capture stdout regardless (status=0 means clean), then optionally
                    // gate on severity per FAIL_ON_SEVERITY.
                    def rc = sh(
                        script: """
                            dotnet list ${params.BUILD_FILE} package \\
                                --vulnerable --include-transitive \\
                                --format json --output-version 1 \\
                                > vulnerabilities.json
                        """,
                        returnStatus: true
                    )
                    sh "cat vulnerabilities.json | head -120 || true"

                    if (params.FAIL_ON_SEVERITY != 'none') {
                        def report = readJSON file: 'vulnerabilities.json'
                        // Schema: { projects: [ { frameworks: [ { topLevelPackages|transitivePackages: [ { vulnerabilities: [ { severity, advisoryurl } ] } ] } ] } ] }
                        def severityRank = [low: 1, moderate: 2, high: 3, critical: 4]
                        def threshold = severityRank[params.FAIL_ON_SEVERITY]
                        def offenders = []
                        report?.projects?.each { proj ->
                            proj?.frameworks?.each { fw ->
                                (fw?.topLevelPackages ?: []).plus(fw?.transitivePackages ?: []).each { pkg ->
                                    pkg?.vulnerabilities?.each { v ->
                                        def rank = severityRank[v?.severity?.toLowerCase()] ?: 0
                                        if (rank >= threshold) {
                                            offenders << "${pkg.id}@${pkg.resolvedVersion} ${v.severity} ${v.advisoryurl}"
                                        }
                                    }
                                }
                            }
                        }
                        if (offenders) {
                            error "Build failed: ${offenders.size()} vulnerabilities at severity '${params.FAIL_ON_SEVERITY}' or higher:\n  - " + offenders.join('\n  - ')
                        }
                        println "No vulnerabilities at severity '${params.FAIL_ON_SEVERITY}' or higher."
                    }
                }
            }
        }

        stage ('Trivy SBOM') {
            steps {
                // Enrich the CycloneDX SBOM with vulnerability data (VEX style) using
                // Trivy. Output is a single bom-vex.json suitable for ingestion by
                // Dependency-Track, OWASP DT, etc. Trivy is fetched per-build into
                // a workspace-local tools dir — small download; the heavy bit is the
                // vuln DB (~50–100 MB) which Trivy caches under ~/.cache/trivy.
                //
                // To avoid re-downloading the DB every build, add this to
                // BUILD_CONTAINER_ARGS in your job config:
                //     -v /tmp/trivy-cache:/root/.cache/trivy
                sh """
                    set -e
                    # Prefer the trivy baked into the build image (Dockerfile-build
                    # installs it via Aqua's apt repo). Fall back to a workspace-local
                    # download if the image doesn't ship it, so this stage keeps
                    # working on older base images.
                    if command -v trivy >/dev/null 2>&1; then
                        TRIVY_BIN=\$(command -v trivy)
                    else
                        mkdir -p ${env.WORKSPACE}/.trivy
                        TRIVY_BIN=${env.WORKSPACE}/.trivy/trivy
                        if [ ! -x "\$TRIVY_BIN" ]; then
                            TRIVY_VER_NO_V=\$(echo "${params.TRIVY_VERSION}" | sed 's/^v//')
                            echo "Downloading Trivy ${params.TRIVY_VERSION}…"
                            curl -fsSL "https://github.com/aquasecurity/trivy/releases/download/${params.TRIVY_VERSION}/trivy_\${TRIVY_VER_NO_V}_Linux-64bit.tar.gz" \\
                                | tar -xz -C ${env.WORKSPACE}/.trivy/ trivy
                            chmod +x "\$TRIVY_BIN"
                        fi
                    fi
                    "\$TRIVY_BIN" --version

                    # `trivy sbom` reads a CycloneDX/SPDX SBOM and emits one back with
                    # vulnerability data attached (CVEs from the GitHub Advisory + NVD
                    # databases). --format cyclonedx keeps it the same shape as bom.json.
                    "\$TRIVY_BIN" sbom \\
                        --format cyclonedx \\
                        --output bom-vex.json \\
                        bom.json
                    ls -l bom-vex.json
                """
            }
        }

        stage ('Archive Build Info') {
            steps {
                script {
                    writeJSON file: 'build-info.json', json: [
                        packageVersion:       PACKAGE_VERSION,
                        fileVersion:          FILE_VERSION,
                        assemblyVersion:      ASSEMBLY_VERSION,
                        informationalVersion: INFO_VERSION,
                        gitCommitHash:        GIT_COMMIT_HASH,
                        gitCommitShort:       GIT_COMMIT_SHORT,
                        buildNumber:          env.BUILD_NUMBER,
                        packVer:              params.BASE_VER,
                        buildFile:            params.BUILD_FILE,
                        buildTimestamp:       new Date().format("yyyy-MM-dd'T'HH:mm:ss'Z'", TimeZone.getTimeZone('UTC'))
                    ], pretty: 2

                    sh "cat build-info.json"

                    // Archive build-info.json, the CycloneDX SBOM, and the NuGet
                    // vulnerability report together — downstream publish jobs pull
                    // them as a unit via copyArtifacts.
                    archiveArtifacts(
                        artifacts: 'build-info.json,bom.json,vulnerabilities.json,bom-vex.json',
                        fingerprint: true,
                        onlyIfSuccessful: true)

                    currentBuild.description = "${PACKAGE_VERSION} (${GIT_COMMIT_SHORT})"
                }
            }
        }
    }

    post {
        success {
            echo "Build #${BUILD_NUMBER} compiled successfully (PackageVersion ${PACKAGE_VERSION})"
        }
        failure {
            echo "Build #${BUILD_NUMBER} failed at stage: ${env.STAGE_NAME}"
        }
    }
}
