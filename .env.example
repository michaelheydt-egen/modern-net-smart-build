# Copy to .env and fill in. docker-compose.yml reads these.
# NEVER commit a real .env.

# Required — the admin UI won't start without a Jenkins API token.
JENKINS_API_TOKEN=

# Jenkins server the CI sync + UI talk to (the real Jenkins, not jenkins-api).
JENKINS_URL=http://host.docker.internal:8080
JENKINS_USER=admin

# SQL Server sa password for the deployment DB (dev default is in the compose file).
SA_PASSWORD=Your_Strong_Pass123

# Optional — enables CI artifact reconciliation from Nexus.
NEXUS_URL=http://host.docker.internal:8081
NEXUS_PASSWORD=
NEXUS_DOCKER_HOST=host.docker.internal:8082

# --- Deployment service (GAR + Cloud Run) ---
# The deploy steps need go-containerregistry `crane` on PATH (or a full path here) plus a docker
# config seeded for Nexus + GAR, and ambient ADC for Cloud Run. Under .NET Aspire these come from
# the AppHost's user-secrets (Parameters:CraneExecutable / Parameters:DockerConfigDir), not .env —
# see docs/deployment/prerequisites.md. For a raw docker-compose run, point these at a crane binary
# and config dir available inside the container:
# Deployment__GoogleCloudRun__CraneExecutable=crane
# DOCKER_CONFIG=/path/to/docker-config
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/adc.json
