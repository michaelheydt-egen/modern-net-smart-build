@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject JenkinsOptions JenkinsOpts

<MudThemeProvider Theme="@_active.Theme" IsDarkMode="@_active.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@ToggleDrawer"
                       aria-label="Toggle menu" />
        <MudText Typo="Typo.h6">Jenkins WebUI</MudText>
        <MudSpacer />
        <ThemeSwitcher CurrentThemeId="@_active.Id" ThemeChanged="OnThemeChangedAsync" />
        <JenkinsStatusBadge />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Elevation="1"
               Variant="DrawerVariant.Responsive"
               ClipMode="DrawerClipMode.Always">
        <MudNavMenu>
            <MudNavGroup Title="Jenkins"
                         Icon="@Icons.Material.Filled.Build"
                         Expanded="true">
                <MudNavLink Href="jenkins/orchestrator"
                            Match="NavLinkMatch.Prefix"
                            Icon="@Icons.Material.Filled.AccountTree">
                    Orchestrator
                </MudNavLink>
                <MudNavLink Href="jenkins/pipelines"
                            Match="NavLinkMatch.Prefix"
                            Icon="@Icons.Material.Filled.PlayArrow">
                    Pipelines
                </MudNavLink>
                @* External link to the Jenkins server's own UI — opens in a new tab. *@
                <MudNavLink Href="@JenkinsOpts.BaseUrl"
                            Target="_blank"
                            Icon="@Icons.Material.Filled.OpenInNew">
                    Admin
                </MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="Nexus"
                         Icon="@Icons.Material.Filled.Inventory2"
                         Expanded="true">
                <MudNavLink Href="nexus/nuget"
                            Match="NavLinkMatch.Prefix"
                            Icon="@Icons.Material.Filled.Inventory">
                    Nuget
                </MudNavLink>
                <MudNavLink Href="nexus/docker"
                            Match="NavLinkMatch.Prefix"
                            Icon="@Icons.Material.Filled.ViewInAr">
                    Docker
                </MudNavLink>
                @* External link to the Nexus server's own UI — opens in a new tab.
                   Uses the host-reachable URL (localhost) rather than NexusOpts.Url,
                   which is the docker network alias used by the server-side client. *@
                <MudNavLink Href="http://localhost:8081"
                            Target="_blank"
                            Icon="@Icons.Material.Filled.OpenInNew">
                    Admin
                </MudNavLink>
                @* Deep links to Nexus UI browse views (last so they're grouped). *@
                <MudNavLink Href="http://localhost:8081/#browse/browse:nuget-hosted"
                            Target="_blank"
                            Icon="@Icons.Material.Filled.FolderOpen">
                    Nuget Repo
                </MudNavLink>
                <MudNavLink Href="http://localhost:8081/#browse/browse:docker-private"
                            Target="_blank"
                            Icon="@Icons.Material.Filled.FolderOpen">
                    Docker Repo
                </MudNavLink>
                <MudNavLink Href="http://localhost:8081/#browse/browse:sboms"
                            Target="_blank"
                            Icon="@Icons.Material.Filled.FolderOpen">
                    Sbom Repo
                </MudNavLink>
            </MudNavGroup>
            <MudNavLink Href="google"
                        Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.Cloud">
                Google
            </MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private const string LocalStorageKey = "jenkins-webui-theme";

    private bool _drawerOpen = true;
    private AppThemes.Entry _active = AppThemes.Resolve(AppThemes.SolarizedDarkId);

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Persisted theme lives in localStorage; read it once on first interactive render.
        try
        {
            var stored = await JS.InvokeAsync<string?>("localStorage.getItem", LocalStorageKey);
            var resolved = AppThemes.Resolve(stored);
            if (resolved.Id != _active.Id)
            {
                _active = resolved;
                StateHasChanged();
            }
        }
        catch (JSDisconnectedException) { /* page tearing down */ }
    }

    private async Task OnThemeChangedAsync(string themeId)
    {
        _active = AppThemes.Resolve(themeId);
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", LocalStorageKey, _active.Id);
        }
        catch (JSDisconnectedException) { /* page tearing down */ }
        StateHasChanged();
    }
}
