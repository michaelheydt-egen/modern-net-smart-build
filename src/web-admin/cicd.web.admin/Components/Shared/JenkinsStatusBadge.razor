@inject IJenkinsHealth Health
@implements IDisposable

<MudTooltip Text="@Tooltip()">
    <MudChip T="string"
             Color="@ChipColor()"
             Icon="@ChipIcon()"
             Variant="Variant.Filled"
             Size="Size.Small">
        Jenkins: @StatusLabel()
    </MudChip>
</MudTooltip>

@code {
    private JenkinsHealthSnapshot _snapshot = new(JenkinsHealthStatus.Unknown, null, null, null);

    protected override void OnInitialized()
    {
        _snapshot = Health.Snapshot;
        Health.StateChanged += OnChanged;
    }

    private void OnChanged()
    {
        _ = InvokeAsync(() =>
        {
            _snapshot = Health.Snapshot;
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        Health.StateChanged -= OnChanged;
    }

    private string StatusLabel() => _snapshot.Status switch
    {
        JenkinsHealthStatus.Healthy     => "ok",
        JenkinsHealthStatus.Degraded    => "degraded",
        JenkinsHealthStatus.Unreachable => "unreachable",
        _                               => "checking…"
    };

    private Color ChipColor() => _snapshot.Status switch
    {
        JenkinsHealthStatus.Healthy     => Color.Success,
        JenkinsHealthStatus.Degraded    => Color.Warning,
        JenkinsHealthStatus.Unreachable => Color.Error,
        _                               => Color.Default
    };

    private string ChipIcon() => _snapshot.Status switch
    {
        JenkinsHealthStatus.Healthy     => Icons.Material.Filled.CheckCircle,
        JenkinsHealthStatus.Degraded    => Icons.Material.Filled.Warning,
        JenkinsHealthStatus.Unreachable => Icons.Material.Filled.Error,
        _                               => Icons.Material.Filled.HourglassEmpty
    };

    private string Tooltip()
    {
        var last = _snapshot.LastCheckedAt is { } t
            ? $"Last check: {t.LocalDateTime:HH:mm:ss}"
            : "No check yet";
        var detail = _snapshot.Detail is { Length: > 0 } d ? $" — {d}" : "";
        return $"{last}{detail}";
    }
}
