@* Status pill for the optional Jenkins → SQLite build mirror.
   Three states:
     - Live mode (sync disabled in config): grey "Sync: live"
     - Synced, no error: green "Sync: 2m ago • 87"
     - Sync error from the last tick: yellow "Sync: error" (full message in tooltip)
   Polls IBuildStore.Status every 5s so the relative timestamp stays current
   between sync ticks (default tick interval is 60s). Clicking jumps to the
   /settings page where the full state is laid out. *@

@inject IBuildStore Store
@inject NavigationManager Nav
@implements IDisposable

<MudTooltip Text="@Tooltip()">
    <MudChip T="string"
             Color="@ChipColor()"
             Icon="@ChipIcon()"
             Variant="Variant.Filled"
             Size="Size.Small"
             OnClick="OnClick">
        Sync: @StatusLabel()
    </MudChip>
</MudTooltip>

@code {
    private Timer? _timer;
    private BuildSyncStatus? _snapshot;

    protected override void OnInitialized()
    {
        _snapshot = Store.Status;
        _timer = new Timer(_ => _ = InvokeAsync(() =>
        {
            _snapshot = Store.Status;
            StateHasChanged();
        }), null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    public void Dispose() => _timer?.Dispose();

    private void OnClick() => Nav.NavigateTo("/settings");

    private string StatusLabel()
    {
        // Status==null means live mode (no mirror in front of Jenkins).
        if (_snapshot is null) return "live";
        if (_snapshot.LastError is { Length: > 0 }) return "error";
        if (_snapshot.LastSyncedAt == default) return "pending";
        return $"{FormatRelative(_snapshot.LastSyncedAt)} • {_snapshot.BuildsTracked}";
    }

    private Color ChipColor() =>
        _snapshot is null                  ? Color.Default :
        _snapshot.LastError is { Length: > 0 } ? Color.Warning :
        _snapshot.LastSyncedAt == default      ? Color.Default :
                                                 Color.Success;

    private string ChipIcon() =>
        _snapshot is null                  ? Icons.Material.Filled.CloudOff :
        _snapshot.LastError is { Length: > 0 } ? Icons.Material.Filled.SyncProblem :
        _snapshot.LastSyncedAt == default      ? Icons.Material.Filled.HourglassEmpty :
                                                 Icons.Material.Filled.CloudDone;

    private string Tooltip()
    {
        if (_snapshot is null)
        {
            return "Live mode — every read goes straight to Jenkins. Enable BuildSync:Enabled to mirror to SQLite.";
        }
        if (_snapshot.LastError is { Length: > 0 } err)
        {
            return $"Last tick failed: {err}";
        }
        if (_snapshot.LastSyncedAt == default)
        {
            return "Sync service starting — first tick pending";
        }
        return $"Last sync: {_snapshot.LastSyncedAt.LocalDateTime:HH:mm:ss}  •  {_snapshot.BuildsTracked} builds tracked";
    }

    private static string FormatRelative(DateTimeOffset t)
    {
        var ago = DateTimeOffset.UtcNow - t;
        return ago switch
        {
            { TotalSeconds: < 5 }  => "just now",
            { TotalSeconds: < 60 } => $"{(int)ago.TotalSeconds}s ago",
            { TotalMinutes: < 60 } => $"{(int)ago.TotalMinutes}m ago",
            { TotalHours: < 24 }   => $"{(int)ago.TotalHours}h ago",
            _                      => t.LocalDateTime.ToString("HH:mm:ss")
        };
    }
}
