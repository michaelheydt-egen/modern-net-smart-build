@page "/deployment/dashboards/effective-versions"
@inject DeploymentApiClient Api

<PageTitle>Deployment — Effective versions</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Effective versions</MudText>
    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
        Q1′ — running version per (service × target) in an environment
    </MudText>
</MudStack>

<MudPaper Elevation="1" Class="pa-4 mb-4">
    <MudStack Row="true" Spacing="2" Class="mb-3" Wrap="Wrap.Wrap">
        <MudSelect T="Guid?"
                   Value="_applicationId"
                   ValueChanged="OnAppChanged"
                   Label="Application"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Style="max-width: 20rem;">
            <MudSelectItem T="Guid?" Value="@((Guid?)null)">(pick one)</MudSelectItem>
            @foreach (var a in _applications ?? Array.Empty<ApplicationDto>())
            {
                <MudSelectItem T="Guid?" Value="@((Guid?)a.Id)">@a.Name</MudSelectItem>
            }
        </MudSelect>
        <MudSelect T="Guid?"
                   Value="_environmentId"
                   ValueChanged="OnEnvChanged"
                   Label="Environment"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Style="max-width: 16rem;">
            <MudSelectItem T="Guid?" Value="@((Guid?)null)">(pick one)</MudSelectItem>
            @foreach (var e in _environments ?? Array.Empty<EnvironmentDto>())
            {
                <MudSelectItem T="Guid?" Value="@((Guid?)e.Id)">@e.Name</MudSelectItem>
            }
        </MudSelect>
    </MudStack>

    @if (_error is { Length: > 0 })
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-2">@_error</MudAlert>
    }

    @if (_applicationId is null || _environmentId is null)
    {
        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
            Pick an application and environment to compute the effective-versions grid.
        </MudText>
    }
    else if (_loading)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (_rows is { Count: 0 })
    {
        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
            No member services or no targets in this environment.
        </MudText>
    }
    else if (_rows is not null)
    {
        <MudTable Items="@_rows" T="EffectiveVersionRow" Dense="true" Hover="true">
            <HeaderContent>
                <MudTh>Service</MudTh>
                <MudTh Style="width: 9rem;">Region</MudTh>
                <MudTh>Target</MudTh>
                <MudTh Style="width: 10rem;">Version</MudTh>
                <MudTh Style="width: 12rem;">Last deployed</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudLink Href="@($"/deployment/services/{context.ServiceId}")">@context.ServiceName</MudLink>
                </MudTd>
                <MudTd Style="font-family: ui-monospace, monospace;">@context.Region</MudTd>
                <MudTd Style="font-family: ui-monospace, monospace; font-size: 0.85em;">@context.TargetResourceId</MudTd>
                <MudTd>
                    @if (context.RunningReleaseId is { } rid)
                    {
                        <MudLink Href="@($"/deployment/releases/{rid}")"
                                 Style="font-family: ui-monospace, monospace;">
                            v@context.SemanticVersion
                        </MudLink>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">never deployed</MudChip>
                    }
                </MudTd>
                <MudTd Style="font-size: 0.85em;">
                    @(context.CompletedAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "—")
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@code {
    private IReadOnlyList<ApplicationDto>? _applications;
    private IReadOnlyList<EnvironmentDto>? _environments;
    private IReadOnlyList<EffectiveVersionRow>? _rows;
    private Guid? _applicationId;
    private Guid? _environmentId;
    private bool _loading;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var aTask = Api.ListApplicationsAsync(onlyActive: true);
            var eTask = Api.ListEnvironmentsAsync();
            await Task.WhenAll(aTask, eTask);
            _applications = await aTask;
            _environments = await eTask;
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task OnAppChanged(Guid? id) { _applicationId = id; await TryLoadAsync(); }
    private async Task OnEnvChanged(Guid? id) { _environmentId = id; await TryLoadAsync(); }

    private async Task TryLoadAsync()
    {
        if (_applicationId is null || _environmentId is null) { _rows = null; return; }
        _loading = true; _error = null;
        try
        {
            _rows = await Api.GetEffectiveVersionsAsync(_applicationId.Value, _environmentId.Value);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }
}
