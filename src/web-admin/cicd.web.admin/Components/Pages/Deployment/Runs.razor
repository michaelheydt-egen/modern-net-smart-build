@page "/deployment/runs"
@inject DeploymentApiClient Api
@inject ISnackbar Snackbar

<PageTitle>Deployment — Runs</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Deployments</MudText>
    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">history of deployment runs (auto + manual)</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadAsync">Refresh</MudButton>
</MudStack>

@if (_error is { Length: > 0 }) { <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="my-2">@_error</MudAlert> }

<MudPaper Elevation="1" Class="pa-4 mb-4">
    @if (_loading && _items is null) { <MudProgressLinear Indeterminate="true" /> }
    else if (_items is { Count: 0 }) { <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">No deployments yet.</MudText> }
    else if (_items is not null)
    {
        <MudTable Items="@_items" Dense="true" Hover="true" Striped="true" T="DeploymentRunDto">
            <HeaderContent><MudTh Style="width:8rem;">Status</MudTh><MudTh>Service</MudTh><MudTh>Version</MudTh><MudTh>Target</MudTh><MudTh>Trigger</MudTh><MudTh>Revision</MudTh><MudTh Style="width:11rem;">When</MudTh><MudTh Style="width:8rem;"></MudTh></HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Status)" Variant="Variant.Filled">@context.Status</MudChip>
                    @if (context.Status == DeploymentRunStatusDto.AwaitingPromotion && !string.IsNullOrEmpty(context.RolloutGreenSlot))
                    { <MudTooltip Text="@($"'{context.RolloutGreenSlot}' healthy; live '{context.RolloutActiveSlot}'")"><MudIcon Icon="@Icons.Material.Filled.CompareArrows" Color="Color.Warning" Size="Size.Small" /></MudTooltip> }
                    @if (context.RolloutCanaryWeight is { } cw)
                    { <MudTooltip Text="current canary traffic weight"><MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Warning">canary @cw%</MudChip></MudTooltip> }
                </MudTd>
                <MudTd>@context.ServiceName</MudTd>
                <MudTd Style="font-family: ui-monospace, monospace; font-size:0.85em;">@context.Version</MudTd>
                <MudTd Style="font-family: ui-monospace, monospace; font-size:0.8em;">
                    @(string.IsNullOrEmpty(context.CloudRunServiceName) ? context.KubernetesResource : context.CloudRunServiceName)
                    @if ((context.Status == DeploymentRunStatusDto.Failed || context.Status == DeploymentRunStatusDto.RolledBack) && !string.IsNullOrEmpty(context.FailureReason))
                    { <MudTooltip Text="@context.FailureReason"><MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Error" Size="Size.Small" /></MudTooltip> }
                </MudTd>
                <MudTd><MudChip T="string" Size="Size.Small" Variant="Variant.Text">@context.Trigger</MudChip></MudTd>
                <MudTd Style="font-family: ui-monospace, monospace; font-size:0.8em;">@context.CloudRunRevision</MudTd>
                <MudTd>@context.RequestedAtUtc.LocalDateTime.ToString("g")</MudTd>
                <MudTd>
                    @if (context.Status == DeploymentRunStatusDto.AwaitingPromotion)
                    {
                        <MudTooltip Text="@(context.RolloutCanaryWeight is not null ? "Promote — ramp the canary to the next weight, or cut over to 100% at the last step" : "Promote — cut traffic to the green slot")"><MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small" Disabled="_busy" OnClick="@(() => PromoteAsync(context))" /></MudTooltip>
                        <MudTooltip Text="Roll back — delete the new slot, keep the live one"><MudIconButton Icon="@Icons.Material.Filled.Undo" Color="Color.Error" Size="Size.Small" Disabled="_busy" OnClick="@(() => RollbackAsync(context))" /></MudTooltip>
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@code {
    private IReadOnlyList<DeploymentRunDto>? _items;
    private bool _loading, _busy;
    private string? _error;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true; _error = null; StateHasChanged();
        try { _items = await Api.ListRunsAsync(); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; StateHasChanged(); }
    }

    private async Task PromoteAsync(DeploymentRunDto run)
    {
        _busy = true;
        try
        {
            await Api.PromoteRunAsync(run.Id);
            Snackbar.Add($"Promoted '{run.ServiceName}' to the green slot.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _busy = false; }
    }

    private async Task RollbackAsync(DeploymentRunDto run)
    {
        _busy = true;
        try
        {
            await Api.RollbackRunAsync(run.Id);
            Snackbar.Add($"Rolled back '{run.ServiceName}' — blue stays live.", Severity.Warning);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _busy = false; }
    }

    private static Color StatusColor(DeploymentRunStatusDto s) => s switch
    {
        DeploymentRunStatusDto.Succeeded => Color.Success,
        DeploymentRunStatusDto.Failed => Color.Error,
        DeploymentRunStatusDto.RolledBack => Color.Error,
        DeploymentRunStatusDto.Running => Color.Info,
        DeploymentRunStatusDto.AwaitingPromotion => Color.Warning,
        _ => Color.Default,
    };
}
