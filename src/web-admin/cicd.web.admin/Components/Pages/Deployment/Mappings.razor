@page "/deployment/mappings"
@inject DeploymentApiClient Api
@inject ISnackbar Snackbar

<PageTitle>Deployment — Mappings</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Mappings</MudText>
    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">service → environment: Cloud Run or Kubernetes target + auto-deploy</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate"
               Disabled="@(_services is null or { Count: 0 } || _envs is null or { Count: 0 })">Add mapping</MudButton>
</MudStack>

@if (_error is { Length: > 0 }) { <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="my-2">@_error</MudAlert> }
@if (_services is { Count: 0 } || _envs is { Count: 0 })
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="my-2">Add at least one <MudLink Href="/deployment/services">service</MudLink> and one <MudLink Href="/deployment/environments">environment</MudLink> first.</MudAlert>
}

<MudPaper Elevation="1" Class="pa-4 mb-4">
    @if (_loading && _items is null) { <MudProgressLinear Indeterminate="true" /> }
    else if (_items is { Count: 0 }) { <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">No mappings yet. Nothing deploys automatically until a mapping has auto-deploy on.</MudText> }
    else if (_items is not null)
    {
        <MudTable Items="@_items" Dense="true" Hover="true" Striped="true" T="DeploymentMappingDto">
            <HeaderContent><MudTh>Service</MudTh><MudTh>Environment</MudTh><MudTh>Target</MudTh><MudTh>Steps</MudTh><MudTh Style="width:8rem;">Auto-deploy</MudTh><MudTh Style="width:14rem; text-align:right;"></MudTh></HeaderContent>
            <RowTemplate>
                <MudTd>@context.ServiceName</MudTd>
                <MudTd>@context.EnvironmentName</MudTd>
                <MudTd Style="font-family: ui-monospace, monospace; font-size:0.85em;">@(context.Kubernetes is not null ? $"k8s: {context.Kubernetes.DeploymentName}" : context.CloudRunServiceName)</MudTd>
                <MudTd Style="font-size:0.8em;">@string.Join(" → ", context.Steps.OrderBy(s => s.Order).Select(s => s.Kind))</MudTd>
                <MudTd><MudSwitch T="bool" Value="@context.AutoDeploy" Color="Color.Primary" ValueChanged="@(v => ToggleAutoAsync(context, v))" /></MudTd>
                <MudTd Style="text-align:right; white-space:nowrap;">
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.RocketLaunch" OnClick="@(() => DeployAsync(context))">Deploy</MudButton>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context))" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

<MudDialog @bind-Visible="_show" Options="_dlg">
    <TitleContent>Add mapping</TitleContent>
    <DialogContent>
        <MudSelect @bind-Value="_form.ServiceId" Label="Service" T="Guid" Required="true">
            @foreach (var s in _services ?? new List<ServiceDto>()) { <MudSelectItem Value="@s.Id">@s.Name (@s.ContainerName)</MudSelectItem> }
        </MudSelect>
        <MudSelect @bind-Value="_form.EnvironmentId" Label="Environment" T="Guid" Required="true">
            @foreach (var e in _envs ?? new List<EnvironmentDto>()) { <MudSelectItem Value="@e.Id">@e.Name (@(IsK8s(e) ? $"k8s:{e.KubernetesContext}/{e.KubernetesNamespace}" : $"{e.GcpProject}/{e.Region}"))</MudSelectItem> }
        </MudSelect>
        @if (SelectedEnvIsK8s())
        {
            <MudTextField @bind-Value="_form.K8sDeploymentName" Label="Deployment name" HelperText="defaults to the container name" />
            <MudNumericField @bind-Value="_form.K8sPort" Label="Container port" Min="1" />
            <MudNumericField @bind-Value="_form.K8sReplicas" Label="Replicas" Min="1" />
            <MudTextField @bind-Value="_form.K8sImagePullSecret" Label="Image pull secret (optional)" HelperText="for pulling from a private Nexus" />
            <MudSelect T="RolloutStrategyDto" @bind-Value="_form.K8sStrategy" Label="Rollout strategy" Class="mt-2">
                <MudSelectItem Value="RolloutStrategyDto.Direct">Direct (rolling update in place)</MudSelectItem>
                <MudSelectItem Value="RolloutStrategyDto.BlueGreen">Blue-green (deploy green, health-gate, cut over)</MudSelectItem>
                <MudSelectItem Value="RolloutStrategyDto.Canary">Canary (ingress traffic-weighted, progressive ramp)</MudSelectItem>
            </MudSelect>
            @if (_form.K8sStrategy == RolloutStrategyDto.Canary)
            {
                <MudTextField @bind-Value="_form.K8sCanarySteps" Label="Canary weight ladder (%)" HelperText="ascending traffic % the canary Ingress routes; Manual promotion advances through these, then cuts over to 100%. e.g. 10,25,50" />
            }
            @if (_form.K8sStrategy != RolloutStrategyDto.Direct)
            {
                <MudSelect T="PromotionModeDto" @bind-Value="_form.K8sPromotionMode" Label="Promotion" HelperText="when to complete the rollout (cut over / scale canary to full)">
                    <MudSelectItem Value="PromotionModeDto.Automatic">Automatic (promote once healthy)</MudSelectItem>
                    <MudSelectItem Value="PromotionModeDto.Manual">Manual (park for a human to promote / ramp)</MudSelectItem>
                </MudSelect>
            }
            <MudSwitch T="bool" @bind-Value="_form.AutoDeploy" Color="Color.Primary" Label="Auto-deploy on new container push" Class="mt-2" />
            <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">Recipe: KubernetesApply (generated Deployment + Service).</MudText>
        }
        else
        {
            <MudTextField @bind-Value="_form.CloudRunServiceName" Label="Cloud Run service name" Required="true" />
            <MudSwitch T="bool" @bind-Value="_form.AutoDeploy" Color="Color.Primary" Label="Auto-deploy on new container push" Class="mt-2" />
            <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">Recipe: GarPush → CloudRunDeploy (default).</MudText>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _show = false)">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="_busy">Add</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [SupplyParameterFromQuery] public Guid? ServiceId { get; set; }

    private IReadOnlyList<DeploymentMappingDto>? _items;
    private IReadOnlyList<ServiceDto>? _services;
    private IReadOnlyList<EnvironmentDto>? _envs;
    private bool _loading, _busy, _show;
    private string? _error;
    private Form _form = new();
    private static readonly DialogOptions _dlg = new() { MaxWidth = MaxWidth.Small, FullWidth = true };

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true; _error = null; StateHasChanged();
        try
        {
            _services = await Api.ListServicesAsync();
            _envs = await Api.ListEnvironmentsAsync();
            _items = await Api.ListMappingsAsync(ServiceId);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; StateHasChanged(); }
    }

    private void OpenCreate()
    {
        _form = new Form
        {
            ServiceId = ServiceId ?? _services?.FirstOrDefault()?.Id ?? Guid.Empty,
            EnvironmentId = _envs?.FirstOrDefault()?.Id ?? Guid.Empty,
        };
        _show = true;
    }

    private static bool IsK8s(EnvironmentDto e) => !string.IsNullOrEmpty(e.KubernetesContext) && !string.IsNullOrEmpty(e.KubernetesNamespace);
    private bool SelectedEnvIsK8s() => _envs?.FirstOrDefault(e => e.Id == _form.EnvironmentId) is { } e && IsK8s(e);

    private static List<int> ParseCanarySteps(string? csv)
    {
        var steps = (csv ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(s => int.TryParse(s, out var n) ? n : -1)
            .Where(n => n is > 0 and < 100).Distinct().OrderBy(n => n).ToList();
        return steps.Count > 0 ? steps : new List<int> { 20 };
    }

    private async Task SaveAsync()
    {
        _busy = true;
        try
        {
            CreateMappingRequest req;
            if (SelectedEnvIsK8s())
            {
                var steps = ParseCanarySteps(_form.K8sCanarySteps);
                var k8s = new KubernetesSpecDto(_form.K8sDeploymentName ?? "", _form.K8sPort, _form.K8sReplicas, null,
                    string.IsNullOrWhiteSpace(_form.K8sImagePullSecret) ? null : _form.K8sImagePullSecret, true,
                    _form.K8sStrategy, _form.K8sPromotionMode, steps.FirstOrDefault(20), steps);
                req = new CreateMappingRequest(_form.ServiceId, _form.EnvironmentId, null, k8s, _form.AutoDeploy, null);
            }
            else
            {
                req = new CreateMappingRequest(_form.ServiceId, _form.EnvironmentId, _form.CloudRunServiceName, null, _form.AutoDeploy, null);
            }
            await Api.CreateMappingAsync(req);
            Snackbar.Add("Mapping added.", Severity.Success);
            _show = false; await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _busy = false; }
    }

    private async Task ToggleAutoAsync(DeploymentMappingDto m, bool value)
    {
        try { await Api.SetAutoDeployAsync(m.Id, value); await LoadAsync(); }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task DeployAsync(DeploymentMappingDto m)
    {
        try
        {
            var res = await Api.DeployAsync(m.Id, new TriggerDeploymentRequest(null, "ui"));
            if (res.RunId is not null) Snackbar.Add("Deployment queued.", Severity.Success);
            else Snackbar.Add($"No deploy: {res.Outcome}.", Severity.Info);
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task DeleteAsync(DeploymentMappingDto m)
    {
        try { await Api.DeleteMappingAsync(m.Id); Snackbar.Add("Deleted.", Severity.Success); await LoadAsync(); }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private sealed class Form
    {
        public Guid ServiceId { get; set; }
        public Guid EnvironmentId { get; set; }
        public string CloudRunServiceName { get; set; } = "";
        public bool AutoDeploy { get; set; }
        public string? K8sDeploymentName { get; set; }
        public int K8sPort { get; set; } = 8080;
        public int K8sReplicas { get; set; } = 1;
        public string? K8sImagePullSecret { get; set; }
        public RolloutStrategyDto K8sStrategy { get; set; } = RolloutStrategyDto.Direct;
        public PromotionModeDto K8sPromotionMode { get; set; } = PromotionModeDto.Automatic;
        public string K8sCanarySteps { get; set; } = "20,50";
    }
}
