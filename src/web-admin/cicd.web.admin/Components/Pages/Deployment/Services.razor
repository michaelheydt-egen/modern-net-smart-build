@page "/deployment/services"
@inject DeploymentApiClient Api
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Deployment — Services</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Services</MudText>
    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
        deployment catalog
    </MudText>
    <MudSpacer />
    <MudSwitch T="bool"
               @bind-Value="_onlyActive"
               @bind-Value:after="LoadAsync"
               Color="Color.Primary"
               Label="Active only" />
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenRegisterDialog">
        Register
    </MudButton>
</MudStack>

@if (_error is { Length: > 0 })
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="my-2">@_error</MudAlert>
}

<MudPaper Elevation="1" Class="pa-4 mb-4">
    @if (_loading && _services is null)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (_services is { Count: 0 })
    {
        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
            No services registered yet. Click <strong>Register</strong> to add one.
        </MudText>
    }
    else if (_services is not null)
    {
        <MudTable Items="@_services"
                  Dense="true"
                  Hover="true"
                  Striped="true"
                  Filter="new Func<ServiceDto, bool>(MatchesFilter)"
                  T="ServiceDto">
            <ToolBarContent>
                <MudTextField @bind-Value="_filter"
                              Placeholder="Filter by name, kind, repo…"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Small"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Clearable="true"
                              Immediate="true"
                              Style="max-width: 28rem;" />
            </ToolBarContent>
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh Style="width: 9rem;">Kind</MudTh>
                <MudTh>Repository</MudTh>
                <MudTh Style="width: 8rem;">Framework</MudTh>
                <MudTh Style="width: 6rem;">Status</MudTh>
                <MudTh Style="width: 7rem; text-align: right;"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudLink Href="@($"/deployment/services/{context.Id}")">@context.Name</MudLink>
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                        @context.Kind
                    </MudChip>
                </MudTd>
                <MudTd Style="font-family: ui-monospace, monospace; font-size: 0.85em;">
                    @context.RepositoryUrl
                </MudTd>
                <MudTd>@context.TargetFramework</MudTd>
                <MudTd>
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="@(context.IsActive ? Color.Success : Color.Default)"
                             Variant="Variant.Filled">
                        @(context.IsActive ? "Active" : "Inactive")
                    </MudChip>
                </MudTd>
                <MudTd Style="text-align: right; white-space: nowrap;">
                    <MudTooltip Text="Edit">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Size="Size.Small"
                                       OnClick="@(() => Nav.NavigateTo($"/deployment/services/{context.Id}"))" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@code {
    private IReadOnlyList<ServiceDto>? _services;
    private string _filter = "";
    private bool _onlyActive;
    private bool _loading;
    private string? _error;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true; _error = null; StateHasChanged();
        try
        {
            _services = await Api.ListServicesAsync(_onlyActive ? true : null);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private bool MatchesFilter(ServiceDto s)
    {
        if (string.IsNullOrWhiteSpace(_filter)) return true;
        var q = _filter.Trim();
        return s.Name.Contains(q, StringComparison.OrdinalIgnoreCase)
               || s.Kind.ToString().Contains(q, StringComparison.OrdinalIgnoreCase)
               || s.RepositoryUrl.Contains(q, StringComparison.OrdinalIgnoreCase)
               || s.TargetFramework.Contains(q, StringComparison.OrdinalIgnoreCase);
    }

    private async Task OpenRegisterDialog()
    {
        // Inline dialog via simple navigation to a "new" route — keeps the form
        // logic in one place and lets the URL be sharable. The form lives on
        // ServiceDetail with a special "new" id.
        await Task.CompletedTask;
        Nav.NavigateTo("/deployment/services/new");
    }
}
