@*
    Change a release's status. Reason is required when targeting Quarantined
    (mirrors the domain invariant). ChangedByPrincipal is required for audit.
*@

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width: 420px;">
            <MudText Typo="Typo.body2">
                Current status: <strong>@CurrentStatus</strong>
            </MudText>
            <MudSelect T="ReleaseStatusDto"
                       @bind-Value="_newStatus"
                       Label="New status"
                       Variant="Variant.Outlined">
                @foreach (var s in Enum.GetValues<ReleaseStatusDto>())
                {
                    <MudSelectItem Value="@s">@s</MudSelectItem>
                }
            </MudSelect>
            <MudTextField @bind-Value="_reason"
                          Label="@(IsQuarantine ? "Reason (required)" : "Reason (optional)")"
                          Variant="Variant.Outlined"
                          Required="@IsQuarantine"
                          Lines="2"
                          MaxLength="500"
                          HelperText="@(IsQuarantine ? "Required when moving to Quarantined — e.g., CVE-2026-001" : "Free-form audit note")" />
            <MudTextField @bind-Value="_principal"
                          Label="Changed by (principal)"
                          Variant="Variant.Outlined"
                          Required="true"
                          MaxLength="200"
                          HelperText="Identity making this change (logged for audit)." />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Submit"
                   Disabled="@(!CanSubmit())">
            Change status
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter, EditorRequired] public ReleaseStatusDto CurrentStatus { get; set; }

    private ReleaseStatusDto _newStatus;
    private string _reason = "";
    private string _principal = "";

    protected override void OnInitialized()
    {
        // Default the picker to a sensible next state.
        _newStatus = CurrentStatus switch
        {
            ReleaseStatusDto.Available => ReleaseStatusDto.Quarantined,
            ReleaseStatusDto.Quarantined => ReleaseStatusDto.Available,
            _ => CurrentStatus,
        };
    }

    private bool IsQuarantine => _newStatus == ReleaseStatusDto.Quarantined;

    private bool CanSubmit()
    {
        if (_newStatus == CurrentStatus) return false;
        if (string.IsNullOrWhiteSpace(_principal)) return false;
        if (IsQuarantine && string.IsNullOrWhiteSpace(_reason)) return false;
        return true;
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit() =>
        MudDialog.Close(DialogResult.Ok(new Result(_newStatus,
            string.IsNullOrWhiteSpace(_reason) ? null : _reason.Trim(),
            _principal.Trim())));

    public sealed record Result(ReleaseStatusDto NewStatus, string? Reason, string ChangedByPrincipal);
}
