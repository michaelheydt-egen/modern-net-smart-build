@*
    Schedule a freeze window for the environment. v1 has no recurrence — to model
    "every Friday 4pm – Monday 8am" you'd add explicit rows for each occurrence
    (see decisions §7.4). EndUtc must be after StartUtc; the form blocks Submit
    until it is.

    Date pickers capture local-time wall-clock values; we convert to UTC on
    submit so the server stores a stable instant regardless of operator TZ.
*@

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width: 520px;">
            <MudGrid>
                <MudItem xs="6">
                    <MudDatePicker @bind-Date="_startDate"
                                   Label="Start date"
                                   Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="6">
                    <MudTimePicker @bind-Time="_startTime"
                                   Label="Start time"
                                   Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="6">
                    <MudDatePicker @bind-Date="_endDate"
                                   Label="End date"
                                   Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="6">
                    <MudTimePicker @bind-Time="_endTime"
                                   Label="End time"
                                   Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
            @if (RangeIsValid is false)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
                    End must be after start.
                </MudAlert>
            }
            <MudTextField @bind-Value="_reason"
                          Label="Reason"
                          Variant="Variant.Outlined"
                          Required="true"
                          Lines="2"
                          MaxLength="500"
                          HelperText="e.g. 'Holiday freeze 2026 EOY'" />
            <MudTextField @bind-Value="_principal"
                          Label="Created by (principal)"
                          Variant="Variant.Outlined"
                          Required="true"
                          MaxLength="200" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.AcUnit"
                   OnClick="Submit"
                   Disabled="@(!CanSubmit())">
            Schedule
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    private DateTime? _startDate = DateTime.Today;
    private TimeSpan? _startTime = new(0, 0, 0);
    private DateTime? _endDate = DateTime.Today.AddDays(2);
    private TimeSpan? _endTime = new(0, 0, 0);
    private string _reason = "";
    private string _principal = "";

    private DateTimeOffset? StartUtc =>
        _startDate is { } d && _startTime is { } t
            ? new DateTimeOffset(d.Date + t, TimeSpan.Zero).ToUniversalTime()
            : null;

    private DateTimeOffset? EndUtc =>
        _endDate is { } d && _endTime is { } t
            ? new DateTimeOffset(d.Date + t, TimeSpan.Zero).ToUniversalTime()
            : null;

    // null when either bound is missing (don't show warning yet);
    // bool result when both present.
    private bool? RangeIsValid =>
        (StartUtc, EndUtc) switch
        {
            ({ } s, { } e) => e > s,
            _ => null,
        };

    private bool CanSubmit() =>
        RangeIsValid == true
        && !string.IsNullOrWhiteSpace(_reason)
        && !string.IsNullOrWhiteSpace(_principal);

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        if (StartUtc is null || EndUtc is null) return;
        MudDialog.Close(DialogResult.Ok(new Result(
            StartUtc.Value, EndUtc.Value, _reason.Trim(), _principal.Trim())));
    }

    public sealed record Result(
        DateTimeOffset StartUtc,
        DateTimeOffset EndUtc,
        string Reason,
        string CreatedByPrincipal);
}
