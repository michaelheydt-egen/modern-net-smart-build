@page "/deployment/applications/{Id}"
@inject DeploymentApiClient Api
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Deployment — Application @_dto?.Name</PageTitle>

<MudBreadcrumbs Items="@_crumbs" Class="mb-2" />

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_error is { Length: > 0 })
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="my-2">@_error</MudAlert>
}
else if (_isNew)
{
    <MudText Typo="Typo.h4" Class="mb-3">Register a new application</MudText>
    <MudPaper Elevation="1" Class="pa-4" Style="max-width: 720px;">
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_newName"
                          Label="Name"
                          Variant="Variant.Outlined"
                          Required="true"
                          MaxLength="200" />
            <MudTextField @bind-Value="_newDesc"
                          Label="Description"
                          Variant="Variant.Outlined"
                          Lines="3"
                          MaxLength="1000" />
            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Save"
                           OnClick="RegisterAsync"
                           Disabled="@_saving">Register</MudButton>
                <MudButton Variant="Variant.Text"
                           OnClick="@(() => Nav.NavigateTo("/deployment/applications"))">Cancel</MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>
}
else if (_dto is not null)
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
        <MudText Typo="Typo.h4">@_dto.Name</MudText>
        <MudChip T="string"
                 Size="Size.Small"
                 Color="@(_dto.IsActive ? Color.Success : Color.Default)"
                 Variant="Variant.Filled">
            @(_dto.IsActive ? "Active" : "Inactive")
        </MudChip>
        <MudSpacer />
        @if (_dto.IsActive)
        {
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Warning"
                       StartIcon="@Icons.Material.Filled.PauseCircle"
                       OnClick="DeactivateAsync"
                       Disabled="@_saving">Deactivate</MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.PlayCircle"
                       OnClick="ReactivateAsync"
                       Disabled="@_saving">Reactivate</MudButton>
        }
    </MudStack>

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudPaper Elevation="1" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">Identity</MudText>
                <MudTextField @bind-Value="_renameName"
                              Label="Name"
                              Variant="Variant.Outlined"
                              MaxLength="200" />
                <MudButton Class="mt-2"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Save"
                           OnClick="RenameAsync"
                           Disabled="@(_saving || string.Equals(_renameName, _dto.Name, StringComparison.Ordinal))">
                    Save name
                </MudButton>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudPaper Elevation="1" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">Description</MudText>
                <MudTextField @bind-Value="_descText"
                              Variant="Variant.Outlined"
                              Lines="3"
                              MaxLength="1000" />
                <MudButton Class="mt-2"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Save"
                           OnClick="UpdateDescriptionAsync"
                           Disabled="@(_saving || string.Equals(_descText, _dto.Description, StringComparison.Ordinal))">
                    Save description
                </MudButton>
            </MudPaper>
        </MudItem>
        <MudItem xs="12">
            <MudPaper Elevation="1" Class="pa-4 mb-4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                    <MudText Typo="Typo.h6">Service membership</MudText>
                    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
                        lower DeploymentOrder runs first; ties run in parallel
                    </MudText>
                    <MudSpacer />
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="OpenAddMemberDialog"
                               Disabled="@_saving">
                        Add service
                    </MudButton>
                </MudStack>

                @if (_dto.Services.Count == 0)
                {
                    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
                        No services in this application's catalog yet.
                    </MudText>
                }
                else
                {
                    <MudTable Items="@_dto.Services" T="ApplicationServiceMemberDto" Dense="true" Hover="true">
                        <HeaderContent>
                            <MudTh Style="width: 6rem;">Order</MudTh>
                            <MudTh>Service</MudTh>
                            <MudTh Style="width: 10rem;">Role</MudTh>
                            <MudTh Style="width: 6rem;">Optional</MudTh>
                            <MudTh Style="width: 8rem; text-align: right;"></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd Style="font-family: ui-monospace, monospace;">@context.DeploymentOrder</MudTd>
                            <MudTd>
                                <MudLink Href="@($"/deployment/services/{context.ServiceId}")">@context.ServiceName</MudLink>
                            </MudTd>
                            <MudTd>@context.Role</MudTd>
                            <MudTd>
                                @if (context.IsOptional)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">optional</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">required</MudChip>
                                }
                            </MudTd>
                            <MudTd Style="text-align: right; white-space: nowrap;">
                                <MudTooltip Text="Edit membership">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                   Size="Size.Small"
                                                   OnClick="@(() => OpenEditMemberDialog(context))" />
                                </MudTooltip>
                                <MudTooltip Text="Remove from application">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Size="Size.Small"
                                                   Color="Color.Error"
                                                   OnClick="@(() => RemoveMemberAsync(context))" />
                                </MudTooltip>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>
        </MudItem>
        <MudItem xs="12">
            <ReleasesCard DeployableUnitId="@_dto.Id"
                          DeployableUnitName="@_dto.Name"
                          UnitIsApplication="true" />
        </MudItem>
        <MudItem xs="12">
            <ConfigurationCard DeployableUnitId="@_dto.Id"
                               DeployableUnitName="@_dto.Name" />
        </MudItem>
        <MudItem xs="12">
            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-2">Metadata</MudText>
                <DetailRow Label="Application id" Value="@_dto.Id.ToString()" Mono="true" />
                <DetailRow Label="Created (UTC)" Value="@_dto.CreatedAtUtc.ToString("u")" />
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public string? Id { get; set; }

    private ApplicationDto? _dto;
    private bool _isNew;
    private bool _loading;
    private bool _saving;
    private string? _error;

    private string _newName = "";
    private string _newDesc = "";

    private string _renameName = "";
    private string _descText = "";

    private List<BreadcrumbItem> _crumbs = new();

    protected override async Task OnParametersSetAsync()
    {
        _isNew = string.Equals(Id, "new", StringComparison.OrdinalIgnoreCase);
        _crumbs = new()
        {
            new BreadcrumbItem("Applications", "/deployment/applications"),
            new BreadcrumbItem(_isNew ? "New" : (_dto?.Name ?? "Detail"), href: null, disabled: true),
        };
        if (_isNew) return;
        if (Guid.TryParse(Id, out var id)) await LoadAsync(id);
        else _error = "Invalid application id.";
    }

    private async Task LoadAsync(Guid id)
    {
        _loading = true; _error = null;
        try
        {
            _dto = await Api.GetApplicationAsync(id);
            if (_dto is null)
            {
                _error = $"Application {id} not found.";
                return;
            }
            _renameName = _dto.Name;
            _descText = _dto.Description;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task RegisterAsync()
    {
        _saving = true;
        try
        {
            var body = new RegisterApplicationRequest(_newName.Trim(), _newDesc?.Trim() ?? "");
            var created = await Api.RegisterApplicationAsync(body);
            Snackbar.Add($"Registered '{created.Name}'.", Severity.Success);
            Nav.NavigateTo($"/deployment/applications/{created.Id}");
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _saving = false; }
    }

    private async Task RenameAsync()
    {
        if (_dto is null) return;
        _saving = true;
        try
        {
            await Api.RenameApplicationAsync(_dto.Id, new RenameApplicationRequest(_renameName));
            Snackbar.Add("Renamed.", Severity.Success);
            await LoadAsync(_dto.Id);
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _saving = false; }
    }

    private async Task UpdateDescriptionAsync()
    {
        if (_dto is null) return;
        _saving = true;
        try
        {
            await Api.ChangeApplicationDescriptionAsync(_dto.Id,
                new ChangeApplicationDescriptionRequest(_descText));
            Snackbar.Add("Description updated.", Severity.Success);
            await LoadAsync(_dto.Id);
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _saving = false; }
    }

    private async Task DeactivateAsync()
    {
        if (_dto is null) return;
        _saving = true;
        try
        {
            await Api.DeactivateApplicationAsync(_dto.Id);
            Snackbar.Add("Deactivated.", Severity.Success);
            await LoadAsync(_dto.Id);
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _saving = false; }
    }

    private async Task ReactivateAsync()
    {
        if (_dto is null) return;
        _saving = true;
        try
        {
            await Api.ReactivateApplicationAsync(_dto.Id);
            Snackbar.Add("Reactivated.", Severity.Success);
            await LoadAsync(_dto.Id);
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _saving = false; }
    }

    private async Task OpenAddMemberDialog()
    {
        if (_dto is null) return;
        var services = await Api.ListServicesAsync(onlyActive: true);
        var excludedIds = _dto.Services.Select(m => m.ServiceId).ToHashSet();
        var pickable = services.Where(s => !excludedIds.Contains(s.Id)).ToList();

        var parameters = new DialogParameters
        {
            ["Services"] = pickable,
            ["IsEdit"] = false,
        };
        var dlg = await DialogService.ShowAsync<MembershipDialog>("Add service to application", parameters);
        var result = await dlg.Result;
        if (result is null || result.Canceled || result.Data is not MembershipDialog.Result data) return;

        try
        {
            await Api.AddApplicationMemberAsync(_dto.Id, new AddApplicationMemberRequest(
                data.ServiceId, data.Role, data.IsOptional, data.DeploymentOrder));
            Snackbar.Add("Service added.", Severity.Success);
            await LoadAsync(_dto.Id);
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task OpenEditMemberDialog(ApplicationServiceMemberDto m)
    {
        if (_dto is null) return;
        var parameters = new DialogParameters
        {
            ["IsEdit"] = true,
            ["Existing"] = m,
        };
        var dlg = await DialogService.ShowAsync<MembershipDialog>($"Edit '{m.ServiceName}' membership", parameters);
        var result = await dlg.Result;
        if (result is null || result.Canceled || result.Data is not MembershipDialog.Result data) return;

        try
        {
            await Api.UpdateApplicationMemberAsync(_dto.Id, m.ServiceId,
                new UpdateApplicationMemberRequest(data.Role, data.IsOptional, data.DeploymentOrder));
            Snackbar.Add("Membership updated.", Severity.Success);
            await LoadAsync(_dto.Id);
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task RemoveMemberAsync(ApplicationServiceMemberDto m)
    {
        if (_dto is null) return;
        var parameters = new DialogParameters
        {
            ["Message"] = $"Remove '{m.ServiceName}' from '{_dto.Name}' catalog membership?",
            ["Items"] = (IReadOnlyList<string>)new[] { $"{m.ServiceName} (role: {m.Role}, order: {m.DeploymentOrder})" },
        };
        var dlg = await DialogService.ShowAsync<ConfirmDeleteDialog>(
            $"Remove service from application", parameters);
        var result = await dlg.Result;
        if (result is null || result.Canceled || result.Data is not true) return;

        try
        {
            await Api.RemoveApplicationMemberAsync(_dto.Id, m.ServiceId);
            Snackbar.Add("Removed.", Severity.Success);
            await LoadAsync(_dto.Id);
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }
}
