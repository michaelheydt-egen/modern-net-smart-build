@*
    Shared Configuration table for a single deployable unit (service or app).
    Lives on both ServiceDetail and ApplicationDetail. Filter by env (with a
    "unit default" pseudo-option for EnvironmentId IS NULL rows) so operators
    can focus on one scope at a time. Each row has Edit / History / Delete.
*@

@inject DeploymentApiClient Api
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudPaper Elevation="1" Class="pa-4 mb-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
        <MudText Typo="Typo.h6">Configuration</MudText>
        @if (_settings is { Count: > 0 })
        {
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@_settings.Count</MudChip>
        }
        <MudSpacer />
        <MudSelect T="Guid?"
                   Value="_envFilter"
                   ValueChanged="OnEnvFilterChanged"
                   Label="Scope"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Style="max-width: 16rem;">
            <MudSelectItem T="Guid?" Value="@AllScopes">(all)</MudSelectItem>
            <MudSelectItem T="Guid?" Value="@((Guid?)null)">(unit default)</MudSelectItem>
            @foreach (var e in _environments ?? Array.Empty<EnvironmentDto>())
            {
                <MudSelectItem T="Guid?" Value="@((Guid?)e.Id)">@e.Name</MudSelectItem>
            }
        </MudSelect>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenAddDialog"
                   Disabled="@_loading">
            Add setting
        </MudButton>
    </MudStack>

    @if (_loading && _settings is null)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (_error is { Length: > 0 })
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_error</MudAlert>
    }
    else if (Filtered.Count == 0)
    {
        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
            @(_settings is null or { Count: 0 }
                ? "No configuration settings yet. Click Add setting to create one."
                : "No settings match the current scope filter.")
        </MudText>
    }
    else
    {
        <MudTable Items="@Filtered" T="ConfigurationSettingDto" Dense="true" Hover="true">
            <HeaderContent>
                <MudTh>Key</MudTh>
                <MudTh Style="width: 10rem;">Scope</MudTh>
                <MudTh Style="width: 6rem;">Type</MudTh>
                <MudTh>Value</MudTh>
                <MudTh Style="width: 9rem; text-align: right;"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd Style="font-family: ui-monospace, monospace;">@context.Key</MudTd>
                <MudTd>
                    @if (context.EnvironmentId is null)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">unit default</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                            @(context.EnvironmentName ?? "?")
                        </MudChip>
                    }
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.ValueType</MudChip>
                </MudTd>
                <MudTd Style="font-family: ui-monospace, monospace; font-size: 0.85em;">
                    @if (context.IsSecret)
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Warning" />
                            <span>@context.SecretReference</span>
                        </MudStack>
                    }
                    else
                    {
                        @(context.Value ?? "")
                    }
                </MudTd>
                <MudTd Style="text-align: right; white-space: nowrap;">
                    <MudTooltip Text="History">
                        <MudIconButton Icon="@Icons.Material.Filled.History"
                                       Size="Size.Small"
                                       OnClick="@(() => OpenHistoryDialog(context))" />
                    </MudTooltip>
                    <MudTooltip Text="Edit">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Size="Size.Small"
                                       OnClick="@(() => OpenEditDialog(context))" />
                    </MudTooltip>
                    <MudTooltip Text="Delete">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Size="Size.Small"
                                       Color="Color.Error"
                                       OnClick="@(() => DeleteAsync(context))" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@code {
    [Parameter, EditorRequired] public Guid DeployableUnitId { get; set; }
    [Parameter, EditorRequired] public string DeployableUnitName { get; set; } = "";

    /// <summary>
    /// Sentinel meaning "show all scopes". Distinct from null (which means
    /// "show only unit-default rows where EnvironmentId IS NULL").
    /// </summary>
    private static readonly Guid? AllScopes = Guid.Empty;

    private IReadOnlyList<ConfigurationSettingDto>? _settings;
    private IReadOnlyList<EnvironmentDto>? _environments;
    private Guid? _envFilter = AllScopes;
    private bool _loading;
    private string? _error;

    private IReadOnlyList<ConfigurationSettingDto> Filtered
    {
        get
        {
            if (_settings is null) return Array.Empty<ConfigurationSettingDto>();
            if (_envFilter == AllScopes) return _settings;
            return _settings.Where(s => s.EnvironmentId == _envFilter).ToList();
        }
    }

    protected override Task OnParametersSetAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        if (DeployableUnitId == Guid.Empty) return;
        _loading = true; _error = null;
        try
        {
            // Settings + envs in parallel — both feed the dialog and the filter.
            var sTask = Api.ListConfigurationSettingsAsync(DeployableUnitId);
            var eTask = Api.ListEnvironmentsAsync();
            await Task.WhenAll(sTask, eTask);
            _settings = await sTask;
            _environments = await eTask;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private void OnEnvFilterChanged(Guid? id) => _envFilter = id;

    private async Task OpenAddDialog()
    {
        var parameters = new DialogParameters
        {
            ["IsEdit"] = false,
            ["Environments"] = _environments,
        };
        var dlg = await DialogService.ShowAsync<ConfigurationEditorDialog>(
            $"Add setting for '{DeployableUnitName}'", parameters);
        var result = await dlg.Result;
        if (result is null || result.Canceled || result.Data is not ConfigurationEditorDialog.Result data) return;

        try
        {
            await Api.CreateConfigurationSettingAsync(new CreateConfigurationSettingRequest(
                DeployableUnitId: DeployableUnitId,
                EnvironmentId: data.EnvironmentId,
                Key: data.Key,
                IsSecret: data.IsSecret,
                Value: data.Value,
                SecretReference: data.SecretReference,
                ValueType: data.ValueType,
                ChangedByPrincipal: data.ChangedByPrincipal));
            Snackbar.Add($"Created '{data.Key}'.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task OpenEditDialog(ConfigurationSettingDto s)
    {
        var parameters = new DialogParameters
        {
            ["IsEdit"] = true,
            ["Existing"] = s,
            ["Environments"] = _environments,
        };
        var dlg = await DialogService.ShowAsync<ConfigurationEditorDialog>(
            $"Edit '{s.Key}'", parameters);
        var result = await dlg.Result;
        if (result is null || result.Canceled || result.Data is not ConfigurationEditorDialog.Result data) return;

        try
        {
            await Api.UpdateConfigurationSettingAsync(s.Id, new UpdateConfigurationSettingRequest(
                IsSecret: data.IsSecret,
                Value: data.Value,
                SecretReference: data.SecretReference,
                ValueType: data.ValueType,
                ChangedByPrincipal: data.ChangedByPrincipal));
            Snackbar.Add("Updated.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task OpenHistoryDialog(ConfigurationSettingDto s)
    {
        var parameters = new DialogParameters { ["Setting"] = s };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        await DialogService.ShowAsync<ConfigurationHistoryDialog>(
            $"History — {s.Key}", parameters, options);
    }

    private async Task DeleteAsync(ConfigurationSettingDto s)
    {
        // ChangedByPrincipal is required for the audit event, so use a small
        // prompt dialog rather than just confirm-delete. ConfirmDeleteDialog
        // takes Message + Items only; we wrap with a principal prompt.
        var who = await PromptPrincipalAsync($"Delete '{s.Key}'?");
        if (who is null) return;

        try
        {
            await Api.DeleteConfigurationSettingAsync(s.Id, new DeleteConfigurationSettingRequest(who));
            Snackbar.Add("Deleted.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task<string?> PromptPrincipalAsync(string title)
    {
        var dlg = await DialogService.ShowAsync<PrincipalPromptDialog>(title);
        var result = await dlg.Result;
        if (result is null || result.Canceled || result.Data is not string principal || string.IsNullOrWhiteSpace(principal))
            return null;
        return principal;
    }
}
