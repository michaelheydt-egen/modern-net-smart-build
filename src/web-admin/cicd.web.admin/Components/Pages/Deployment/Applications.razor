@page "/deployment/applications"
@inject DeploymentApiClient Api
@inject NavigationManager Nav

<PageTitle>Deployment — Applications</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Applications</MudText>
    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
        compositions of services
    </MudText>
    <MudSpacer />
    <MudSwitch T="bool"
               @bind-Value="_onlyActive"
               @bind-Value:after="LoadAsync"
               Color="Color.Primary"
               Label="Active only" />
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="@(() => Nav.NavigateTo("/deployment/applications/new"))">
        Register
    </MudButton>
</MudStack>

@if (_error is { Length: > 0 })
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="my-2">@_error</MudAlert>
}

<MudPaper Elevation="1" Class="pa-4 mb-4">
    @if (_loading && _apps is null)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (_apps is { Count: 0 })
    {
        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
            No applications registered yet.
        </MudText>
    }
    else if (_apps is not null)
    {
        <MudTable Items="@_apps"
                  Dense="true"
                  Hover="true"
                  Striped="true"
                  Filter="new Func<ApplicationDto, bool>(MatchesFilter)"
                  T="ApplicationDto">
            <ToolBarContent>
                <MudTextField @bind-Value="_filter"
                              Placeholder="Filter by name or description…"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Small"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Clearable="true"
                              Immediate="true"
                              Style="max-width: 28rem;" />
            </ToolBarContent>
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Description</MudTh>
                <MudTh Style="width: 7rem;">Services</MudTh>
                <MudTh Style="width: 6rem;">Status</MudTh>
                <MudTh Style="width: 6rem; text-align: right;"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudLink Href="@($"/deployment/applications/{context.Id}")">@context.Name</MudLink>
                </MudTd>
                <MudTd>@context.Description</MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                        @context.Services.Count
                    </MudChip>
                </MudTd>
                <MudTd>
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="@(context.IsActive ? Color.Success : Color.Default)"
                             Variant="Variant.Filled">
                        @(context.IsActive ? "Active" : "Inactive")
                    </MudChip>
                </MudTd>
                <MudTd Style="text-align: right; white-space: nowrap;">
                    <MudTooltip Text="Edit">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Size="Size.Small"
                                       OnClick="@(() => Nav.NavigateTo($"/deployment/applications/{context.Id}"))" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@code {
    private IReadOnlyList<ApplicationDto>? _apps;
    private string _filter = "";
    private bool _onlyActive;
    private bool _loading;
    private string? _error;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true; _error = null; StateHasChanged();
        try
        {
            _apps = await Api.ListApplicationsAsync(_onlyActive ? true : null);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; StateHasChanged(); }
    }

    private bool MatchesFilter(ApplicationDto a)
    {
        if (string.IsNullOrWhiteSpace(_filter)) return true;
        var q = _filter.Trim();
        return a.Name.Contains(q, StringComparison.OrdinalIgnoreCase)
               || a.Description.Contains(q, StringComparison.OrdinalIgnoreCase);
    }
}
