@*
    Capture an approval decision. The handler enforces the 4-eyes rule
    server-side (approver ≠ triggerer); we also pre-check it client-side
    so users see the failure immediately.
*@

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width: 460px;">
            <MudText Typo="Typo.body2">
                Deployment triggered by <strong>@TriggeredByPrincipal</strong>.
                A different identity must approve (4-eyes).
            </MudText>
            <MudTextField @bind-Value="_approver"
                          Label="Approver principal"
                          Variant="Variant.Outlined"
                          Required="true"
                          MaxLength="200"
                          AutoFocus="true" />
            <MudRadioGroup T="ApprovalStatusDto" @bind-Value="_verdict">
                <MudRadio T="ApprovalStatusDto" Value="@ApprovalStatusDto.Approved" Color="Color.Success">Approve</MudRadio>
                <MudRadio T="ApprovalStatusDto" Value="@ApprovalStatusDto.Rejected" Color="Color.Error">Reject</MudRadio>
            </MudRadioGroup>
            <MudTextField @bind-Value="_comment"
                          Label="Comment (optional)"
                          Variant="Variant.Outlined"
                          Lines="2"
                          MaxLength="2000" />
            @if (FourEyesViolated)
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true">
                    Approver cannot match the triggerer.
                </MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="@(_verdict == ApprovalStatusDto.Approved ? Color.Success : Color.Error)"
                   Variant="Variant.Filled"
                   OnClick="Submit"
                   Disabled="@(!CanSubmit())">
            @(_verdict == ApprovalStatusDto.Approved ? "Approve" : "Reject")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter, EditorRequired] public string TriggeredByPrincipal { get; set; } = "";

    private string _approver = "";
    private ApprovalStatusDto _verdict = ApprovalStatusDto.Approved;
    private string _comment = "";

    private bool FourEyesViolated =>
        !string.IsNullOrWhiteSpace(_approver)
        && string.Equals(_approver.Trim(), TriggeredByPrincipal, StringComparison.OrdinalIgnoreCase);

    private bool CanSubmit() => !string.IsNullOrWhiteSpace(_approver) && !FourEyesViolated;

    private void Cancel() => MudDialog.Cancel();

    private void Submit() => MudDialog.Close(DialogResult.Ok(new Result(
        _approver.Trim(), _verdict,
        string.IsNullOrWhiteSpace(_comment) ? null : _comment.Trim())));

    public sealed record Result(string ApproverPrincipal, ApprovalStatusDto Verdict, string? Comment);
}
