@*
    Add / edit a DeploymentTarget under an Environment. Region and ResourceId
    are required; Slot is optional and only meaningful for slot-aware targets
    (e.g., App Service deployment slots). For Cloud Run we leave it blank —
    revisions/traffic splits aren't slots.

    ResourceId helper updates per TargetKind so the user sees the expected
    format inline.
*@

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width: 520px;">
            <MudSelect T="TargetKindDto"
                       Value="_kind"
                       ValueChanged="OnKindChanged"
                       Label="Target kind"
                       Variant="Variant.Outlined">
                @foreach (var k in Enum.GetValues<TargetKindDto>())
                {
                    <MudSelectItem Value="@k">@KindLabel(k)</MudSelectItem>
                }
            </MudSelect>
            <MudTextField @bind-Value="_resourceId"
                          Label="Resource id"
                          Variant="Variant.Outlined"
                          Required="true"
                          MaxLength="500"
                          HelperText="@ResourceIdHint" />
            <MudTextField @bind-Value="_region"
                          Label="Region"
                          Variant="Variant.Outlined"
                          Required="true"
                          MaxLength="50"
                          HelperText="@RegionHint" />
            <MudTextField @bind-Value="_slot"
                          Label="Slot (optional)"
                          Variant="Variant.Outlined"
                          MaxLength="100"
                          HelperText="@SlotHint" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Submit"
                   Disabled="@(!CanSubmit())">
            @(IsEdit ? "Save" : "Add")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public bool IsEdit { get; set; }
    [Parameter] public DeploymentTargetDto? Existing { get; set; }

    private TargetKindDto _kind = TargetKindDto.GoogleCloudRun;
    private string _resourceId = "";
    private string _region = "";
    private string _slot = "";

    protected override void OnInitialized()
    {
        if (IsEdit && Existing is not null)
        {
            _kind = Existing.TargetKind;
            _resourceId = Existing.ResourceId;
            _region = Existing.Region;
            _slot = Existing.Slot ?? "";
        }
    }

    private void OnKindChanged(TargetKindDto k)
    {
        _kind = k;
        // Cloud Run uses revisions/traffic, not slots — clear stale slot input
        // when switching to it so the saved row matches the convention.
        if (k == TargetKindDto.GoogleCloudRun) _slot = "";
    }

    private static string KindLabel(TargetKindDto k) => k switch
    {
        TargetKindDto.IIS => "IIS",
        TargetKindDto.AzureAppService => "Azure App Service",
        TargetKindDto.KubernetesCluster => "Kubernetes cluster",
        TargetKindDto.ContainerApp => "Azure Container Apps",
        TargetKindDto.VM => "Virtual machine",
        TargetKindDto.GoogleCloudRun => "Google Cloud Run",
        _ => k.ToString(),
    };

    private string ResourceIdHint => _kind switch
    {
        TargetKindDto.IIS => "e.g. server01:DefaultAppPool/SiteName",
        TargetKindDto.AzureAppService => "e.g. /subscriptions/{sub}/resourceGroups/{rg}/providers/Microsoft.Web/sites/{name}",
        TargetKindDto.KubernetesCluster => "e.g. cluster-name/namespace",
        TargetKindDto.ContainerApp => "e.g. /subscriptions/{sub}/resourceGroups/{rg}/providers/Microsoft.App/containerApps/{name}",
        TargetKindDto.VM => "e.g. inventory hostname or instance id",
        TargetKindDto.GoogleCloudRun => "e.g. projects/{project}/locations/{region}/services/{service}",
        _ => "",
    };

    private string RegionHint => _kind switch
    {
        TargetKindDto.AzureAppService or TargetKindDto.ContainerApp => "e.g. eastus, westeurope",
        TargetKindDto.GoogleCloudRun => "e.g. us-central1, europe-west1",
        TargetKindDto.KubernetesCluster => "e.g. us-east, on-prem",
        _ => "Free-form — used by Q1′ to group by region.",
    };

    private string SlotHint => _kind switch
    {
        TargetKindDto.AzureAppService => "Optional — e.g. 'staging' for slot swap.",
        TargetKindDto.GoogleCloudRun => "Not used for Cloud Run (revision/traffic instead).",
        _ => "Optional — leave blank if not applicable.",
    };

    private bool CanSubmit() =>
        !string.IsNullOrWhiteSpace(_resourceId)
        && !string.IsNullOrWhiteSpace(_region);

    private void Cancel() => MudDialog.Cancel();

    private void Submit() => MudDialog.Close(DialogResult.Ok(new Result(
        _kind, _resourceId.Trim(), _region.Trim(),
        string.IsNullOrWhiteSpace(_slot) ? null : _slot.Trim())));

    public sealed record Result(
        TargetKindDto TargetKind,
        string ResourceId,
        string Region,
        string? Slot);
}
