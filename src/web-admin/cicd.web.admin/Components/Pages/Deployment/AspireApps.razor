@page "/deployment/aspire-apps"
@inject DeploymentApiClient Api
@inject ISnackbar Snackbar

<PageTitle>Deployment — Aspire apps</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Aspire applications</MudText>
    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">deploy a whole .NET Aspire app to Kubernetes via Aspir8 (images pulled from Nexus)</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadAsync">Refresh</MudButton>
</MudStack>

@if (_error is { Length: > 0 }) { <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="my-2">@_error</MudAlert> }

<MudExpansionPanels Class="mb-4">
    <MudExpansionPanel Text="Register an Aspire application">
        @if (_k8sEnvs is { Count: 0 })
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No Kubernetes environments yet — add one under Environments (set its Kube context + namespace) first.</MudAlert>
        }
        else
        {
            <MudGrid>
                <MudItem xs="12" md="6"><MudTextField @bind-Value="_name" Label="Name" Required="true" /></MudItem>
                <MudItem xs="12" md="6"><MudTextField @bind-Value="_description" Label="Description (optional)" /></MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="Guid?" @bind-Value="_environmentId" Label="Environment (Kubernetes target)" Required="true">
                        @foreach (var e in _k8sEnvs ?? new List<EnvironmentDto>())
                        { <MudSelectItem T="Guid?" Value="@e.Id">@e.Name (@e.KubernetesContext/@e.KubernetesNamespace)</MudSelectItem> }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6"><MudTextField @bind-Value="_version" Label="Version (optional)" /></MudItem>
                <MudItem xs="12" md="6"><MudTextField @bind-Value="_sourceKey" Label="CI source key (optional)" HelperText="the AspireAppPublished app name that feeds this app; defaults to Name" /></MudItem>
                <MudItem xs="12"><MudTextField @bind-Value="_manifestSource" Label="Manifest source (URL to the aspirate kustomize-output archive)" Required="true" HelperText="e.g. http://localhost:8081/repository/raw/myapp/1.0.0/aspirate-output.zip" /></MudItem>
                <MudItem xs="12">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="RegisterAsync" Disabled="_busy">Register</MudButton>
                </MudItem>
            </MudGrid>
        }
    </MudExpansionPanel>
</MudExpansionPanels>

<MudPaper Elevation="1" Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" Class="mb-2">Registered apps</MudText>
    @if (_loading && _apps is null) { <MudProgressLinear Indeterminate="true" /> }
    else if (_apps is { Count: 0 }) { <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">No Aspire apps registered yet.</MudText> }
    else if (_apps is not null)
    {
        <MudTable Items="@_apps" Dense="true" Hover="true" Striped="true" T="AspireApplicationDto">
            <HeaderContent><MudTh>Name</MudTh><MudTh>Environment</MudTh><MudTh>Version</MudTh><MudTh>Manifest source</MudTh><MudTh Style="width:7rem;">Auto-deploy</MudTh><MudTh Style="width:12rem;">Actions</MudTh></HeaderContent>
            <RowTemplate>
                <MudTd>
                    @context.Name
                    @if (!string.IsNullOrEmpty(context.SourceKey) && context.SourceKey != context.Name)
                    { <MudTooltip Text="CI source key this app tracks"><MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default" Icon="@Icons.Material.Filled.Link">@context.SourceKey</MudChip></MudTooltip> }
                </MudTd>
                <MudTd>@context.EnvironmentName</MudTd>
                <MudTd Style="font-family: ui-monospace, monospace; font-size:0.85em;">@(context.Version ?? "—")</MudTd>
                <MudTd Style="font-family: ui-monospace, monospace; font-size:0.78em; max-width:24rem; overflow:hidden; text-overflow:ellipsis;">@context.ManifestSource</MudTd>
                <MudTd>
                    <MudTooltip Text="When on, a CI publish of this app auto-triggers a deployment.">
                        <MudSwitch T="bool" Value="context.AutoDeploy" Color="Color.Primary" Size="Size.Small"
                                   ValueChanged="@(v => ToggleAutoDeployAsync(context, v))" Disabled="_busy" />
                    </MudTooltip>
                </MudTd>
                <MudTd>
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.RocketLaunch" OnClick="@(() => DeployAsync(context))" Disabled="_busy">Deploy</MudButton>
                    <MudTooltip Text="Live status — cluster health + drift for this app"><MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.MonitorHeart" OnClick="@(() => OpenStatusAsync(context))" Disabled="_busy" /></MudTooltip>
                    <MudTooltip Text="Promote this app's current manifest to another environment"><MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.MoveUp" OnClick="@(() => OpenPromote(context))" Disabled="_busy" /></MudTooltip>
                    <MudTooltip Text="Edit (name, environment, manifest source, …)"><MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Edit" OnClick="@(() => OpenEdit(context))" /></MudTooltip>
                    <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => DeleteAsync(context))" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

<MudPaper Elevation="1" Class="pa-4">
    <MudText Typo="Typo.h6" Class="mb-2">Recent deployments</MudText>
    @if (_runs is { Count: 0 }) { <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">No deployments yet.</MudText> }
    else if (_runs is not null)
    {
        <MudTable Items="@_runs" Dense="true" Hover="true" Striped="true" T="AspireApplicationRunDto">
            <HeaderContent><MudTh Style="width:7rem;">Status</MudTh><MudTh>App</MudTh><MudTh>Environment</MudTh><MudTh>By</MudTh><MudTh Style="width:11rem;">When</MudTh><MudTh Style="width:5rem;"></MudTh></HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Status)" Variant="Variant.Filled">@context.Status</MudChip>
                    @if ((context.Status == AspireRunStatusDto.Failed || context.Status == AspireRunStatusDto.Rejected) && !string.IsNullOrEmpty(context.FailureReason))
                    { <MudTooltip Text="@context.FailureReason"><MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Error" Size="Size.Small" /></MudTooltip> }
                </MudTd>
                <MudTd>@context.ApplicationName</MudTd>
                <MudTd>@context.EnvironmentName (@context.Namespace)</MudTd>
                <MudTd>@context.TriggeredBy</MudTd>
                <MudTd>@context.RequestedAtUtc.LocalDateTime.ToString("g")</MudTd>
                <MudTd>
                    <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@(() => ShowLog(context))">Log</MudButton>
                    @if (context.Status == AspireRunStatusDto.AwaitingApproval)
                    {
                        <MudTooltip Text="Approve — deploy to this protected environment now">
                            <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small" Disabled="_busy" OnClick="@(() => ApproveRunAsync(context))" />
                        </MudTooltip>
                        <MudTooltip Text="Reject — cancel this deploy">
                            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small" Disabled="_busy" OnClick="@(() => RejectRunAsync(context))" />
                        </MudTooltip>
                    }
                    @if (context.Status == AspireRunStatusDto.Succeeded)
                    {
                        <MudTooltip Text="Roll the app back to this deploy's manifest">
                            <MudIconButton Icon="@Icons.Material.Filled.Restore" Size="Size.Small" Disabled="_busy" OnClick="@(() => RollbackAsync(context))" />
                        </MudTooltip>
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

<MudDialog @bind-Visible="_promoteShow" Options="_promoteDlg">
    <TitleContent>Promote @_promoteApp?.Name</TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-2" Style="color: var(--mud-palette-text-secondary);">
            Deploys this app's current manifest (@(_promoteApp?.Version ?? "—")) to another Kubernetes environment. The images are digest-pinned, so it runs the exact same artifacts.
        </MudText>
        @if (_k8sEnvs is { Count: 0 })
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">No Kubernetes environments exist — add one under Environments first.</MudAlert>
        }
        <MudSelect T="Guid?" @bind-Value="_promoteEnvId" Label="Target environment" Required="true">
            @foreach (var e in _k8sEnvs ?? new List<EnvironmentDto>())
            { <MudSelectItem T="Guid?" Value="@e.Id">@e.Name (@e.KubernetesContext/@e.KubernetesNamespace)</MudSelectItem> }
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _promoteShow = false)">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ConfirmPromoteAsync" Disabled="_busy">Promote</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_editShow" Options="_editDlg">
    <TitleContent>Edit @_editName</TitleContent>
    <DialogContent>
        @if (_k8sEnvs is { Count: 0 })
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">No Kubernetes environments exist — add one under Environments (Kube context + namespace) before you can point this app at one.</MudAlert>
        }
        <MudGrid>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_editName" Label="Name" Required="true" /></MudItem>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_editDescription" Label="Description (optional)" /></MudItem>
            <MudItem xs="12" md="6">
                <MudSelect T="Guid?" @bind-Value="_editEnvironmentId" Label="Environment (Kubernetes target)" Required="true">
                    @foreach (var e in _k8sEnvs ?? new List<EnvironmentDto>())
                    { <MudSelectItem T="Guid?" Value="@e.Id">@e.Name (@e.KubernetesContext/@e.KubernetesNamespace)</MudSelectItem> }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_editVersion" Label="Version (optional)" /></MudItem>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="_editSourceKey" Label="CI source key (optional)" HelperText="AspireAppPublished app name that feeds this app; defaults to Name" /></MudItem>
            <MudItem xs="12"><MudTextField @bind-Value="_editManifestSource" Label="Manifest source (URL to the aspirate kustomize-output archive)" Required="true" /></MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _editShow = false)">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveEditAsync" Disabled="_busy">Save</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_statusShow" Options="_statusDlg">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.MonitorHeart" />
            <MudText Typo="Typo.h6">@(_status?.ApplicationName ?? "Status")</MudText>
            @if (_status is not null && _status.Reachable)
            { <MudChip T="string" Size="Size.Small" Color="@HealthColor(_status.OverallHealth)" Variant="Variant.Filled">@_status.OverallHealth</MudChip> }
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (_statusLoading) { <MudProgressLinear Indeterminate="true" Class="my-2" /> }
        else if (_status is null) { <MudText Typo="Typo.body2">No status.</MudText> }
        else
        {
            <MudText Typo="Typo.body2" Class="mb-2" Style="color: var(--mud-palette-text-secondary);">
                @_status.EnvironmentName · @(_status.KubeContext ?? "—")/@(_status.Namespace ?? "—")
            </MudText>

            @if (!_status.Reachable)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="my-2">@(_status.Error ?? "Cluster unreachable.")</MudAlert>
            }
            else if (!string.IsNullOrEmpty(_status.Error))
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="my-2">@_status.Error</MudAlert>
            }

            @if (_status.HasUndeployedChanges)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Icon="@Icons.Material.Filled.SyncProblem" Class="my-2">
                    Undeployed changes — the app's current manifest (@(_status.CurrentVersion ?? "—")) differs from the last deploy (@(_status.LastDeployedVersion ?? "—")). Deploy to roll them out.
                </MudAlert>
            }

            @if (_status.HasImageDrift)
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Warning" Class="my-2">
                    Image drift — a live workload is running a different image than this app last deployed (see the flagged rows below). The cluster was changed out of band; redeploy to reconcile.
                </MudAlert>
            }

            <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                Last deployed: @(_status.LastDeployedAtUtc is { } t ? t.LocalDateTime.ToString("g") : "never")
                @(_status.LastDeployedVersion is { Length: > 0 } v ? $" · {v}" : "")
            </MudText>

            @if (_status.Reachable && _status.Workloads.Count > 0)
            {
                <MudTable Items="@_status.Workloads" Dense="true" Hover="true" T="WorkloadStatusDto" Class="mt-3">
                    <HeaderContent><MudTh Style="width:6rem;">Health</MudTh><MudTh>Workload</MudTh><MudTh>Image</MudTh><MudTh Style="width:6rem;">Ready</MudTh><MudTh Style="width:6rem;">Restarts</MudTh></HeaderContent>
                    <RowTemplate>
                        <MudTd><MudChip T="string" Size="Size.Small" Color="@HealthColor(context.Health)" Variant="Variant.Filled">@context.Health</MudChip></MudTd>
                        <MudTd>@context.Name</MudTd>
                        <MudTd Style="font-family: ui-monospace, monospace; font-size:0.75em; max-width:22rem;">
                            <div style="overflow:hidden; text-overflow:ellipsis;">@(context.Image ?? "—")</div>
                            @if (context.Drifted)
                            {
                                <MudTooltip Text="@($"Expected (last deployed): {context.ExpectedImage}")">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Text" Icon="@Icons.Material.Filled.Warning">drift</MudChip>
                                </MudTooltip>
                            }
                        </MudTd>
                        <MudTd>@context.ReadyReplicas / @context.DesiredReplicas</MudTd>
                        <MudTd>@context.Pods.Sum(p => p.Restarts)</MudTd>
                    </RowTemplate>
                </MudTable>
            }
            else if (_status.Reachable)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-3">No workloads found in this namespace — the app may not be deployed yet.</MudAlert>
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton StartIcon="@Icons.Material.Filled.Refresh" OnClick="@(() => RefreshStatusAsync())" Disabled="_statusLoading">Refresh</MudButton>
        <MudButton OnClick="@(() => _statusShow = false)">Close</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_logShow" Options="_logDlg">
    <TitleContent>@(_logRun is null ? "Run" : $"{_logRun.ApplicationName} — {_logRun.Status}")</TitleContent>
    <DialogContent>
        @if (_logRun is not null)
        {
            <MudText Typo="Typo.body2" Class="mb-1">@_logRun.EnvironmentName · @_logRun.KubeContext/@_logRun.Namespace · @(_logRun.Version ?? "—")</MudText>
            <MudText Typo="Typo.caption" Style="font-family: ui-monospace, monospace; word-break: break-all;">@_logRun.ManifestSource</MudText>
            @if (!string.IsNullOrEmpty(_logRun.FailureReason))
            { <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="my-2">@_logRun.FailureReason</MudAlert> }
            <MudPaper Outlined="true" Class="pa-2 mt-2" Style="max-height:50vh; overflow:auto; background: var(--mud-palette-background-grey);">
                <pre style="margin:0; white-space:pre-wrap; font-size:0.8em;">@(_logRun.Log ?? "(no log)")</pre>
            </MudPaper>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _logShow = false)">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private IReadOnlyList<AspireApplicationDto>? _apps;
    private IReadOnlyList<AspireApplicationRunDto>? _runs;
    private List<EnvironmentDto>? _k8sEnvs;
    private bool _loading, _busy;
    private string? _error;

    private string _name = "", _description = "", _manifestSource = "", _version = "", _sourceKey = "";
    private Guid? _environmentId;

    private bool _logShow;
    private AspireApplicationRunDto? _logRun;
    private static readonly DialogOptions _logDlg = new() { MaxWidth = MaxWidth.Large, FullWidth = true };

    private bool _promoteShow;
    private static readonly DialogOptions _promoteDlg = new() { MaxWidth = MaxWidth.Small, FullWidth = true };
    private AspireApplicationDto? _promoteApp;
    private Guid? _promoteEnvId;

    private bool _statusShow, _statusLoading;
    private static readonly DialogOptions _statusDlg = new() { MaxWidth = MaxWidth.Large, FullWidth = true };
    private Guid _statusAppId;
    private AspireAppStatusDto? _status;

    private bool _editShow;
    private static readonly DialogOptions _editDlg = new() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    private Guid _editId;
    private string _editName = "", _editDescription = "", _editManifestSource = "", _editVersion = "", _editSourceKey = "";
    private Guid? _editEnvironmentId;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true; _error = null; StateHasChanged();
        try
        {
            _apps = await Api.ListAspireAppsAsync();
            _runs = await Api.ListAspireRunsAsync();
            var envs = await Api.ListEnvironmentsAsync();
            _k8sEnvs = envs.Where(e => !string.IsNullOrEmpty(e.KubernetesContext) && !string.IsNullOrEmpty(e.KubernetesNamespace)).ToList();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; StateHasChanged(); }
    }

    private async Task RegisterAsync()
    {
        if (_environmentId is not { } envId) { Snackbar.Add("Pick an environment.", Severity.Warning); return; }
        _busy = true;
        try
        {
            await Api.CreateAspireAppAsync(new CreateAspireApplicationRequest(_name, _description, envId, _manifestSource, string.IsNullOrWhiteSpace(_version) ? null : _version, string.IsNullOrWhiteSpace(_sourceKey) ? null : _sourceKey));
            Snackbar.Add($"Registered '{_name}'.", Severity.Success);
            _name = _description = _manifestSource = _version = _sourceKey = ""; _environmentId = null;
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _busy = false; }
    }

    private async Task DeployAsync(AspireApplicationDto app)
    {
        _busy = true;
        try
        {
            var r = await Api.DeployAspireAppAsync(app.Id, new TriggerAspireDeploymentRequest("ui"));
            Snackbar.Add(r.Outcome == "requested" ? $"Deploy of '{app.Name}' queued." : $"Deploy: {r.Outcome}",
                r.Outcome == "requested" ? Severity.Info : Severity.Warning);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _busy = false; }
    }

    private async Task DeleteAsync(AspireApplicationDto app)
    {
        try { await Api.DeleteAspireAppAsync(app.Id); await LoadAsync(); }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private void OpenPromote(AspireApplicationDto app)
    {
        _promoteApp = app;
        _promoteEnvId = null;
        _promoteShow = true;
    }

    private async Task ConfirmPromoteAsync()
    {
        if (_promoteApp is not { } app) return;
        if (_promoteEnvId is not { } envId) { Snackbar.Add("Pick a target environment.", Severity.Warning); return; }
        _busy = true;
        try
        {
            var r = await Api.PromoteAspireAppAsync(app.Id, envId);
            var envName = _k8sEnvs?.FirstOrDefault(e => e.Id == envId)?.Name ?? "target";
            Snackbar.Add(r.Outcome == "requested" ? $"Promotion of '{app.Name}' to {envName} queued." : $"Promote: {r.Outcome}",
                r.Outcome == "requested" ? Severity.Info : Severity.Warning);
            _promoteShow = false;
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _busy = false; }
    }

    private void OpenEdit(AspireApplicationDto app)
    {
        _editId = app.Id;
        _editName = app.Name;
        _editDescription = app.Description ?? "";
        _editEnvironmentId = app.EnvironmentId;   // if the env is missing/dangling it won't match a list item → user re-picks
        _editManifestSource = app.ManifestSource;
        _editVersion = app.Version ?? "";
        _editSourceKey = app.SourceKey ?? "";
        _editShow = true;
    }

    private async Task SaveEditAsync()
    {
        if (_editEnvironmentId is not { } envId) { Snackbar.Add("Pick an environment.", Severity.Warning); return; }
        _busy = true;
        try
        {
            await Api.UpdateAspireAppAsync(_editId, new UpdateAspireApplicationRequest(
                _editName, string.IsNullOrWhiteSpace(_editDescription) ? null : _editDescription, envId, _editManifestSource,
                string.IsNullOrWhiteSpace(_editVersion) ? null : _editVersion,
                string.IsNullOrWhiteSpace(_editSourceKey) ? null : _editSourceKey));
            Snackbar.Add($"Updated '{_editName}'.", Severity.Success);
            _editShow = false;
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _busy = false; }
    }

    private async Task ToggleAutoDeployAsync(AspireApplicationDto app, bool value)
    {
        _busy = true;
        try
        {
            await Api.SetAspireAutoDeployAsync(app.Id, value);
            Snackbar.Add($"Auto-deploy {(value ? "enabled" : "disabled")} for '{app.Name}'.", Severity.Info);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _busy = false; }
    }

    private async Task OpenStatusAsync(AspireApplicationDto app)
    {
        _statusAppId = app.Id;
        _status = null;
        _statusShow = true;
        await RefreshStatusAsync();
    }

    private async Task RefreshStatusAsync()
    {
        _statusLoading = true; StateHasChanged();
        try { _status = await Api.GetAspireAppStatusAsync(_statusAppId); }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _statusLoading = false; StateHasChanged(); }
    }

    private static Color HealthColor(WorkloadHealthDto h) => h switch
    {
        WorkloadHealthDto.Healthy => Color.Success,
        WorkloadHealthDto.Degraded => Color.Warning,
        WorkloadHealthDto.Down => Color.Error,
        _ => Color.Default,
    };

    private void ShowLog(AspireApplicationRunDto run) { _logRun = run; _logShow = true; }

    private async Task RollbackAsync(AspireApplicationRunDto run)
    {
        _busy = true;
        try
        {
            var r = await Api.RollbackAspireAppAsync(run.ApplicationId, run.Id);
            var label = run.Version ?? run.Id.ToString("N")[..8];
            Snackbar.Add(r.Outcome == "requested" ? $"Rollback of '{run.ApplicationName}' to {label} queued." : $"Rollback: {r.Outcome}",
                r.Outcome == "requested" ? Severity.Info : Severity.Warning);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _busy = false; }
    }

    private async Task ApproveRunAsync(AspireApplicationRunDto run)
    {
        _busy = true;
        try
        {
            await Api.ApproveAspireRunAsync(run.Id);
            Snackbar.Add($"Approved — deploying '{run.ApplicationName}' to {run.EnvironmentName}.", Severity.Info);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _busy = false; }
    }

    private async Task RejectRunAsync(AspireApplicationRunDto run)
    {
        _busy = true;
        try
        {
            await Api.RejectAspireRunAsync(run.Id);
            Snackbar.Add($"Rejected deploy of '{run.ApplicationName}' to {run.EnvironmentName}.", Severity.Warning);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _busy = false; }
    }

    private static Color StatusColor(AspireRunStatusDto s) => s switch
    {
        AspireRunStatusDto.Succeeded => Color.Success,
        AspireRunStatusDto.Failed => Color.Error,
        AspireRunStatusDto.Rejected => Color.Error,
        AspireRunStatusDto.Running => Color.Info,
        AspireRunStatusDto.AwaitingApproval => Color.Warning,
        _ => Color.Default,
    };
}
