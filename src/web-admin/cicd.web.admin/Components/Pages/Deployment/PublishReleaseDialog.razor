@*
    Publish-a-release form. For Service units, the user picks an ArtifactType
    (Zip/ContainerImage/NuGet) and provides an ArtifactUri. For Application
    units, ArtifactType is forced to Manifest and ArtifactUri is hidden.
*@

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width: 480px;">
            <MudTextField @bind-Value="_semver"
                          Label="Semantic version"
                          Variant="Variant.Outlined"
                          Required="true"
                          MaxLength="64"
                          HelperText="e.g. 1.2.3" />
            <MudTextField @bind-Value="_buildNumber"
                          Label="Build number"
                          Variant="Variant.Outlined"
                          Required="true"
                          MaxLength="64"
                          HelperText="e.g. cicd-build/#42" />
            <MudTextField @bind-Value="_commitSha"
                          Label="Commit SHA"
                          Variant="Variant.Outlined"
                          Required="true"
                          MaxLength="64"
                          HelperText="Full git SHA — e.g. abc123def456…" />

            @if (UnitIsApplication)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                    Application releases are manifest-only (BOM). Add member compositions
                    on the release detail page after publishing.
                </MudAlert>
            }
            else
            {
                <MudSelect T="ArtifactTypeDto"
                           @bind-Value="_artifactType"
                           Label="Artifact type"
                           Variant="Variant.Outlined">
                    <MudSelectItem Value="@ArtifactTypeDto.ContainerImage">Container Image</MudSelectItem>
                    <MudSelectItem Value="@ArtifactTypeDto.NuGet">NuGet</MudSelectItem>
                    <MudSelectItem Value="@ArtifactTypeDto.Zip">Zip</MudSelectItem>
                </MudSelect>
                <MudTextField @bind-Value="_artifactUri"
                              Label="Artifact URI"
                              Variant="Variant.Outlined"
                              Required="true"
                              MaxLength="500"
                              HelperText="@UriHint" />
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.NewReleases"
                   OnClick="Submit"
                   Disabled="@(!CanSubmit())">
            Publish
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public bool UnitIsApplication { get; set; }
    [Parameter] public string UnitName { get; set; } = "";

    private string _semver = "";
    private string _buildNumber = "";
    private string _commitSha = "";
    private ArtifactTypeDto _artifactType = ArtifactTypeDto.ContainerImage;
    private string _artifactUri = "";

    private string UriHint => _artifactType switch
    {
        ArtifactTypeDto.ContainerImage => "e.g. registry.example.com/billing-api:1.2.3",
        ArtifactTypeDto.NuGet => "e.g. https://nexus/repository/nuget-hosted/billing.contracts/1.2.3",
        ArtifactTypeDto.Zip => "e.g. https://nexus/repository/raw/billing-api-1.2.3.zip",
        _ => "",
    };

    private bool CanSubmit()
    {
        if (string.IsNullOrWhiteSpace(_semver)) return false;
        if (string.IsNullOrWhiteSpace(_buildNumber)) return false;
        if (string.IsNullOrWhiteSpace(_commitSha)) return false;
        if (!UnitIsApplication && string.IsNullOrWhiteSpace(_artifactUri)) return false;
        return true;
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        var type = UnitIsApplication ? ArtifactTypeDto.Manifest : _artifactType;
        var uri = UnitIsApplication ? null : _artifactUri.Trim();
        MudDialog.Close(DialogResult.Ok(new Result(
            _semver.Trim(), _buildNumber.Trim(), _commitSha.Trim(), type, uri)));
    }

    public sealed record Result(
        string SemanticVersion,
        string BuildNumber,
        string CommitSha,
        ArtifactTypeDto ArtifactType,
        string? ArtifactUri);
}
