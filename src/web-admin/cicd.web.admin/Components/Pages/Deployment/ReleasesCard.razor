@*
    Shared "Releases" table for a single deployable unit (service or application).
    Lives on both ServiceDetail and ApplicationDetail to give each unit its
    own catalog of versions. Click a release to navigate to its dedicated
    detail page; Publish opens a dialog that POSTs PublishReleaseRequest.

    The card auto-selects ArtifactType=Manifest with a null ArtifactUri when
    UnitIsApplication is true so the publish form matches the domain
    invariant (Application releases are BOM-only).
*@

@inject DeploymentApiClient Api
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudPaper Elevation="1" Class="pa-4 mb-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
        <MudText Typo="Typo.h6">Releases</MudText>
        @if (_releases is { Count: > 0 })
        {
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@_releases.Count</MudChip>
        }
        <MudSpacer />
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.NewReleases"
                   OnClick="OpenPublishDialog"
                   Disabled="@_loading">
            Publish release
        </MudButton>
    </MudStack>

    @if (_loading && _releases is null)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (_error is { Length: > 0 })
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_error</MudAlert>
    }
    else if (_releases is { Count: 0 })
    {
        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
            No releases published yet.
        </MudText>
    }
    else if (_releases is not null)
    {
        <MudTable Items="@_releases" T="ReleaseDto" Dense="true" Hover="true">
            <HeaderContent>
                <MudTh Style="width: 9rem;">Version</MudTh>
                <MudTh Style="width: 8rem;">Build #</MudTh>
                <MudTh Style="width: 10rem;">Commit</MudTh>
                <MudTh Style="width: 8rem;">Artifact</MudTh>
                <MudTh Style="width: 6rem;">Status</MudTh>
                <MudTh Style="width: 10rem;">Created (UTC)</MudTh>
                <MudTh Style="width: 6rem;">Provenance</MudTh>
                <MudTh Style="width: 4rem; text-align: right;"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudLink Href="@($"/deployment/releases/{context.Id}")"
                             Style="font-family: ui-monospace, monospace;">
                        @context.SemanticVersion
                    </MudLink>
                </MudTd>
                <MudTd Style="font-family: ui-monospace, monospace; font-size: 0.85em;">@context.BuildNumber</MudTd>
                <MudTd Style="font-family: ui-monospace, monospace; font-size: 0.85em;">
                    @ShortSha(context.CommitSha)
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.ArtifactType</MudChip>
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Status)" Variant="Variant.Filled">
                        @context.Status
                    </MudChip>
                </MudTd>
                <MudTd Style="font-size: 0.85em;">@context.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</MudTd>
                <MudTd>
                    @if (context.Provenance is not null)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Small" Color="Color.Success" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Outlined.Shield" Size="Size.Small"
                                 Style="color: var(--mud-palette-text-secondary);" />
                    }
                </MudTd>
                <MudTd Style="text-align: right;">
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowForward"
                                   Size="Size.Small"
                                   OnClick="@(() => Nav.NavigateTo($"/deployment/releases/{context.Id}"))" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@code {
    [Parameter, EditorRequired] public Guid DeployableUnitId { get; set; }
    [Parameter, EditorRequired] public string DeployableUnitName { get; set; } = "";
    [Parameter] public bool UnitIsApplication { get; set; }

    private IReadOnlyList<ReleaseDto>? _releases;
    private bool _loading;
    private string? _error;

    protected override Task OnParametersSetAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        if (DeployableUnitId == Guid.Empty) return;
        _loading = true; _error = null;
        try
        {
            _releases = await Api.ListReleasesAsync(DeployableUnitId);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task OpenPublishDialog()
    {
        var parameters = new DialogParameters
        {
            ["UnitIsApplication"] = UnitIsApplication,
            ["UnitName"] = DeployableUnitName,
        };
        var dlg = await DialogService.ShowAsync<PublishReleaseDialog>(
            $"Publish release of '{DeployableUnitName}'", parameters);
        var result = await dlg.Result;
        if (result is null || result.Canceled || result.Data is not PublishReleaseDialog.Result data) return;

        try
        {
            var body = new PublishReleaseRequest(
                DeployableUnitId,
                data.SemanticVersion, data.BuildNumber, data.CommitSha,
                data.ArtifactType, data.ArtifactUri);
            var id = await Api.PublishReleaseAsync(body);
            Snackbar.Add($"Published v{data.SemanticVersion}.", Severity.Success);
            Nav.NavigateTo($"/deployment/releases/{id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private static string ShortSha(string sha) =>
        string.IsNullOrEmpty(sha) ? "" : (sha.Length > 8 ? sha[..8] : sha);

    private static Color StatusColor(ReleaseStatusDto s) => s switch
    {
        ReleaseStatusDto.Available => Color.Success,
        ReleaseStatusDto.Superseded => Color.Default,
        ReleaseStatusDto.Quarantined => Color.Error,
        _ => Color.Default,
    };
}
