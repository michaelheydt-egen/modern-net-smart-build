@page "/deployment/releases/{Id:guid}"
@inject DeploymentApiClient Api
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Deployment — Release @_dto?.SemanticVersion</PageTitle>

<MudBreadcrumbs Items="@_crumbs" Class="mb-2" />

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_error is { Length: > 0 })
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="my-2">@_error</MudAlert>
}
else if (_dto is not null)
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
        <MudText Typo="Typo.h4" Style="font-family: ui-monospace, monospace;">
            v@_dto.SemanticVersion
        </MudText>
        <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">
            @_dto.DeployableUnitName
        </MudText>
        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@_dto.ArtifactType</MudChip>
        <MudChip T="string" Size="Size.Small"
                 Color="@StatusColor(_dto.Status)" Variant="Variant.Filled">
            @_dto.Status
        </MudChip>
        <MudSpacer />
        @if (_dto.Status == ReleaseStatusDto.Available)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.RocketLaunch"
                       OnClick="@(() => Nav.NavigateTo($"/deployment/deployments/new?releaseId={_dto.Id}"))">
                Deploy this release
            </MudButton>
        }
        <MudButton Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.SwapHoriz"
                   OnClick="OpenChangeStatusDialog">Change status</MudButton>
        <MudButton Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.VerifiedUser"
                   OnClick="OpenProvenanceDialog">
            @(_dto.Provenance is null ? "Attach provenance" : "Edit provenance")
        </MudButton>
    </MudStack>

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudPaper Elevation="1" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">Build binding</MudText>
                <DetailRow Label="Build number" Value="@_dto.BuildNumber" Mono="true" />
                <DetailRow Label="Commit SHA" Value="@_dto.CommitSha" Mono="true" />
                <DetailRow Label="Created (UTC)" Value="@_dto.CreatedAtUtc.ToString("u")" />
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudPaper Elevation="1" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">Artifact</MudText>
                <DetailRow Label="Type" Value="@_dto.ArtifactType.ToString()" />
                @if (_dto.ArtifactType == ArtifactTypeDto.Manifest)
                {
                    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
                        Manifest release — no artifact URI. BOM lives below.
                    </MudText>
                }
                else
                {
                    <DetailRow Label="URI" Value="@(_dto.ArtifactUri ?? "")" Mono="true" />
                }
            </MudPaper>
        </MudItem>
        <MudItem xs="12">
            <MudPaper Elevation="1" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">Provenance</MudText>
                @if (_dto.Provenance is null)
                {
                    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
                        No provenance attached yet. CI typically attaches this once
                        the SBOM and vulnerability scan complete.
                    </MudText>
                }
                else
                {
                    <DetailRow Label="Artifact SHA-256" Value="@_dto.Provenance.ArtifactSha256" Mono="true" />
                    <DetailRow Label="SBOM" Value="@_dto.Provenance.SbomUri" Mono="true" />
                    <DetailRow Label="Vulnerabilities" Value="@_dto.Provenance.VulnerabilityReportUri" Mono="true" />
                    <DetailRow Label="CI run" Value="@_dto.Provenance.CiRunUrl" Mono="true" />
                    <DetailRow Label="CI run id" Value="@_dto.Provenance.CiRunId" Mono="true" />
                    <DetailRow Label="Published by" Value="@_dto.Provenance.PublishedByPrincipal" />
                }
            </MudPaper>
        </MudItem>
        <MudItem xs="12">
            <MudPaper Elevation="1" Class="pa-4 mb-4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                    <MudText Typo="Typo.h6">Status history</MudText>
                    @if (_history is { Count: > 0 })
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@_history.Count</MudChip>
                    }
                </MudStack>
                @if (_history is null)
                {
                    <MudProgressLinear Indeterminate="true" />
                }
                else if (_history.Count == 0)
                {
                    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
                        No status changes recorded. The initial Available status from publish
                        is implicit and does not appear here.
                    </MudText>
                }
                else
                {
                    <MudTimeline TimelinePosition="TimelinePosition.Start">
                        @foreach (var h in _history)
                        {
                            <MudTimelineItem Color="@StatusColor(h.ToStatus)" Size="Size.Small">
                                <ItemContent>
                                    <MudText Typo="Typo.body2">
                                        <strong>@h.FromStatus → @h.ToStatus</strong>
                                        <span style="color: var(--mud-palette-text-secondary);">
                                            @(" by " + h.ChangedByPrincipal + " @ " + h.ChangedAtUtc.ToString("u"))
                                        </span>
                                    </MudText>
                                    @if (!string.IsNullOrWhiteSpace(h.Reason))
                                    {
                                        <MudText Typo="Typo.caption">@h.Reason</MudText>
                                    }
                                </ItemContent>
                            </MudTimelineItem>
                        }
                    </MudTimeline>
                }
            </MudPaper>
        </MudItem>
        @if (_dto.ArtifactType == ArtifactTypeDto.Manifest)
        {
            <MudItem xs="12">
                <MudPaper Elevation="1" Class="pa-4 mb-4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                        <MudText Typo="Typo.h6">Composition (BOM)</MudText>
                        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
                            per-release member service pins
                        </MudText>
                        <MudSpacer />
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="OpenAddCompositionDialog">
                            Add member
                        </MudButton>
                    </MudStack>
                    @if (_dto.Compositions.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
                            No members in this BOM yet. Click <strong>Add member</strong> to pin a service.
                        </MudText>
                    }
                    else
                    {
                        <MudTable Items="@_dto.Compositions" T="ReleaseCompositionEntryDto" Dense="true" Hover="true">
                            <HeaderContent>
                                <MudTh>Service</MudTh>
                                <MudTh Style="width: 8rem;">Pin mode</MudTh>
                                <MudTh Style="width: 8rem;">Pinned version</MudTh>
                                <MudTh Style="width: 20rem;">Service release id</MudTh>
                                <MudTh Style="width: 7rem; text-align: right;"></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>
                                    <MudLink Href="@($"/deployment/services/{context.ServiceId}")">
                                        @context.ServiceName
                                    </MudLink>
                                </MudTd>
                                <MudTd>
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@PinColor(context.PinMode)" Variant="Variant.Outlined">
                                        @context.PinMode
                                    </MudChip>
                                </MudTd>
                                <MudTd Style="font-family: ui-monospace, monospace;">
                                    @(context.ServiceReleaseVersion ?? "—")
                                </MudTd>
                                <MudTd Style="font-family: ui-monospace, monospace; font-size: 0.8em;">
                                    @(context.ServiceReleaseId?.ToString() ?? "—")
                                </MudTd>
                                <MudTd Style="text-align: right; white-space: nowrap;">
                                    <MudTooltip Text="Edit pin">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                       Size="Size.Small"
                                                       OnClick="@(() => OpenEditCompositionDialog(context))" />
                                    </MudTooltip>
                                    <MudTooltip Text="Remove from BOM">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                       Size="Size.Small"
                                                       Color="Color.Error"
                                                       OnClick="@(() => RemoveCompositionAsync(context))" />
                                    </MudTooltip>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudPaper>
            </MudItem>
        }
        <MudItem xs="12">
            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-2">Metadata</MudText>
                <DetailRow Label="Release id" Value="@_dto.Id.ToString()" Mono="true" />
                <DetailRow Label="Deployable unit id" Value="@_dto.DeployableUnitId.ToString()" Mono="true" />
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private ReleaseDto? _dto;
    private IReadOnlyList<ReleaseStatusChangeDto>? _history;
    private bool _loading;
    private string? _error;
    private List<BreadcrumbItem> _crumbs = new();

    protected override async Task OnParametersSetAsync()
    {
        if (Id == Guid.Empty) { _error = "Invalid release id."; return; }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true; _error = null;
        try
        {
            _dto = await Api.GetReleaseAsync(Id);
            if (_dto is null) { _error = $"Release {Id} not found."; return; }

            _crumbs = new()
            {
                new BreadcrumbItem(_dto.ArtifactType == ArtifactTypeDto.Manifest ? "Applications" : "Services",
                    _dto.ArtifactType == ArtifactTypeDto.Manifest ? "/deployment/applications" : "/deployment/services"),
                new BreadcrumbItem(_dto.DeployableUnitName,
                    _dto.ArtifactType == ArtifactTypeDto.Manifest
                        ? $"/deployment/applications/{_dto.DeployableUnitId}"
                        : $"/deployment/services/{_dto.DeployableUnitId}"),
                new BreadcrumbItem($"v{_dto.SemanticVersion}", href: null, disabled: true),
            };

            _history = await Api.GetReleaseStatusHistoryAsync(Id);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task OpenChangeStatusDialog()
    {
        if (_dto is null) return;
        var parameters = new DialogParameters { ["CurrentStatus"] = _dto.Status };
        var dlg = await DialogService.ShowAsync<ChangeReleaseStatusDialog>(
            $"Change status of v{_dto.SemanticVersion}", parameters);
        var result = await dlg.Result;
        if (result is null || result.Canceled || result.Data is not ChangeReleaseStatusDialog.Result data) return;

        try
        {
            await Api.ChangeReleaseStatusAsync(_dto.Id,
                new ChangeReleaseStatusRequest(data.NewStatus, data.Reason, data.ChangedByPrincipal));
            Snackbar.Add($"Status changed to {data.NewStatus}.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task OpenProvenanceDialog()
    {
        if (_dto is null) return;
        var parameters = new DialogParameters { ["Existing"] = _dto.Provenance };
        var dlg = await DialogService.ShowAsync<AttachProvenanceDialog>("Attach provenance", parameters);
        var result = await dlg.Result;
        if (result is null || result.Canceled || result.Data is not AttachProvenanceDialog.Result data) return;

        try
        {
            await Api.AttachProvenanceAsync(_dto.Id, new AttachProvenanceRequest(
                data.ArtifactSha256, data.SbomUri, data.VulnerabilityReportUri,
                data.CiRunUrl, data.CiRunId, data.PublishedByPrincipal));
            Snackbar.Add("Provenance attached.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task OpenAddCompositionDialog()
    {
        if (_dto is null) return;

        // BOM members reference the Service catalog. Exclude any service that's
        // already in this BOM so a single AddComposition call can't fail the
        // domain's idempotency check.
        var services = await Api.ListServicesAsync(onlyActive: true);
        var excluded = _dto.Compositions.Select(c => c.ServiceId).ToHashSet();
        var pickable = services.Where(s => !excluded.Contains(s.Id)).ToList();

        var parameters = new DialogParameters
        {
            ["IsEdit"] = false,
            ["PickableServices"] = (IReadOnlyList<ServiceDto>)pickable,
        };
        var dlg = await DialogService.ShowAsync<CompositionEditorDialog>(
            "Add service to BOM", parameters);
        var result = await dlg.Result;
        if (result is null || result.Canceled || result.Data is not CompositionEditorDialog.Result data) return;

        try
        {
            await Api.AddCompositionEntryAsync(_dto.Id,
                new AddCompositionEntryRequest(data.ServiceId, data.PinMode, data.ServiceReleaseId));
            Snackbar.Add("Member added.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task OpenEditCompositionDialog(ReleaseCompositionEntryDto entry)
    {
        if (_dto is null) return;
        var parameters = new DialogParameters
        {
            ["IsEdit"] = true,
            ["Existing"] = entry,
        };
        var dlg = await DialogService.ShowAsync<CompositionEditorDialog>(
            $"Edit pin for '{entry.ServiceName}'", parameters);
        var result = await dlg.Result;
        if (result is null || result.Canceled || result.Data is not CompositionEditorDialog.Result data) return;

        try
        {
            await Api.UpdateCompositionEntryAsync(_dto.Id, entry.ServiceId,
                new UpdateCompositionEntryRequest(data.PinMode, data.ServiceReleaseId));
            Snackbar.Add("Pin updated.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task RemoveCompositionAsync(ReleaseCompositionEntryDto entry)
    {
        if (_dto is null) return;
        var parameters = new DialogParameters
        {
            ["Message"] = $"Remove '{entry.ServiceName}' from this release's BOM?",
            ["Items"] = (IReadOnlyList<string>)new[]
            {
                $"{entry.ServiceName} ({entry.PinMode}" +
                (entry.ServiceReleaseVersion is null ? "" : $" → v{entry.ServiceReleaseVersion}") + ")",
            },
        };
        var dlg = await DialogService.ShowAsync<ConfirmDeleteDialog>(
            "Remove BOM member", parameters);
        var result = await dlg.Result;
        if (result is null || result.Canceled || result.Data is not true) return;

        try
        {
            await Api.RemoveCompositionEntryAsync(_dto.Id, entry.ServiceId);
            Snackbar.Add("Removed.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private static Color StatusColor(ReleaseStatusDto s) => s switch
    {
        ReleaseStatusDto.Available => Color.Success,
        ReleaseStatusDto.Superseded => Color.Default,
        ReleaseStatusDto.Quarantined => Color.Error,
        _ => Color.Default,
    };

    private static Color PinColor(PinModeDto p) => p switch
    {
        PinModeDto.Pinned => Color.Primary,
        PinModeDto.Latest => Color.Info,
        PinModeDto.Current => Color.Warning,
        _ => Color.Default,
    };
}
