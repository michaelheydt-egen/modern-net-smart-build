@page "/sca/sbom"
@inject IBuildStore Store
@inject JenkinsOptions JenkinsOpts
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>SCA — SBOM</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">SBOM viewer</MudText>
    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
        @_jobName · bom-vex.json
    </MudText>
    <MudSpacer />
</MudStack>

@* ---------- Top: build selector ---------- *@
<MudPaper Elevation="1" Class="pa-4 mb-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Filled.Build" Color="Color.Primary" />
        <MudText Typo="Typo.h6">Select build</MudText>
        @if (_selectedBuild is { } sel)
        {
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                     Style="font-family: ui-monospace, monospace;">
                #@sel.Number @(sel.Description ?? string.Empty)
            </MudChip>
        }
        <MudSpacer />
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Download"
                   Disabled="@(_selectedBuild is null || _bomLoading)"
                   OnClick="OnLoadBomAsync">
            Load bom-vex.json
        </MudButton>
        <RefreshControls Loading="@_buildsLoading"
                         AutoRefreshOn="@_autoOn"
                         LastFetchedAt="@_buildsLastFetched"
                         IntervalSec="@IntervalSec"
                         OnRefresh="RefreshBuildsAsync"
                         OnToggleAuto="ToggleAuto" />
    </MudStack>

    @if (_buildsError is { Length: > 0 })
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="my-2">@_buildsError</MudAlert>
    }

    @if (_buildsLoading && _builds is null)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (_builds is { Count: > 0 })
    {
        <MudTable Items="@_builds"
                  Dense="true"
                  Hover="true"
                  Striped="true"
                  RowsPerPage="5"
                  OnRowClick="OnRowClicked"
                  RowClassFunc="@RowClassFunc"
                  T="Build">
            <HeaderContent>
                <MudTh Style="width: 5rem;">#</MudTh>
                <MudTh>Version</MudTh>
                <MudTh Style="width: 8rem;">Status</MudTh>
                <MudTh Style="width: 11rem;">Started</MudTh>
                <MudTh Style="width: 4rem; text-align: center;"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd Style="font-family: ui-monospace, monospace;">#@context.Number</MudTd>
                <MudTd>@(context.Description ?? "—")</MudTd>
                <MudTd>
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="@StatusColor(context)"
                             Variant="Variant.Filled">
                        @StatusLabel(context)
                    </MudChip>
                </MudTd>
                <MudTd>@FormatStarted(context.Timestamp)</MudTd>
                <MudTd Style="text-align: center;">
                    @* Direct jump to /sca/visualize/{number} — skips the "select then Load"
                       flow when the user already knows which build they want to dig into. *@
                    <MudTooltip Text="Open SCA visualization">
                        <MudIconButton Icon="@Icons.Material.Filled.Hub"
                                       Size="Size.Small"
                                       OnClick="@(() => Nav.NavigateTo($"/sca/visualize/{context.Number}"))" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new[] { 5, 10, 25, 50 }" />
            </PagerContent>
        </MudTable>
    }
    else if (!_buildsLoading && _buildsError is null)
    {
        <MudText Typo="Typo.body2" Class="mt-2" Style="color: var(--mud-palette-text-secondary);">
            No builds. Refresh to fetch.
        </MudText>
    }
</MudPaper>

@* ---------- Bottom: bom-vex.json viewer ---------- *@
<MudPaper Elevation="1" Class="pa-4 mb-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Filled.DataObject" Color="Color.Primary" />
        <MudText Typo="Typo.h6">bom-vex.json</MudText>
        @if (_bomLoadedFromBuild is { } n)
        {
            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary); font-family: ui-monospace, monospace;">
                — build #@n
            </MudText>
        }
        <MudSpacer />
        @if (_bomSizeBytes > 0)
        {
            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
                @FormatSize(_bomSizeBytes)
            </MudText>
        }
        @if (_bomLoadedFromBuild is { } loaded && _bomError is null && !_bomLoading)
        {
            <MudLink Href="@BomDownloadUrl(loaded)" Target="_blank" Typo="Typo.caption">
                Download
            </MudLink>
        }
    </MudStack>

    @if (_bomLoading)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (_bomError is { Length: > 0 })
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_bomError</MudAlert>
    }
    else if (_bomTooLarge)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            bom-vex.json is @FormatSize(_bomSizeBytes); too large for inline rendering
            (cap @FormatSize(MaxPreviewBytes)). Use the download link above.
        </MudAlert>
    }
    else if (_bomText is { Length: > 0 })
    {
        <pre @ref="_bomElement" class="sca-preview-pane language-json">@_bomText</pre>
    }
    else
    {
        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
            Select a build above and click <em>Load bom-vex.json</em> to preview its contents.
        </MudText>
    }
</MudPaper>

@* Analysis panels — shared with the Aspire per-image SBOM viewer. *@
<SbomAnalysis Sbom="_sbom"
              VisualizeHref="@(_bomLoadedFromBuild is { } vizN ? $"/sca/visualize/{vizN}" : null)" />

@code {
    public const int IntervalSec = 30;
    // The SBOM (bom-vex.json) is produced by the dedicated cicd-scan job, not cicd-build.
    private const string _jobName = "cicd-scan";
    private const int _buildListCount = 25;
    // Bigger cap than the artifact viewer — Trivy-enriched SBOMs can run a few MB.
    private const long MaxPreviewBytes = 10L * 1024 * 1024;

    // --- Build picker state ---
    private bool _buildsLoading;
    private bool _autoOn;
    private string? _buildsError;
    private IReadOnlyList<Build>? _builds;
    private Build? _selectedBuild;
    private DateTimeOffset? _buildsLastFetched;
    private CancellationTokenSource? _buildsInflightCts;
    private Timer? _timer;

    // --- bom-vex viewer state ---
    private bool _bomLoading;
    private string? _bomError;
    private string? _bomText;
    private long _bomSizeBytes;
    private bool _bomTooLarge;
    private int? _bomLoadedFromBuild;
    private ElementReference _bomElement;
    private bool _needHighlight;

    // Parsed SBOM handed to the shared <SbomAnalysis> component for the panels below the JSON viewer.
    private SbomDocument? _sbom;

    protected override async Task OnInitializedAsync() => await RefreshBuildsAsync();

    private async Task RefreshBuildsAsync()
    {
        _buildsInflightCts?.Cancel();
        _buildsInflightCts = new CancellationTokenSource();
        var ct = _buildsInflightCts.Token;

        _buildsLoading = true;
        _buildsError = null;
        StateHasChanged();

        try
        {
            _builds = await Store.ListBuildsAsync(_jobName, _buildListCount, ct);
            _buildsLastFetched = DateTimeOffset.UtcNow;
            // Preserve selection across refreshes — match by build number.
            if (_selectedBuild is { } prev)
            {
                _selectedBuild = _builds.FirstOrDefault(b => b.Number == prev.Number);
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            _buildsError = ex.Message;
        }
        finally
        {
            _buildsLoading = false;
            StateHasChanged();
        }
    }

    private void ToggleAuto()
    {
        _autoOn = !_autoOn;
        if (_autoOn)
        {
            _timer ??= new Timer(_ => _ = InvokeAsync(RefreshBuildsAsync),
                null, Timeout.Infinite, Timeout.Infinite);
            _timer.Change(TimeSpan.FromSeconds(IntervalSec), TimeSpan.FromSeconds(IntervalSec));
        }
        else
        {
            _timer?.Change(Timeout.Infinite, Timeout.Infinite);
        }
    }

    public void Dispose()
    {
        _timer?.Dispose();
        _buildsInflightCts?.Cancel();
        _buildsInflightCts?.Dispose();
    }

    private void OnRowClicked(TableRowClickEventArgs<Build> args)
    {
        _selectedBuild = args.Item;
    }

    private string RowClassFunc(Build b, int rowNumber) =>
        _selectedBuild?.Number == b.Number ? "sca-row-selected" : string.Empty;

    private async Task OnLoadBomAsync()
    {
        if (_selectedBuild is not { } sel) return;

        _bomLoading = true;
        _bomError = null;
        _bomText = null;
        _bomSizeBytes = 0;
        _bomTooLarge = false;
        _bomLoadedFromBuild = null;
        _sbom = null;   // new build means new SBOM
        StateHasChanged();

        try
        {
            var bytes = await Store.GetArtifactBytesAsync(_jobName, sel.Number, "bom-vex.json");
            _bomSizeBytes = bytes.LongLength;
            _bomLoadedFromBuild = sel.Number;

            // Parse for the analysis panels regardless of size. Even when the JSON
            // viewer is suppressed by the size cap, the structured panels still load.
            _sbom = SbomReader.Parse(bytes);

            if (bytes.LongLength > MaxPreviewBytes)
            {
                _bomTooLarge = true;
                return;
            }

            _bomText = PrettyPrintJson(bytes);
            _needHighlight = true;
        }
        catch (Exception ex)
        {
            _bomError = ResolveBomError(ex, sel.Number);
        }
        finally
        {
            _bomLoading = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_needHighlight) return;
        _needHighlight = false;
        try
        {
            await JS.InvokeVoidAsync("artifactHighlight", _bomElement);
        }
        catch (JSDisconnectedException) { }
        catch (TaskCanceledException) { }
    }

    private string BomDownloadUrl(int buildNumber)
    {
        var baseUrl = JenkinsOpts.BaseUrl.TrimEnd('/');
        return $"{baseUrl}/job/{Uri.EscapeDataString(_jobName)}/{buildNumber}/artifact/bom-vex.json";
    }

    /// <summary>
    /// Surfaces a friendlier message when the build simply doesn't archive bom-vex.json
    /// yet — older runs predate the Trivy step. Anything else falls back to the raw
    /// exception message.
    /// </summary>
    private static string ResolveBomError(Exception ex, int buildNumber)
    {
        if (ex is HttpRequestException hre && hre.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            return $"Build #{buildNumber} did not archive bom-vex.json. " +
                   "Re-run cicd-scan (Trivy SBOM stage generates the file) and try again.";
        }
        return ex.Message;
    }

    private static string PrettyPrintJson(byte[] bytes)
    {
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(new ReadOnlyMemory<byte>(bytes));
            return System.Text.Json.JsonSerializer.Serialize(doc,
                new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        }
        catch (System.Text.Json.JsonException)
        {
            // Corrupt file — render the raw bytes as UTF-8 so the user can still inspect.
            return System.Text.Encoding.UTF8.GetString(bytes);
        }
    }

    // --- Display helpers (mirror the Builds page conventions) ---

    private static string StatusLabel(Build b) =>
        b.Building ? "Running" : (b.Result?.ToString() ?? "Unknown");

    private static Color StatusColor(Build b)
    {
        if (b.Building) return Color.Info;
        return b.Result switch
        {
            BuildResult.Success  => Color.Success,
            BuildResult.Failure  => Color.Error,
            BuildResult.Unstable => Color.Warning,
            BuildResult.Aborted  => Color.Dark,
            _                    => Color.Default
        };
    }

    private static string FormatStarted(long unixMs)
    {
        if (unixMs <= 0) return "—";
        var t = DateTimeOffset.FromUnixTimeMilliseconds(unixMs);
        var ago = DateTimeOffset.UtcNow - t;
        return ago switch
        {
            { TotalMinutes: < 1 } => "just now",
            { TotalHours: < 1 }   => $"{(int)ago.TotalMinutes}m ago",
            { TotalDays: < 1 }    => $"{(int)ago.TotalHours}h ago",
            { TotalDays: < 30 }   => $"{(int)ago.TotalDays}d ago",
            _                     => t.LocalDateTime.ToString("yyyy-MM-dd HH:mm")
        };
    }

    private static string FormatSize(long bytes) => bytes switch
    {
        < 1024                => $"{bytes} B",
        < 1024 * 1024         => $"{bytes / 1024.0:F1} KB",
        < 1024L * 1024 * 1024 => $"{bytes / (1024.0 * 1024):F1} MB",
        _                     => $"{bytes / (1024.0 * 1024 * 1024):F2} GB"
    };
}
