@page "/sca/sbom"
@inject IBuildStore Store
@inject JenkinsOptions JenkinsOpts
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>SCA — SBOM</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">SBOM viewer</MudText>
    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
        @_jobName · bom-vex.json
    </MudText>
    <MudSpacer />
</MudStack>

@* ---------- Top: build selector ---------- *@
<MudPaper Elevation="1" Class="pa-4 mb-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Filled.Build" Color="Color.Primary" />
        <MudText Typo="Typo.h6">Select build</MudText>
        @if (_selectedBuild is { } sel)
        {
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                     Style="font-family: ui-monospace, monospace;">
                #@sel.Number @(sel.Description ?? string.Empty)
            </MudChip>
        }
        <MudSpacer />
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Download"
                   Disabled="@(_selectedBuild is null || _bomLoading)"
                   OnClick="OnLoadBomAsync">
            Load bom-vex.json
        </MudButton>
        <RefreshControls Loading="@_buildsLoading"
                         AutoRefreshOn="@_autoOn"
                         LastFetchedAt="@_buildsLastFetched"
                         IntervalSec="@IntervalSec"
                         OnRefresh="RefreshBuildsAsync"
                         OnToggleAuto="ToggleAuto" />
    </MudStack>

    @if (_buildsError is { Length: > 0 })
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="my-2">@_buildsError</MudAlert>
    }

    @if (_buildsLoading && _builds is null)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (_builds is { Count: > 0 })
    {
        <MudTable Items="@_builds"
                  Dense="true"
                  Hover="true"
                  Striped="true"
                  RowsPerPage="5"
                  OnRowClick="OnRowClicked"
                  RowClassFunc="@RowClassFunc"
                  T="Build">
            <HeaderContent>
                <MudTh Style="width: 5rem;">#</MudTh>
                <MudTh>Version</MudTh>
                <MudTh Style="width: 8rem;">Status</MudTh>
                <MudTh Style="width: 11rem;">Started</MudTh>
                <MudTh Style="width: 4rem; text-align: center;"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd Style="font-family: ui-monospace, monospace;">#@context.Number</MudTd>
                <MudTd>@(context.Description ?? "—")</MudTd>
                <MudTd>
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="@StatusColor(context)"
                             Variant="Variant.Filled">
                        @StatusLabel(context)
                    </MudChip>
                </MudTd>
                <MudTd>@FormatStarted(context.Timestamp)</MudTd>
                <MudTd Style="text-align: center;">
                    @* Direct jump to /sca/visualize/{number} — skips the "select then Load"
                       flow when the user already knows which build they want to dig into. *@
                    <MudTooltip Text="Open SCA visualization">
                        <MudIconButton Icon="@Icons.Material.Filled.Hub"
                                       Size="Size.Small"
                                       OnClick="@(() => Nav.NavigateTo($"/sca/visualize/{context.Number}"))" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new[] { 5, 10, 25, 50 }" />
            </PagerContent>
        </MudTable>
    }
    else if (!_buildsLoading && _buildsError is null)
    {
        <MudText Typo="Typo.body2" Class="mt-2" Style="color: var(--mud-palette-text-secondary);">
            No builds. Refresh to fetch.
        </MudText>
    }
</MudPaper>

@* ---------- Bottom: bom-vex.json viewer ---------- *@
<MudPaper Elevation="1" Class="pa-4 mb-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Filled.DataObject" Color="Color.Primary" />
        <MudText Typo="Typo.h6">bom-vex.json</MudText>
        @if (_bomLoadedFromBuild is { } n)
        {
            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary); font-family: ui-monospace, monospace;">
                — build #@n
            </MudText>
        }
        <MudSpacer />
        @if (_bomSizeBytes > 0)
        {
            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
                @FormatSize(_bomSizeBytes)
            </MudText>
        }
        @if (_bomLoadedFromBuild is { } loaded && _bomError is null && !_bomLoading)
        {
            <MudLink Href="@BomDownloadUrl(loaded)" Target="_blank" Typo="Typo.caption">
                Download
            </MudLink>
        }
    </MudStack>

    @if (_bomLoading)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (_bomError is { Length: > 0 })
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_bomError</MudAlert>
    }
    else if (_bomTooLarge)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            bom-vex.json is @FormatSize(_bomSizeBytes); too large for inline rendering
            (cap @FormatSize(MaxPreviewBytes)). Use the download link above.
        </MudAlert>
    }
    else if (_bomText is { Length: > 0 })
    {
        <pre @ref="_bomElement" class="sca-preview-pane language-json">@_bomText</pre>
    }
    else
    {
        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
            Select a build above and click <em>Load bom-vex.json</em> to preview its contents.
        </MudText>
    }
</MudPaper>

@* ============================================================
   Analysis panels — render only when the parser handed us a doc.
   Each section hides individually if its slice of the BOM is empty.
   ============================================================ *@
@if (_sbom is { } sbom)
{
    @* ---------- Metadata ---------- *@
    @if (sbom.Metadata is { } md)
    {
        <MudPaper Elevation="1" Class="pa-4 mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Primary" />
                <MudText Typo="Typo.h6">Metadata</MudText>
            </MudStack>

            <DetailRow Label="Generated"    Value="@FormatTimestamp(md.Timestamp)" />
            <DetailRow Label="Spec version" Value="@FormatSpec(sbom)" />
            @if (md.Component is { } rc)
            {
                <DetailRow Label="Component" Value="@rc.Name" />
                <DetailRow Label="Type"      Value="@rc.Type" />
                <DetailRow Label="Version"   Value="@rc.Version" Mono="true" />
                <DetailRow Label="BOM ref"   Value="@rc.BomRef"  Mono="true" />
            }

            @if (md.Tools.Count > 0)
            {
                <MudDivider Class="my-3" />
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                    <MudText Typo="Typo.subtitle2">Tools</MudText>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@md.Tools.Count</MudChip>
                </MudStack>
                <MudSimpleTable Dense="true" Hover="true" Style="font-size: 0.9em;">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th style="width: 8rem;">Version</th>
                            <th style="width: 12rem;">Vendor</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in md.Tools)
                        {
                            <tr>
                                <td>@(t.Name ?? "—")</td>
                                <td style="font-family: ui-monospace, monospace;">@(t.Version ?? "—")</td>
                                <td>@(t.Vendor ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }

            @if (md.Properties.Count > 0)
            {
                <MudDivider Class="my-3" />
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                    <MudText Typo="Typo.subtitle2">Properties</MudText>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@md.Properties.Count</MudChip>
                </MudStack>
                <div class="sca-properties-pane">
                    @foreach (var p in md.Properties)
                    {
                        <DetailRow Label="@p.Name" Value="@p.Value" Mono="true" />
                    }
                </div>
            }
        </MudPaper>
    }

    @* ---------- Components ---------- *@
    @if (sbom.Components.Count > 0)
    {
        <MudPaper Elevation="1" Class="pa-4 mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Inventory2" Color="Color.Primary" />
                <MudText Typo="Typo.h6">Components</MudText>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@sbom.Components.Count</MudChip>
            </MudStack>

            <MudTable Items="@sbom.Components"
                      Dense="true"
                      Hover="true"
                      Striped="true"
                      RowsPerPage="25"
                      Filter="new Func<SbomComponentEntry, bool>(MatchesComponentFilter)"
                      T="SbomComponentEntry">
                <ToolBarContent>
                    <MudTextField @bind-Value="_componentsFilter"
                                  Placeholder="Filter by name, version, or licence…"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  IconSize="Size.Small"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Clearable="true"
                                  Immediate="true"
                                  Style="max-width: 28rem;" />
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh Style="width: 9rem;">Version</MudTh>
                    <MudTh Style="width: 7rem;">Type</MudTh>
                    <MudTh>Licenses</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd Style="font-family: ui-monospace, monospace; font-size: 0.9em; word-break: break-all;">
                        @(context.Name ?? "—")
                    </MudTd>
                    <MudTd Style="font-family: ui-monospace, monospace;">@(context.Version ?? "—")</MudTd>
                    <MudTd>@(context.Type ?? "—")</MudTd>
                    <MudTd Style="font-size: 0.85em;">@FormatLicenses(context.Licenses)</MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new[] { 25, 50, 100, 250 }" />
                </PagerContent>
            </MudTable>
        </MudPaper>
    }

    @* ---------- Vulnerabilities ----------
       Always render the panel when an SBOM is loaded. Three branches inside:
         (a) source had no `vulnerabilities` array      → unenriched warning
         (b) source had the array but it was empty      → clean success
         (c) source had entries                         → existing table *@
    <MudPaper Elevation="1" Class="pa-4 mb-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.BugReport" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Vulnerabilities</MudText>
            @if (sbom.HasVulnerabilitiesSection)
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@sbom.Vulnerabilities.Count</MudChip>
            }
            <MudSpacer />
            @* Severity counts only shown when there's something to count. *@
            @foreach (var sev in new[] { "critical", "high", "medium", "low" })
            {
                var count = sbom.Vulnerabilities.Count(v =>
                    string.Equals(v.Severity, sev, StringComparison.OrdinalIgnoreCase));
                if (count > 0)
                {
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="@SeverityColor(sev)"
                             Variant="Variant.Filled">
                        @CapitalizeFirst(sev) @count
                    </MudChip>
                }
            }
        </MudStack>

        @if (!sbom.HasVulnerabilitiesSection)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                This SBOM has no <code>vulnerabilities</code> array — it wasn't enriched
                by a scanner. Most likely cause: the Trivy step in <code>cicd-build</code>
                couldn't reach (or download) the vulnerability database. Check that build's
                log for <em>vulnerability DB</em> download warnings, or re-run the
                <strong>Trivy SBOM</strong> stage once the network/DB cache is set up.
            </MudAlert>
        }
        else if (sbom.Vulnerabilities.Count == 0)
        {
            <MudAlert Severity="Severity.Success" Variant="Variant.Outlined">
                No vulnerabilities reported. Trivy scanned this SBOM and the dependency
                graph came back clean against the advisory databases it had loaded.
            </MudAlert>
        }
        else
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">Filter:</MudText>
                @foreach (var opt in new[] { "all", "critical", "high", "medium", "low", "unrated" })
                {
                    var selected = _vulnSeverityFilter == opt;
                    <MudChip T="string"
                             Size="Size.Small"
                             Variant="@(selected ? Variant.Filled : Variant.Outlined)"
                             Color="@(selected ? SeverityColor(opt) : Color.Default)"
                             OnClick="@(() => _vulnSeverityFilter = opt)">
                        @CapitalizeFirst(opt)
                    </MudChip>
                }
            </MudStack>

            <MudTable Items="@FilteredVulnerabilities(sbom.Vulnerabilities)"
                      Dense="true"
                      Hover="true"
                      Striped="true"
                      RowsPerPage="25"
                      T="SbomVulnerability">
                <HeaderContent>
                    <MudTh Style="width: 13rem;">ID</MudTh>
                    <MudTh>Affects</MudTh>
                    <MudTh Style="width: 8rem;">Severity</MudTh>
                    <MudTh Style="width: 7rem;">Source</MudTh>
                    <MudTh>Description</MudTh>
                    <MudTh Style="width: 3rem; text-align: center;"></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd Style="font-family: ui-monospace, monospace; font-size: 0.85em;">
                        @if (PrimaryVulnUrl(context) is { Length: > 0 } url)
                        {
                            <MudLink Href="@url" Target="_blank">@(context.Id ?? "—")</MudLink>
                        }
                        else
                        {
                            @(context.Id ?? "—")
                        }
                    </MudTd>
                    <MudTd Style="font-size: 0.85em;">@FormatAffects(context.AffectsRefs)</MudTd>
                    <MudTd>
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="@SeverityColor(context.Severity)"
                                 Variant="Variant.Filled">
                            @(string.IsNullOrEmpty(context.Severity) ? "unrated" : CapitalizeFirst(context.Severity))
                        </MudChip>
                    </MudTd>
                    <MudTd Style="font-size: 0.85em;">@(context.Source ?? "—")</MudTd>
                    <MudTd Style="font-size: 0.85em;">@Truncate(context.Description, 200)</MudTd>
                    <MudTd Style="text-align: center;">
                        @if (PrimaryVulnUrl(context) is { Length: > 0 } refUrl)
                        {
                            <MudTooltip Text="Open advisory in new tab">
                                <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                               Size="Size.Small"
                                               Href="@refUrl"
                                               Target="_blank" />
                            </MudTooltip>
                        }
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new[] { 25, 50, 100, 250 }" />
                </PagerContent>
            </MudTable>
        }
    </MudPaper>

    @* ---------- Dependencies ---------- *@
    @if (sbom.Dependencies.Count > 0)
    {
        <MudPaper Elevation="1" Class="pa-4 mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.AccountTree" Color="Color.Primary" />
                <MudText Typo="Typo.h6">Dependencies</MudText>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@sbom.Dependencies.Count</MudChip>
                <MudSpacer />
                @* Visualize takes the user to a dedicated page that re-fetches this
                   build's bom-vex.json and renders deeper analysis / graphs. Build
                   number comes from the load that populated this view. *@
                <MudButton Color="Color.Primary"
                           Variant="Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.Hub"
                           Disabled="@(_bomLoadedFromBuild is null)"
                           OnClick="@(() => Nav.NavigateTo($"/sca/visualize/{_bomLoadedFromBuild}"))">
                    Visualize
                </MudButton>
            </MudStack>

            @{
                var edgeCount = sbom.Dependencies.Sum(d => d.DependsOn.Count);
                var withEdges = sbom.Dependencies.Count(d => d.DependsOn.Count > 0);
                var rootDeps = ResolveRootDependencies(sbom);
            }

            <DetailRow Label="Components in graph" Value="@sbom.Dependencies.Count.ToString()" />
            <DetailRow Label="Edges (depends-on)"  Value="@edgeCount.ToString()" />
            <DetailRow Label="With outgoing edges" Value="@withEdges.ToString()" />

            @if (rootDeps is { Count: > 0 } rds && sbom.Metadata?.Component is { } root)
            {
                <MudDivider Class="my-3" />
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                    <MudText Typo="Typo.subtitle2">Root direct dependencies</MudText>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@rds.Count</MudChip>
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                        from @root.Name
                    </MudText>
                </MudStack>
                <div class="sca-deps-pane">
                    <MudList T="string" Dense="true">
                        @foreach (var depRef in rds)
                        {
                            <MudListItem T="string"
                                         Icon="@Icons.Material.Filled.SubdirectoryArrowRight"
                                         IconSize="Size.Small">
                                <span style="font-family: ui-monospace, monospace; font-size: 0.85em; word-break: break-all;">
                                    @ResolveComponentDisplay(depRef)
                                </span>
                            </MudListItem>
                        }
                    </MudList>
                </div>
            }
            else
            {
                <MudText Typo="Typo.body2" Class="mt-2" Style="color: var(--mud-palette-text-secondary);">
                    No root component reference in metadata, so direct deps can't be resolved.
                </MudText>
            }
        </MudPaper>
    }
}

@code {
    public const int IntervalSec = 30;
    private const string _jobName = "cicd-build";
    private const int _buildListCount = 25;
    // Bigger cap than the artifact viewer — Trivy-enriched SBOMs can run a few MB.
    private const long MaxPreviewBytes = 10L * 1024 * 1024;

    // --- Build picker state ---
    private bool _buildsLoading;
    private bool _autoOn;
    private string? _buildsError;
    private IReadOnlyList<Build>? _builds;
    private Build? _selectedBuild;
    private DateTimeOffset? _buildsLastFetched;
    private CancellationTokenSource? _buildsInflightCts;
    private Timer? _timer;

    // --- bom-vex viewer state ---
    private bool _bomLoading;
    private string? _bomError;
    private string? _bomText;
    private long _bomSizeBytes;
    private bool _bomTooLarge;
    private int? _bomLoadedFromBuild;
    private ElementReference _bomElement;
    private bool _needHighlight;

    // --- Parsed SBOM (drives the analysis panels below the JSON viewer) ---
    private SbomDocument? _sbom;
    // Lookup so vulnerability rows can show "Microsoft.Foo @ 1.2.3" instead of
    // raw bom-ref strings. Built once per load.
    private Dictionary<string, SbomComponentEntry> _componentsByRef = new(StringComparer.Ordinal);

    // Per-section UI state
    private string _componentsFilter = string.Empty;
    private string _vulnSeverityFilter = "all";   // all / critical / high / medium / low / unrated

    protected override async Task OnInitializedAsync() => await RefreshBuildsAsync();

    private async Task RefreshBuildsAsync()
    {
        _buildsInflightCts?.Cancel();
        _buildsInflightCts = new CancellationTokenSource();
        var ct = _buildsInflightCts.Token;

        _buildsLoading = true;
        _buildsError = null;
        StateHasChanged();

        try
        {
            _builds = await Store.ListBuildsAsync(_jobName, _buildListCount, ct);
            _buildsLastFetched = DateTimeOffset.UtcNow;
            // Preserve selection across refreshes — match by build number.
            if (_selectedBuild is { } prev)
            {
                _selectedBuild = _builds.FirstOrDefault(b => b.Number == prev.Number);
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            _buildsError = ex.Message;
        }
        finally
        {
            _buildsLoading = false;
            StateHasChanged();
        }
    }

    private void ToggleAuto()
    {
        _autoOn = !_autoOn;
        if (_autoOn)
        {
            _timer ??= new Timer(_ => _ = InvokeAsync(RefreshBuildsAsync),
                null, Timeout.Infinite, Timeout.Infinite);
            _timer.Change(TimeSpan.FromSeconds(IntervalSec), TimeSpan.FromSeconds(IntervalSec));
        }
        else
        {
            _timer?.Change(Timeout.Infinite, Timeout.Infinite);
        }
    }

    public void Dispose()
    {
        _timer?.Dispose();
        _buildsInflightCts?.Cancel();
        _buildsInflightCts?.Dispose();
    }

    private void OnRowClicked(TableRowClickEventArgs<Build> args)
    {
        _selectedBuild = args.Item;
    }

    private string RowClassFunc(Build b, int rowNumber) =>
        _selectedBuild?.Number == b.Number ? "sca-row-selected" : string.Empty;

    private async Task OnLoadBomAsync()
    {
        if (_selectedBuild is not { } sel) return;

        _bomLoading = true;
        _bomError = null;
        _bomText = null;
        _bomSizeBytes = 0;
        _bomTooLarge = false;
        _bomLoadedFromBuild = null;
        // Reset analysis panels — new build means new SBOM.
        _sbom = null;
        _componentsByRef = new(StringComparer.Ordinal);
        _componentsFilter = string.Empty;
        _vulnSeverityFilter = "all";
        StateHasChanged();

        try
        {
            var bytes = await Store.GetArtifactBytesAsync(_jobName, sel.Number, "bom-vex.json");
            _bomSizeBytes = bytes.LongLength;
            _bomLoadedFromBuild = sel.Number;

            // Parse for the analysis panels regardless of size. Even when the JSON
            // viewer is suppressed by the size cap, the structured panels still load
            // — the byte cost is the same, just no monospace render.
            _sbom = SbomReader.Parse(bytes);
            if (_sbom is { Components.Count: > 0 } parsed)
            {
                foreach (var c in parsed.Components)
                {
                    if (!string.IsNullOrEmpty(c.BomRef))
                    {
                        _componentsByRef[c.BomRef] = c;
                    }
                }
            }

            if (bytes.LongLength > MaxPreviewBytes)
            {
                _bomTooLarge = true;
                return;
            }

            _bomText = PrettyPrintJson(bytes);
            _needHighlight = true;
        }
        catch (Exception ex)
        {
            _bomError = ResolveBomError(ex, sel.Number);
        }
        finally
        {
            _bomLoading = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_needHighlight) return;
        _needHighlight = false;
        try
        {
            await JS.InvokeVoidAsync("artifactHighlight", _bomElement);
        }
        catch (JSDisconnectedException) { }
        catch (TaskCanceledException) { }
    }

    private string BomDownloadUrl(int buildNumber)
    {
        var baseUrl = JenkinsOpts.BaseUrl.TrimEnd('/');
        return $"{baseUrl}/job/{Uri.EscapeDataString(_jobName)}/{buildNumber}/artifact/bom-vex.json";
    }

    /// <summary>
    /// Surfaces a friendlier message when the build simply doesn't archive bom-vex.json
    /// yet — older runs predate the Trivy step. Anything else falls back to the raw
    /// exception message.
    /// </summary>
    private static string ResolveBomError(Exception ex, int buildNumber)
    {
        if (ex is HttpRequestException hre && hre.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            return $"Build #{buildNumber} did not archive bom-vex.json. " +
                   "Re-run cicd-build (Trivy stage generates the file) and try again.";
        }
        return ex.Message;
    }

    private static string PrettyPrintJson(byte[] bytes)
    {
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(new ReadOnlyMemory<byte>(bytes));
            return System.Text.Json.JsonSerializer.Serialize(doc,
                new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        }
        catch (System.Text.Json.JsonException)
        {
            // Corrupt file — render the raw bytes as UTF-8 so the user can still inspect.
            return System.Text.Encoding.UTF8.GetString(bytes);
        }
    }

    // --- SBOM analysis helpers ---

    private bool MatchesComponentFilter(SbomComponentEntry c)
    {
        if (string.IsNullOrWhiteSpace(_componentsFilter)) return true;
        var f = _componentsFilter.Trim();
        if ((c.Name    ?? string.Empty).Contains(f, StringComparison.OrdinalIgnoreCase)) return true;
        if ((c.Version ?? string.Empty).Contains(f, StringComparison.OrdinalIgnoreCase)) return true;
        return c.Licenses.Any(l => l.Contains(f, StringComparison.OrdinalIgnoreCase));
    }

    private IEnumerable<SbomVulnerability> FilteredVulnerabilities(IReadOnlyList<SbomVulnerability> all)
    {
        IEnumerable<SbomVulnerability> q = _vulnSeverityFilter switch
        {
            "all"     => all,
            "unrated" => all.Where(v => string.IsNullOrEmpty(v.Severity)),
            var s     => all.Where(v => string.Equals(v.Severity, s, StringComparison.OrdinalIgnoreCase)),
        };
        // Stable display order: severity DESC, then ID asc so unstable input doesn't reshuffle the table.
        return q
            .OrderByDescending(v => SeverityWeight(v.Severity))
            .ThenBy(v => v.Id, StringComparer.OrdinalIgnoreCase);
    }

    private static int SeverityWeight(string? severity) => severity?.ToLowerInvariant() switch
    {
        "critical" => 4,
        "high"     => 3,
        "medium"   => 2,
        "low"      => 1,
        _          => 0,
    };

    private static Color SeverityColor(string? severity) => severity?.ToLowerInvariant() switch
    {
        "critical" => Color.Error,
        "high"     => Color.Error,
        "medium"   => Color.Warning,
        "low"      => Color.Info,
        "all"      => Color.Default,
        _          => Color.Default,
    };

    /// <summary>
    /// Resolves a vuln's affected refs into human-readable strings using the
    /// components index we built at load time. Falls back to the raw ref so a
    /// missing component reference still shows something the user can copy.
    /// </summary>
    private string FormatAffects(IReadOnlyList<string> affectsRefs)
    {
        if (affectsRefs.Count == 0) return "—";
        var display = affectsRefs.Select(ResolveComponentDisplay).ToArray();
        return string.Join(", ", display);
    }

    private string ResolveComponentDisplay(string bomRef)
    {
        if (_componentsByRef.TryGetValue(bomRef, out var c) && c.Name is { Length: > 0 } name)
        {
            return c.Version is { Length: > 0 } v ? $"{name} @ {v}" : name;
        }
        return bomRef;
    }

    private IReadOnlyList<string>? ResolveRootDependencies(SbomDocument sbom)
    {
        if (sbom.Metadata?.Component?.BomRef is not { Length: > 0 } rootRef) return null;
        var entry = sbom.Dependencies.FirstOrDefault(d => d.Ref == rootRef);
        return entry?.DependsOn;
    }

    /// <summary>
    /// First non-empty URL we can find for a vulnerability — drives both the ID
    /// hyperlink in the table and the row's open-in-new-tab action button.
    /// Priority: references / advisories (whichever the source populated)
    /// → fall back to source.url so we don't render a linkless row when Trivy
    /// only populated the source pointer.
    /// </summary>
    private static string? PrimaryVulnUrl(SbomVulnerability v) =>
        v.References.FirstOrDefault(r => !string.IsNullOrEmpty(r.Url))?.Url
        ?? v.SourceUrl;

    private static string FormatLicenses(IReadOnlyList<string> licenses)
    {
        if (licenses.Count == 0) return "—";
        if (licenses.Count <= 3) return string.Join(", ", licenses);
        return $"{string.Join(", ", licenses.Take(3))} (+{licenses.Count - 3} more)";
    }

    private static string FormatTimestamp(string? iso)
    {
        if (string.IsNullOrEmpty(iso)) return "—";
        if (!DateTimeOffset.TryParse(iso, out var t)) return iso;
        return $"{t.UtcDateTime:yyyy-MM-dd HH:mm:ss} UTC";
    }

    private static string FormatSpec(SbomDocument d)
    {
        var format  = d.BomFormat ?? "—";
        return string.IsNullOrEmpty(d.SpecVersion) ? format : $"{format} {d.SpecVersion}";
    }

    private static string CapitalizeFirst(string s) =>
        string.IsNullOrEmpty(s) ? s : char.ToUpperInvariant(s[0]) + s[1..];

    private static string Truncate(string? s, int max)
    {
        if (string.IsNullOrEmpty(s)) return "—";
        return s.Length <= max ? s : s[..max] + "…";
    }

    // --- Display helpers (mirror the Builds page conventions) ---

    private static string StatusLabel(Build b) =>
        b.Building ? "Running" : (b.Result?.ToString() ?? "Unknown");

    private static Color StatusColor(Build b)
    {
        if (b.Building) return Color.Info;
        return b.Result switch
        {
            BuildResult.Success  => Color.Success,
            BuildResult.Failure  => Color.Error,
            BuildResult.Unstable => Color.Warning,
            BuildResult.Aborted  => Color.Dark,
            _                    => Color.Default
        };
    }

    private static string FormatStarted(long unixMs)
    {
        if (unixMs <= 0) return "—";
        var t = DateTimeOffset.FromUnixTimeMilliseconds(unixMs);
        var ago = DateTimeOffset.UtcNow - t;
        return ago switch
        {
            { TotalMinutes: < 1 } => "just now",
            { TotalHours: < 1 }   => $"{(int)ago.TotalMinutes}m ago",
            { TotalDays: < 1 }    => $"{(int)ago.TotalHours}h ago",
            { TotalDays: < 30 }   => $"{(int)ago.TotalDays}d ago",
            _                     => t.LocalDateTime.ToString("yyyy-MM-dd HH:mm")
        };
    }

    private static string FormatSize(long bytes) => bytes switch
    {
        < 1024                => $"{bytes} B",
        < 1024 * 1024         => $"{bytes / 1024.0:F1} KB",
        < 1024L * 1024 * 1024 => $"{bytes / (1024.0 * 1024):F1} MB",
        _                     => $"{bytes / (1024.0 * 1024 * 1024):F2} GB"
    };
}
