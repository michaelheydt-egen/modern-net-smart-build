@page "/publisher/inventory"
@inject PublisherApiClient Api
@inject INexusClient Nexus
@inject NexusOptions NexusOpts
@inject ISnackbar Snackbar

<PageTitle>Publisher — Inventory</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Container inventory</MudText>
    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
        containers recorded from local Nexus (via the CI ContainerPublished event, or added manually)
    </MudText>
    <MudSpacer />
    @if (_selected.Count > 0)
    {
        <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteSweep"
                   OnClick="DeleteSelectedAsync" Disabled="_busy">Delete selected (@_selected.Count)</MudButton>
    }
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAdd">Add container</MudButton>
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadAsync">Refresh</MudButton>
</MudStack>

@if (_error is { Length: > 0 })
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="my-2">@_error</MudAlert>
}

<MudPaper Elevation="1" Class="pa-4 mb-4">
    @if (_loading && _items is null)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (_items is { Count: 0 })
    {
        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
            No containers recorded yet. They appear here once a build publishes a container to the local Nexus docker registry — or click <strong>Add container</strong>.
        </MudText>
    }
    else if (_items is not null)
    {
        <MudTable Items="@_items" Dense="true" Hover="true" Striped="true" T="PublishableContainerDto"
                  MultiSelection="true" @bind-SelectedItems="_selected">
            <HeaderContent>
                <MudTh>Container</MudTh>
                <MudTh Style="width: 11rem;">Version</MudTh>
                <MudTh>Nexus ref</MudTh>
                <MudTh Style="width: 6rem;">Source</MudTh>
                <MudTh Style="width: 9rem;">Channels</MudTh>
                <MudTh Style="width: 6rem;">Status</MudTh>
                <MudTh Style="width: 16rem; text-align: right;"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd Style="font-family: ui-monospace, monospace; font-size: 0.85em;">@context.ContainerName</MudTd>
                <MudTd Style="font-family: ui-monospace, monospace; font-size: 0.85em;">@context.Version</MudTd>
                <MudTd Style="font-family: ui-monospace, monospace; font-size: 0.8em;">@context.ArtifactUri</MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                             Color="@(context.Source == ContainerSourceDto.Manual ? Color.Secondary : Color.Default)">
                        @context.Source
                    </MudChip>
                </MudTd>
                <MudTd>
                    @foreach (var ch in ChannelsFor(context.Id))
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">@ch</MudChip>
                    }
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)" Variant="Variant.Filled">
                        @(context.IsActive ? "Active" : "Inactive")
                    </MudChip>
                </MudTd>
                <MudTd Style="text-align: right; white-space: nowrap;">
                    <MudButton Size="Size.Small" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Label"
                               OnClick="@(() => OpenTag(context))">Tag</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" Disabled="@(!context.IsActive)"
                               StartIcon="@Icons.Material.Filled.CloudUpload" OnClick="@(() => OpenPromote(context))">Promote</MudButton>
                    <MudTooltip Text="@(context.IsActive ? "Deactivate" : "Activate")">
                        <MudIconButton Size="Size.Small"
                                       Icon="@(context.IsActive ? Icons.Material.Filled.ToggleOn : Icons.Material.Filled.ToggleOff)"
                                       Color="@(context.IsActive ? Color.Success : Color.Default)"
                                       OnClick="@(() => ToggleActiveAsync(context))" />
                    </MudTooltip>
                    <MudTooltip Text="Delete">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => DeleteOneAsync(context))" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

<MudText Typo="Typo.h6" Class="mb-2">Publishable channels</MudText>
<MudPaper Elevation="1" Class="pa-4 mb-4">
    @if (_channels is { Count: 0 })
    {
        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
            No channels yet. Tag a container above to create a named publishable alias.
        </MudText>
    }
    else if (_channels is not null)
    {
        <MudTable Items="@_channels" Dense="true" Hover="true" T="PublishChannelDto">
            <HeaderContent>
                <MudTh>Channel</MudTh>
                <MudTh>Current container</MudTh>
                <MudTh Style="width: 7rem;">Moves</MudTh>
                <MudTh Style="width: 11rem;">Updated</MudTh>
                <MudTh Style="width: 10rem; text-align: right;"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">@context.Name</MudChip></MudTd>
                <MudTd Style="font-family: ui-monospace, monospace; font-size: 0.85em;">@ContainerLabel(context.CurrentContainerId)</MudTd>
                <MudTd>@context.History.Count</MudTd>
                <MudTd>@context.UpdatedAtUtc.LocalDateTime.ToString("g")</MudTd>
                <MudTd Style="text-align: right;">
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.CloudUpload" OnClick="@(() => PublishChannelAsync(context))">Publish</MudButton>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@* ---- Add-from-Nexus dialog ---- *@
<MudDialog @bind-Visible="_showAdd" Options="_wideDialogOptions">
    <TitleContent>Add container from Nexus</TitleContent>
    <DialogContent>
        @if (!Nexus.IsConfigured)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                Nexus is not configured (@Nexus.ConfigurationError). Set Nexus:Url / Nexus:Password to browse the docker registry.
            </MudAlert>
        }
        else if (_addLoading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else
        {
            <MudText Typo="Typo.body2" Class="mb-2" Style="color: var(--mud-palette-text-secondary);">
                Pick a container, then a <code>&lt;build#&gt;-&lt;hash&gt;</code> tag. Registry: <strong>@NexusOpts.DockerRegistryHost</strong>
            </MudText>
            <MudGrid>
                <MudItem xs="6">
                    <MudText Typo="Typo.subtitle2">Containers</MudText>
                    <MudPaper Outlined="true" Style="max-height: 16rem; overflow:auto;">
                        <MudList T="string" Dense="true">
                            @foreach (var n in _names)
                            {
                                <MudListItem T="string" Text="@n" Icon="@Icons.Material.Filled.Inventory2"
                                             OnClick="@(() => SelectName(n))"
                                             Style="@(n == _selectedName ? "background: var(--mud-palette-action-default-hover);" : "")" />
                            }
                        </MudList>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.subtitle2">Tags (&lt;build#&gt;-&lt;hash&gt;)</MudText>
                    <MudPaper Outlined="true" Style="max-height: 16rem; overflow:auto;">
                        @if (_selectedName is null)
                        {
                            <MudText Typo="Typo.caption" Class="pa-2" Style="color: var(--mud-palette-text-secondary);">Select a container.</MudText>
                        }
                        else if (_tags.Count == 0)
                        {
                            <MudText Typo="Typo.caption" Class="pa-2" Style="color: var(--mud-palette-text-secondary);">No build#-hash tags for this container.</MudText>
                        }
                        else
                        {
                            <MudList T="string" Dense="true">
                                @foreach (var t in _tags)
                                {
                                    <MudListItem T="string" Text="@t" Icon="@Icons.Material.Filled.Sell"
                                                 OnClick="@(() => _selectedTag = t)"
                                                 Style="@(t == _selectedTag ? "background: var(--mud-palette-action-default-hover);" : "")" />
                                }
                            </MudList>
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
            @if (_selectedName is not null && _selectedTag is not null)
            {
                <MudAlert Severity="Severity.Info" Dense="true" Variant="Variant.Text" Class="mt-2"
                          Style="font-family: ui-monospace, monospace;">
                    @NexusOpts.DockerRegistryHost/@_selectedName:@_selectedTag
                </MudAlert>
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showAdd = false)">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="AddAsync"
                   Disabled="@(_busy || _selectedName is null || _selectedTag is null)">Add (active)</MudButton>
    </DialogActions>
</MudDialog>

@* ---- Tag publishable dialog ---- *@
<MudDialog @bind-Visible="_showTag" Options="_dialogOptions">
    <TitleContent>Tag publishable</TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-2">Container: <strong>@_target?.ContainerName</strong> @_target?.Version</MudText>
        <MudTextField @bind-Value="_channelName" Label="Channel name" Required="true"
                      HelperText="A stable publishable name, e.g. stable or prod-candidate. Re-tagging moves it here." />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showTag = false)">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="TagAsync" Disabled="_busy">Tag</MudButton>
    </DialogActions>
</MudDialog>

@* ---- Promote dialog ---- *@
<MudDialog @bind-Visible="_showPromote" Options="_dialogOptions">
    <TitleContent>Promote to remote registry</TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-2">Container: <strong>@_target?.ContainerName</strong> @_target?.Version</MudText>
        <MudSelect @bind-Value="_promoteRegistryId" Label="Registry" T="Guid" HelperText="Defaults to the default registry if left unset.">
            @foreach (var r in _registries ?? new List<RemoteRegistryDto>())
            {
                <MudSelectItem Value="@r.Id">@r.Name (@r.RegistryHost)@(r.IsDefault ? " — default" : "")</MudSelectItem>
            }
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showPromote = false)">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="PromoteAsync" Disabled="_busy">Promote</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private IReadOnlyList<PublishableContainerDto>? _items;
    private IReadOnlyList<PublishChannelDto>? _channels;
    private IReadOnlyList<RemoteRegistryDto>? _registries;
    private HashSet<PublishableContainerDto> _selected = new();
    private bool _loading, _busy;
    private string? _error;

    private static readonly DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true };
    private static readonly DialogOptions _wideDialogOptions = new() { MaxWidth = MaxWidth.Medium, FullWidth = true };

    // Add-from-Nexus dialog state
    private bool _showAdd, _addLoading;
    private IReadOnlyList<DockerImage> _dockerImages = new List<DockerImage>();
    private IReadOnlyList<string> _names = new List<string>();
    private List<string> _tags = new();
    private string? _selectedName, _selectedTag;

    // Tag / promote dialog state
    private bool _showTag, _showPromote;
    private PublishableContainerDto? _target;
    private string _channelName = "";
    private Guid _promoteRegistryId = Guid.Empty;

    // <build#>-<hash> tag, e.g. 42-7a4b9c1
    private static readonly System.Text.RegularExpressions.Regex BuildHashTag =
        new(@"^\d+-[0-9a-fA-F]{7,40}$", System.Text.RegularExpressions.RegexOptions.Compiled);

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true; _error = null; _selected = new(); StateHasChanged();
        try
        {
            _items = await Api.ListContainersAsync();
            _channels = await Api.ListChannelsAsync();
            _registries = await Api.ListRegistriesAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; StateHasChanged(); }
    }

    private IEnumerable<string> ChannelsFor(Guid containerId)
        => _channels?.Where(c => c.CurrentContainerId == containerId).Select(c => c.Name) ?? Enumerable.Empty<string>();

    private string ContainerLabel(Guid id)
    {
        var c = _items?.FirstOrDefault(x => x.Id == id);
        return c is null ? id.ToString()[..8] + "…" : $"{c.ContainerName} {c.Version}";
    }

    // ---- Add from Nexus ----

    private async Task OpenAdd()
    {
        _showAdd = true;
        _selectedName = null; _selectedTag = null; _tags = new();
        if (!Nexus.IsConfigured) return;
        _addLoading = true; StateHasChanged();
        try
        {
            _dockerImages = await Nexus.ListDockerImagesAsync();
            _names = _dockerImages.Select(i => i.Name).Distinct().OrderBy(n => n).ToList();
        }
        catch (Exception ex) { Snackbar.Add($"Could not list Nexus docker images: {ex.Message}", Severity.Error); }
        finally { _addLoading = false; StateHasChanged(); }
    }

    private void SelectName(string name)
    {
        _selectedName = name;
        _selectedTag = null;
        _tags = _dockerImages.Where(i => i.Name == name && BuildHashTag.IsMatch(i.Tag))
                             .Select(i => i.Tag).Distinct().OrderByDescending(t => t).ToList();
    }

    private async Task AddAsync()
    {
        if (_selectedName is null || _selectedTag is null) return;
        _busy = true;
        try
        {
            var commit = _selectedTag.Contains('-') ? _selectedTag[(_selectedTag.IndexOf('-') + 1)..] : null;
            var artifactUri = $"{NexusOpts.DockerRegistryHost}/{_selectedName}:{_selectedTag}";
            await Api.AddContainerAsync(new AddContainerRequest(_selectedName, _selectedTag, commit, artifactUri));
            Snackbar.Add($"Added '{_selectedName}:{_selectedTag}'.", Severity.Success);
            _showAdd = false;
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _busy = false; }
    }

    // ---- Active toggle ----

    private async Task ToggleActiveAsync(PublishableContainerDto c)
    {
        try
        {
            if (c.IsActive) await Api.DeactivateContainerAsync(c.Id); else await Api.ActivateContainerAsync(c.Id);
            Snackbar.Add($"{(c.IsActive ? "Deactivated" : "Activated")} '{c.ContainerName}'.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    // ---- Delete ----

    private async Task DeleteOneAsync(PublishableContainerDto c)
    {
        _busy = true;
        try
        {
            await Api.DeleteContainerAsync(c.Id);
            Snackbar.Add($"Deleted '{c.ContainerName} {c.Version}'.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _busy = false; }
    }

    private async Task DeleteSelectedAsync()
    {
        if (_selected.Count == 0) return;
        _busy = true;
        var targets = _selected.ToList();
        var ok = 0;
        try
        {
            foreach (var c in targets)
            {
                try { await Api.DeleteContainerAsync(c.Id); ok++; }
                catch (Exception ex) { Snackbar.Add($"'{c.ContainerName}': {ex.Message}", Severity.Error); }
            }
            Snackbar.Add($"Deleted {ok} of {targets.Count} container(s).", ok == targets.Count ? Severity.Success : Severity.Warning);
            await LoadAsync();
        }
        finally { _busy = false; }
    }

    // ---- Tag / promote ----

    private void OpenTag(PublishableContainerDto c) { _target = c; _channelName = ""; _showTag = true; }

    private void OpenPromote(PublishableContainerDto c)
    {
        _target = c;
        _promoteRegistryId = _registries?.FirstOrDefault(r => r.IsDefault)?.Id ?? _registries?.FirstOrDefault()?.Id ?? Guid.Empty;
        _showPromote = true;
    }

    private async Task TagAsync()
    {
        if (_target is null || string.IsNullOrWhiteSpace(_channelName)) { Snackbar.Add("Channel name is required.", Severity.Warning); return; }
        _busy = true;
        try
        {
            await Api.TagPublishableAsync(_channelName.Trim(), new TagPublishableRequest(_target.Id, "ui"));
            Snackbar.Add($"Tagged '{_target.ContainerName}' as '{_channelName}'.", Severity.Success);
            _showTag = false;
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _busy = false; }
    }

    private async Task PromoteAsync()
    {
        if (_target is null) return;
        _busy = true;
        try
        {
            Guid? reg = _promoteRegistryId == Guid.Empty ? null : _promoteRegistryId;
            var res = await Api.PromoteContainerAsync(_target.Id, new PromoteContainerRequest(reg, "ui"));
            Announce(res);
            _showPromote = false;
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _busy = false; }
    }

    private async Task PublishChannelAsync(PublishChannelDto channel)
    {
        try
        {
            var res = await Api.PublishChannelAsync(channel.Name, new PromoteContainerRequest(null, "ui"));
            Announce(res);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private void Announce(PromoteResponse res)
    {
        if (res.PromotionId is not null) Snackbar.Add("Promotion queued.", Severity.Success);
        else Snackbar.Add($"No push: {res.Outcome}.", Severity.Info);
    }
}
