@page "/cloud/azure"

<PageTitle>Azure</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Azure</MudText>
</MudStack>

<MudPaper Elevation="1" Class="pa-4 mb-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
        <MudIcon Icon="@Icons.Material.Filled.Cloud" Color="Color.Primary" />
        <MudText Typo="Typo.h6">Coming soon</MudText>
    </MudStack>

    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
        No Azure-side integrations are wired up yet. When they are, this page will
        likely mirror the Google overview shape — a subscription picker + sections
        for the artifact registries / container apps / etc. that the pipeline
        targets. Until then, this is a placeholder so the menu structure reads
        consistently.
    </MudText>
</MudPaper>
