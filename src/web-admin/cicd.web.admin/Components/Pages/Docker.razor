@page "/nexus/docker"
@inject INexusClient Nexus
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@implements IDisposable

<PageTitle>Nexus — Docker</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Docker</MudText>
    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
        @Nexus.DockerRepositoryName
    </MudText>
    <MudSpacer />
    <MudButton Color="Color.Error"
               Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.DeleteForever"
               Disabled="@(_loading || _deleting || !Nexus.IsConfigured || _images is null or { Count: 0 })"
               OnClick="OnDeleteAllAsync">
        Delete all (@(_images?.Count ?? 0))
    </MudButton>
    <RefreshControls Loading="@(_loading || _deleting)"
                     AutoRefreshOn="@_autoOn"
                     LastFetchedAt="@_lastFetchedAt"
                     IntervalSec="@IntervalSec"
                     OnRefresh="RefreshAsync"
                     OnToggleAuto="ToggleAuto" />
</MudStack>

@if (!Nexus.IsConfigured)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="my-2">
        Nexus is not configured.
        <span style="font-family: ui-monospace, monospace;">@Nexus.ConfigurationError</span>
    </MudAlert>
}
else if (_error is { Length: > 0 })
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="my-2">@_error</MudAlert>
}

<DeleteLog Lines="_deleteLog" />

<MudPaper Elevation="1" Class="pa-4 mb-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudText Typo="Typo.h6">Images</MudText>
        @if (_images is { Count: > 0 })
        {
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                @_images.Count
            </MudChip>
        }
        <MudSpacer />
    </MudStack>

    @if (_loading && _images is null)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (_images is { Count: > 0 })
    {
        <MudTable Items="@_images"
                  Dense="true"
                  Hover="true"
                  Striped="true"
                  Filter="new Func<DockerImage, bool>(MatchesFilter)"
                  T="DockerImage">
            <ToolBarContent>
                <MudTextField @bind-Value="_filter"
                              Placeholder="Filter by image or tag…"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Small"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Clearable="true"
                              Immediate="true"
                              Style="max-width: 24rem;" />
            </ToolBarContent>
            <HeaderContent>
                <MudTh>Image</MudTh>
                <MudTh>Tag</MudTh>
                <MudTh Style="width: 7rem;">Size</MudTh>
                <MudTh Style="width: 9rem;">Uploaded</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Name</MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.Tag</MudChip>
                </MudTd>
                <MudTd>@FormatSize(context.SizeBytes)</MudTd>
                <MudTd>@(context.UploadedAt is { } at ? FormatRelative(at) : "—")</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new[] { 25, 50, 100, 250 }" />
            </PagerContent>
        </MudTable>
    }
    else if (!_loading && _error is null && Nexus.IsConfigured)
    {
        <MudText Typo="Typo.body2" Class="mt-2" Style="color: var(--mud-palette-text-secondary);">
            No images. Refresh to fetch.
        </MudText>
    }
</MudPaper>

@code {
    public const int IntervalSec = 30;

    private bool _loading;
    private bool _deleting;
    private bool _autoOn;
    private string? _error;
    private DateTimeOffset? _lastFetchedAt;
    private IReadOnlyList<DockerImage>? _images;
    private string _filter = string.Empty;
    private CancellationTokenSource? _inflightCts;
    private Timer? _timer;
    private readonly List<string> _deleteLog = new();

    protected override async Task OnInitializedAsync()
    {
        if (Nexus.IsConfigured)
        {
            await RefreshAsync();
        }
    }

    private async Task RefreshAsync()
    {
        if (!Nexus.IsConfigured) return;

        _inflightCts?.Cancel();
        _inflightCts = new CancellationTokenSource();
        var ct = _inflightCts.Token;

        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            _images = await Nexus.ListDockerImagesAsync(ct);
            _lastFetchedAt = DateTimeOffset.UtcNow;
        }
        catch (OperationCanceledException) { /* superseded — ignore */ }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void ToggleAuto()
    {
        _autoOn = !_autoOn;
        if (_autoOn)
        {
            _timer ??= new Timer(_ =>
            {
                if (!_deleting) _ = InvokeAsync(RefreshAsync);
            }, null, Timeout.Infinite, Timeout.Infinite);
            _timer.Change(TimeSpan.FromSeconds(IntervalSec), TimeSpan.FromSeconds(IntervalSec));
        }
        else
        {
            _timer?.Change(Timeout.Infinite, Timeout.Infinite);
        }
    }

    public void Dispose()
    {
        _timer?.Dispose();
        _inflightCts?.Cancel();
        _inflightCts?.Dispose();
    }

    private bool MatchesFilter(DockerImage i)
    {
        if (string.IsNullOrWhiteSpace(_filter)) return true;
        var f = _filter.Trim();
        return i.Name.Contains(f, StringComparison.OrdinalIgnoreCase)
            || i.Tag.Contains(f, StringComparison.OrdinalIgnoreCase);
    }

    private async Task OnDeleteAllAsync()
    {
        if (_images is not { Count: > 0 } images) return;

        var preview = images.Take(20).Select(i => $"{i.Name}:{i.Tag}").ToList();
        if (images.Count > preview.Count)
        {
            preview.Add($"… and {images.Count - preview.Count} more");
        }

        var parameters = new DialogParameters
        {
            ["Message"] = $"Delete ALL {images.Count} image tag(s) from '{Nexus.DockerRepositoryName}'? " +
                          "Runs three phases: (1) component delete, (2) orphan asset sweep " +
                          "(manifests + blob refs), (3) trigger compact-blob-store task to free disk. " +
                          "Phases 1–2 are immediate and cannot be undone; phase 3 runs async on Nexus " +
                          "and needs admin perms — it'll be skipped silently if your account lacks them.",
            ["Items"]   = (IReadOnlyList<string>)preview,
        };
        var dialog = await DialogService.ShowAsync<ConfirmDeleteDialog>(
            title: $"Delete {images.Count} Docker tag(s)",
            parameters: parameters);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        _deleting = true;
        _deleteLog.Clear();
        StateHasChanged();

        // --- Phase 1 of 3 — component delete ---
        AppendLog($"Phase 1/3 — deleting {images.Count} image tag(s) from {Nexus.DockerRepositoryName}…");
        StateHasChanged();

        var compSuccess = 0;
        var compFailures = new List<(string Item, string Error)>();
        foreach (var img in images)
        {
            var label = $"{img.Name}:{img.Tag}";
            AppendLog($"→ Deleting {label}…");
            StateHasChanged();

            try
            {
                await Nexus.DeleteDockerImageAsync(img);
                compSuccess++;
                AppendLog($"✓ Deleted {label}");
            }
            catch (Exception ex)
            {
                compFailures.Add((label, ex.Message));
                AppendLog($"✗ Failed: {label} — {ex.Message}");
            }
            StateHasChanged();
        }
        AppendLog($"Phase 1 done: {compSuccess} deleted, {compFailures.Count} failed.");
        StateHasChanged();

        // --- Phase 2 of 3 — orphan asset sweep ---
        // Manifests + blob layer refs survive component delete; sweep what remains.
        AppendLog("Phase 2/3 — sweeping orphan assets (manifests + blob refs)…");
        StateHasChanged();

        var assetSuccess = 0;
        var assetFailures = new List<(string Item, string Error)>();
        try
        {
            var assets = await Nexus.ListDockerAssetsAsync();
            if (assets.Count == 0)
            {
                AppendLog("Phase 2: no orphan assets found.");
            }
            else
            {
                AppendLog($"Phase 2: {assets.Count} asset(s) to remove.");
                foreach (var a in assets)
                {
                    AppendLog($"→ Deleting asset {a.Path}…");
                    StateHasChanged();

                    try
                    {
                        await Nexus.DeleteAssetAsync(a);
                        assetSuccess++;
                        AppendLog($"✓ Deleted {a.Path}");
                    }
                    catch (Exception ex)
                    {
                        assetFailures.Add((a.Path, ex.Message));
                        AppendLog($"✗ Failed: {a.Path} — {ex.Message}");
                    }
                    StateHasChanged();
                }
                AppendLog($"Phase 2 done: {assetSuccess} cleared, {assetFailures.Count} failed.");
            }
        }
        catch (Exception ex)
        {
            AppendLog($"Phase 2 failed before iterating: {ex.Message}");
        }
        StateHasChanged();

        // --- Phase 3 of 3 — compact-blob-store task (async, fire-and-forget) ---
        AppendLog("Phase 3/3 — triggering compact-blob-store task(s)…");
        StateHasChanged();
        try
        {
            var triggered = await Nexus.TriggerCompactBlobStoreTasksAsync();
            if (triggered.Count == 0)
            {
                AppendLog("Phase 3: no compact-blob-store task configured, or admin permission missing — skipped.");
            }
            else
            {
                foreach (var id in triggered)
                {
                    AppendLog($"✓ Triggered compact-blob-store task {id} (running async on Nexus)");
                }
            }
        }
        catch (Exception ex)
        {
            AppendLog($"Phase 3 failed: {ex.Message}");
        }

        AppendLog($"All phases complete: {compSuccess} tags + {assetSuccess} assets cleared.");
        StateHasChanged();

        _deleting = false;
        await RefreshAsync();

        if (compSuccess > 0)
        {
            Snackbar.Add(
                $"Deleted {compSuccess} tag(s) and {assetSuccess} asset(s) from {Nexus.DockerRepositoryName}",
                Severity.Success);
        }
        foreach (var (item, error) in compFailures.Concat(assetFailures))
        {
            Snackbar.Add($"Failed: {item} — {error}", Severity.Error);
        }
    }

    private void AppendLog(string line)
    {
        _deleteLog.Add($"[{DateTime.Now:HH:mm:ss}] {line}");
    }

    private static string FormatSize(long? bytes) => bytes switch
    {
        null                  => "—",
        < 1024                => $"{bytes} B",
        < 1024 * 1024         => $"{bytes / 1024.0:F1} KB",
        < 1024L * 1024 * 1024 => $"{bytes / (1024.0 * 1024):F1} MB",
        _                     => $"{bytes / (1024.0 * 1024 * 1024):F2} GB"
    };

    private static string FormatRelative(DateTimeOffset t)
    {
        if (t == DateTimeOffset.MinValue) return "—";
        var ago = DateTimeOffset.UtcNow - t;
        return ago switch
        {
            { TotalMinutes: < 1 } => "just now",
            { TotalHours: < 1 }   => $"{(int)ago.TotalMinutes}m ago",
            { TotalDays: < 1 }    => $"{(int)ago.TotalHours}h ago",
            { TotalDays: < 30 }   => $"{(int)ago.TotalDays}d ago",
            _                     => t.LocalDateTime.ToString("yyyy-MM-dd")
        };
    }
}
