@page "/"
@page "/jenkins/orchestrator"
@inject IPipelineRunner Runner
@inject JenkinsApiClient Api
@implements IDisposable

<PageTitle>Orchestrator</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Orchestrator</MudText>
    <MudChip T="string" Color="@StateChipColor()" Variant="Variant.Filled" Size="Size.Small">
        @_snapshot.State.ToString()
    </MudChip>
    <MudSpacer />
    <MudSelect T="Guid?" Value="_selectedId" ValueChanged="OnPipelineSelectedAsync"
               Label="Pipeline" Dense="true" Variant="Variant.Outlined"
               Style="min-width: 16rem;" Disabled="@(_snapshot.State == PipelineState.Running)">
        @foreach (var p in _pipelines)
        {
            <MudSelectItem T="Guid?" Value="@((Guid?)p.Id)">@p.Name (@p.StageCount)</MudSelectItem>
        }
    </MudSelect>
    <MudTooltip Text="Manage pipelines">
        <MudIconButton Icon="@Icons.Material.Filled.Edit" Href="/ci/pipelines" />
    </MudTooltip>
    @if (_snapshot.State == PipelineState.Running)
    {
        <MudButton Color="Color.Error"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Stop"
                   OnClick="OnCancel">
            Cancel
        </MudButton>
    }
    else
    {
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.PlayArrow"
                   Disabled="@(_steps.Count == 0)"
                   OnClick="OnRun">
            Run Pipeline
        </MudButton>
    }
</MudStack>

@if (_snapshot.State is PipelineState.Completed or PipelineState.Failed && _snapshot.Result is { } result)
{
    <MudAlert Severity="@(result.Success ? Severity.Success : Severity.Error)"
              Variant="Variant.Filled"
              Class="mb-4">
        Pipeline @(result.Success ? "succeeded" : "failed")
        @if (!result.Success && result.FailureReason is { Length: > 0 } reason)
        {
            <span> — @reason</span>
        }
    </MudAlert>
}

<MudPaper Elevation="1" Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" Class="mb-2">Steps</MudText>
    <MudSimpleTable Dense="true" Hover="true" Striped="true" Style="font-family: ui-monospace, monospace;">
        <thead>
            <tr>
                <th style="width: 2rem;"></th>
                <th>Job</th>
                <th style="width: 6rem;">Build</th>
                <th>Status</th>
                <th style="width: 6rem;">Duration</th>
            </tr>
        </thead>
        <tbody>
            @if (_steps.Count == 0)
            {
                <tr><td colspan="5" style="color: var(--mud-palette-text-secondary);">No pipeline selected, or it has no stages.</td></tr>
            }
            @foreach (var step in _steps)
            {
                var view = StepStatusFor(step.JobName);
                <tr>
                    <td>
                        <MudIcon Icon="@view.Icon"
                                 Color="@view.IconColor"
                                 Size="Size.Small" />
                    </td>
                    <td>@step.JobName</td>
                    <td>@(view.BuildNumber is int n ? $"#{n}" : "-")</td>
                    <td>
                        <MudText Color="@view.IconColor" Typo="Typo.body2">@view.Status</MudText>
                    </td>
                    <td>@(view.Duration is TimeSpan d ? $"{d.TotalSeconds:F1}s" : "-")</td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>
</MudPaper>

<MudPaper Elevation="1" Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" Class="mb-2">
        Console
        @if (_snapshot.CurrentStepJob is { Length: > 0 } job)
        {
            <MudText Typo="Typo.body2" Class="d-inline ml-2" Style="color: var(--mud-palette-text-secondary);">— @job</MudText>
        }
    </MudText>
    <div class="console-log">
        @if (CurrentLog() is { Length: > 0 } logHtml)
        {
            @((MarkupString)logHtml)
        }
        else
        {
            <div class="empty">No console output yet.</div>
        }
    </div>
</MudPaper>

<MudPaper Elevation="1" Class="pa-4">
    <MudText Typo="Typo.h6" Class="mb-2">Events</MudText>
    <div class="events-log">
        @if (_snapshot.Events.Count == 0)
        {
            <div class="empty">No events yet — click <em>Run Pipeline</em>.</div>
        }
        else
        {
            @foreach (var evt in _snapshot.Events)
            {
                <div class="event event-@EventKind(evt)">
                    <span class="ts">[@evt.Timestamp.ToString("HH:mm:ss")]</span>
                    <span class="job">@evt.JobName</span>
                    <span class="text">@EventText(evt)</span>
                </div>
            }
        }
    </div>
</MudPaper>

@code {
    // Steps are loaded from the selected persisted pipeline (Jenkins.Api). Falls back to
    // the built-in CICD Main if the service is unreachable so the page still runs.
    private IReadOnlyList<PipelineStep> _steps = Array.Empty<PipelineStep>();
    private IReadOnlyList<PipelineSummaryDto> _pipelines = Array.Empty<PipelineSummaryDto>();
    private Guid? _selectedId;

    private PipelineSnapshot _snapshot = new(
    PipelineState.Idle,
    Array.Empty<PipelineEvent>(),
    CurrentStepJob: null,
    Logs: new Dictionary<string, string>(),
    Result: null);

    protected override async Task OnInitializedAsync()
    {
        _snapshot = Runner.Snapshot;
        Runner.StateChanged += OnStateChanged;
        await LoadPipelinesAsync();
    }

    private async Task LoadPipelinesAsync()
    {
        try
        {
            _pipelines = await Api.ListPipelinesAsync();
        }
        catch
        {
            _pipelines = Array.Empty<PipelineSummaryDto>();
        }

        // Prefer the first active pipeline, else the first one.
        var initial = _pipelines.FirstOrDefault(p => p.IsActive) ?? _pipelines.FirstOrDefault();
        if (initial is not null)
        {
            await OnPipelineSelectedAsync(initial.Id);
        }
        else
        {
            // No persisted pipelines reachable — fall back to the built-in default.
            _steps = DefaultPipelines.CicdMain();
        }
    }

    private async Task OnPipelineSelectedAsync(Guid? id)
    {
        _selectedId = id;
        if (id is not { } pid) { _steps = Array.Empty<PipelineStep>(); return; }
        try
        {
            var dto = await Api.GetPipelineAsync(pid);
            _steps = dto is null
                ? Array.Empty<PipelineStep>()
                : dto.Stages
                     .Select(s => new PipelineStep(
                         s.JobName,
                         string.IsNullOrWhiteSpace(s.UpstreamJobName) ? null : s.UpstreamJobName,
                         s.Parameters.Count > 0 ? new Dictionary<string, string>(s.Parameters) : null))
                     .ToList();
        }
        catch
        {
            _steps = DefaultPipelines.CicdMain();
        }
        StateHasChanged();
    }

    private void OnStateChanged()
    {
        _ = InvokeAsync(() =>
        {
            _snapshot = Runner.Snapshot;
            StateHasChanged();
        });
    }

    private void OnRun()    => Runner.TryStart(_steps);
    private void OnCancel() => Runner.Cancel();

    private string? CurrentLog()
    {
        if (_snapshot.CurrentStepJob is not { Length: > 0 } job) return null;
        return _snapshot.Logs.TryGetValue(job, out var html) ? html : null;
    }

    public void Dispose() => Runner.StateChanged -= OnStateChanged;

    private Color StateChipColor() => _snapshot.State switch
    {
        PipelineState.Running   => Color.Info,
        PipelineState.Completed => Color.Success,
        PipelineState.Failed    => Color.Error,
        _                       => Color.Default
    };

    private sealed record StepView(string Icon, Color IconColor, string Status, int? BuildNumber, TimeSpan? Duration);

    private StepView StepStatusFor(string jobName)
    {
        PipelineEvent? latest = null;
        for (var i = _snapshot.Events.Count - 1; i >= 0; i--)
        {
            if (string.Equals(_snapshot.Events[i].JobName, jobName, StringComparison.OrdinalIgnoreCase))
            {
                latest = _snapshot.Events[i];
                break;
            }
        }

        return latest switch
        {
            PipelineStepCompleted c => new(Icons.Material.Filled.CheckCircle,    Color.Success, $"{c.Result}", c.BuildNumber, c.Duration),
            PipelineStepFailed f    => new(Icons.Material.Filled.Cancel,         Color.Error,   $"failed: {f.Reason}", null, null),
            PipelineStepRunning r   => new(Icons.Material.Filled.PlayCircle,     Color.Info,    "running", r.BuildNumber, null),
            PipelineStepQueued q    => new(Icons.Material.Filled.Schedule,       Color.Info,    $"queued ({q.QueueId})", null, null),
            PipelineStepStarted s   => new(Icons.Material.Filled.HourglassTop,   Color.Info,    "starting", null, null),
            _                       => new(Icons.Material.Filled.RadioButtonUnchecked, Color.Default, "pending", null, null)
        };
    }

    private static string EventKind(PipelineEvent evt) => evt switch
    {
        PipelineStepCompleted => "success",
        PipelineStepFailed    => "failure",
        _                     => "info"
    };

    private static string EventText(PipelineEvent evt) => evt switch
    {
        PipelineStepStarted s   => s.UpstreamBuildNumber is int n ? $"started (consuming upstream build #{n})" : "started",
        PipelineStepQueued q    => $"queued (queue item {q.QueueId})",
        PipelineStepRunning r   => $"running as build #{r.BuildNumber}",
        PipelineStepCompleted c => $"completed #{c.BuildNumber} {c.Result} in {c.Duration.TotalSeconds:F1}s",
        PipelineStepFailed f    => $"FAILED — {f.Reason}",
        _                       => evt.GetType().Name
    };
}
