@page "/jenkins/builds"
@inject IBuildStore Store
@inject JenkinsOptions JenkinsOpts
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Jenkins — Builds</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Builds</MudText>
    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
        @_jobName
    </MudText>
    <MudSpacer />
    <MudNumericField T="int"
                     @bind-Value="_count"
                     Min="5"
                     Max="200"
                     Step="5"
                     Label="Show last"
                     Variant="Variant.Outlined"
                     Margin="Margin.Dense"
                     Style="max-width: 9rem;" />
    <RefreshControls Loading="@_loading"
                     AutoRefreshOn="@_autoOn"
                     LastFetchedAt="@_lastFetchedAt"
                     IntervalSec="@IntervalSec"
                     OnRefresh="RefreshAsync"
                     OnToggleAuto="ToggleAuto" />
</MudStack>

@if (_error is { Length: > 0 })
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="my-2">@_error</MudAlert>
}

<MudPaper Elevation="1" Class="pa-4 mb-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudText Typo="Typo.h6">Recent runs</MudText>
        @if (_builds is { Count: > 0 })
        {
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                @_builds.Count
            </MudChip>
        }
        <MudSpacer />
    </MudStack>

    @if (_loading && _builds is null)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (_builds is { Count: > 0 })
    {
        <MudTable Items="@_builds"
                  Dense="true"
                  Hover="true"
                  Striped="true"
                  Filter="new Func<Build, bool>(MatchesFilter)"
                  T="Build">
            <ToolBarContent>
                <MudTextField @bind-Value="_filter"
                              Placeholder="Filter by version, build #, or status…"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Small"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Clearable="true"
                              Immediate="true"
                              Style="max-width: 28rem;" />
            </ToolBarContent>
            <HeaderContent>
                <MudTh Style="width: 5rem;">#</MudTh>
                <MudTh>Version</MudTh>
                <MudTh Style="width: 8rem;">Status</MudTh>
                <MudTh Style="width: 11rem;">Started</MudTh>
                <MudTh Style="width: 7rem;">Duration</MudTh>
                <MudTh Style="width: 8rem; text-align: right;"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd Style="font-family: ui-monospace, monospace;">#@context.Number</MudTd>
                <MudTd>@(context.Description ?? "—")</MudTd>
                <MudTd>
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="@StatusColor(context)"
                             Variant="Variant.Filled">
                        @StatusLabel(context)
                    </MudChip>
                </MudTd>
                <MudTd>@FormatStarted(context.Timestamp)</MudTd>
                <MudTd>@FormatDuration(context)</MudTd>
                <MudTd Style="text-align: right; white-space: nowrap;">
                    <MudTooltip Text="View summary">
                        <MudIconButton Icon="@Icons.Material.Filled.Info"
                                       Size="Size.Small"
                                       OnClick="@(() => Nav.NavigateTo($"/jenkins/builds/{context.Number}"))" />
                    </MudTooltip>
                    <MudTooltip Text="Open in Jenkins">
                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                       Size="Size.Small"
                                       Href="@JenkinsLinkFor(context)"
                                       Target="_blank" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new[] { 25, 50, 100, 200 }" />
            </PagerContent>
        </MudTable>
    }
    else if (!_loading && _error is null)
    {
        <MudText Typo="Typo.body2" Class="mt-2" Style="color: var(--mud-palette-text-secondary);">
            No builds. Refresh to fetch.
        </MudText>
    }
</MudPaper>

@code {
    public const int IntervalSec = 30;

    // First cut targets the canonical orchestrator job; could become a dropdown
    // later if we want builds across multiple jobs in one view.
    private const string _jobName = "cicd-build";

    private int _count = 25;
    private bool _loading;
    private bool _autoOn;
    private string? _error;
    private DateTimeOffset? _lastFetchedAt;
    private IReadOnlyList<Build>? _builds;
    private string _filter = string.Empty;
    private CancellationTokenSource? _inflightCts;
    private Timer? _timer;
    private int _lastFetchedCount;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        // Refetch when the user changes the count, but only if the value actually changed.
        if (_count != _lastFetchedCount && !_loading)
        {
            await RefreshAsync();
        }
    }

    private async Task RefreshAsync()
    {
        _inflightCts?.Cancel();
        _inflightCts = new CancellationTokenSource();
        var ct = _inflightCts.Token;

        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            _builds = await Store.ListBuildsAsync(_jobName, _count, ct);
            _lastFetchedAt = DateTimeOffset.UtcNow;
            _lastFetchedCount = _count;
        }
        catch (OperationCanceledException) { /* superseded — ignore */ }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void ToggleAuto()
    {
        _autoOn = !_autoOn;
        if (_autoOn)
        {
            _timer ??= new Timer(_ => _ = InvokeAsync(RefreshAsync),
                null, Timeout.Infinite, Timeout.Infinite);
            _timer.Change(TimeSpan.FromSeconds(IntervalSec), TimeSpan.FromSeconds(IntervalSec));
        }
        else
        {
            _timer?.Change(Timeout.Infinite, Timeout.Infinite);
        }
    }

    public void Dispose()
    {
        _timer?.Dispose();
        _inflightCts?.Cancel();
        _inflightCts?.Dispose();
    }

    private bool MatchesFilter(Build b)
    {
        if (string.IsNullOrWhiteSpace(_filter)) return true;
        var f = _filter.Trim();
        return $"#{b.Number}".Contains(f, StringComparison.OrdinalIgnoreCase)
            || (b.Description?.Contains(f, StringComparison.OrdinalIgnoreCase) ?? false)
            || StatusLabel(b).Contains(f, StringComparison.OrdinalIgnoreCase);
    }

    /// <summary>
    /// Build URLs returned by Jenkins point at the docker network alias used by
    /// the WebUI's server-side client. Rewrite onto JenkinsOpts.BaseUrl so the
    /// browser can actually open them — matches what the Jenkins Admin link does.
    /// </summary>
    private string JenkinsLinkFor(Build b)
    {
        var path = $"/job/{Uri.EscapeDataString(_jobName)}/{b.Number}/";
        var baseUrl = JenkinsOpts.BaseUrl.TrimEnd('/');
        return $"{baseUrl}{path}";
    }

    private static string StatusLabel(Build b) =>
        b.Building ? "Running" : (b.Result?.ToString() ?? "Unknown");

    private static Color StatusColor(Build b)
    {
        if (b.Building) return Color.Info;
        return b.Result switch
        {
            BuildResult.Success  => Color.Success,
            BuildResult.Failure  => Color.Error,
            BuildResult.Unstable => Color.Warning,
            BuildResult.Aborted  => Color.Dark,
            _                    => Color.Default
        };
    }

    private static string FormatStarted(long unixMs)
    {
        if (unixMs <= 0) return "—";
        var t = DateTimeOffset.FromUnixTimeMilliseconds(unixMs);
        var ago = DateTimeOffset.UtcNow - t;
        return ago switch
        {
            { TotalMinutes: < 1 } => "just now",
            { TotalHours: < 1 }   => $"{(int)ago.TotalMinutes}m ago",
            { TotalDays: < 1 }    => $"{(int)ago.TotalHours}h ago",
            { TotalDays: < 30 }   => $"{(int)ago.TotalDays}d ago",
            _                     => t.LocalDateTime.ToString("yyyy-MM-dd HH:mm")
        };
    }

    private static string FormatDuration(Build b)
    {
        // For in-progress builds Jenkins reports duration=0; show "running" so the
        // column doesn't read "0.0s" and look misleading.
        if (b.Building) return "running…";
        if (b.Duration <= 0) return "—";
        var ts = TimeSpan.FromMilliseconds(b.Duration);
        return ts switch
        {
            { TotalSeconds: < 60 }  => $"{ts.TotalSeconds:F1}s",
            { TotalMinutes: < 60 }  => $"{(int)ts.TotalMinutes}m {ts.Seconds}s",
            _                       => $"{(int)ts.TotalHours}h {ts.Minutes}m"
        };
    }
}
