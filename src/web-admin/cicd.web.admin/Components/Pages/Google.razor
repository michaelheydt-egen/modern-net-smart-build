@page "/cloud/google"
@inject GcpOptions Options

<PageTitle>Google Cloud — Overview</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h4">Google Cloud · Overview</MudText>
    <MudSpacer />

    @if (Options.Projects.Count == 0)
    {
        <MudText Typo="Typo.body2" Color="Color.Warning">
            No projects configured. Add entries under <code>Google:Projects</code> in appsettings.
        </MudText>
    }
    else
    {
        <MudSelect T="string"
                   Value="@_selectedKey"
                   ValueChanged="OnProjectChanged"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Style="min-width: 22rem;"
                   Label="Project">
            @foreach (var p in Options.Projects)
            {
                <MudSelectItem T="string" Value="@p.Key">@p.Label</MudSelectItem>
            }
        </MudSelect>
    }
</MudStack>

@if (_selected is { } env)
{
    <GarSection Environment="@env" />
    <CloudRunSection Environment="@env" />
}

@code {
    private string? _selectedKey;
    private GcpEnvironment? _selected;

    protected override void OnInitialized()
    {
        _selected = Options.Default;
        _selectedKey = _selected?.Key;
    }

    private void OnProjectChanged(string newKey)
    {
        _selectedKey = newKey;
        _selected = Options.Projects.FirstOrDefault(p => p.Key == newKey);
    }
}
