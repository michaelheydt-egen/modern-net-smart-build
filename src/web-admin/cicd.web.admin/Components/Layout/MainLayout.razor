@inherits LayoutComponentBase
@inject JenkinsOptions JenkinsOpts
@inject ThemeService Theme
@inject NavStateService Nav
@inject NavigationManager Navigation
@implements IDisposable

<MudThemeProvider Theme="@Theme.Current.Theme" IsDarkMode="@Theme.Current.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@* App-wide completion toasts: listens to both APIs' SignalR hubs and pops a toast when a
   pipeline run or deployment run finishes, regardless of which page is open. *@
<CompletionToasts />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@ToggleDrawer"
                       aria-label="Toggle menu" />
        <MudText Typo="Typo.h6">Egen Modern .NET CI/CD</MudText>
        <MudSpacer />
        <PendingWorkBadge />
        <BuildSyncBadge />
        <JenkinsStatusBadge />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Elevation="1"
               Variant="DrawerVariant.Responsive"
               ClipMode="DrawerClipMode.Always">
        @* Drawer nav is rendered from NavModel (single source of truth). Groups default to collapsed and remember
           their state (NavStateService → localStorage); the active section auto-expands on navigation. *@
        <MudNavMenu>
            <MudNavLink Href="@NavModel.Home.Href" Match="@NavModel.Home.Match" Icon="@NavModel.Home.Icon">@NavModel.Home.Label</MudNavLink>
            @foreach (var s in _sections)
            {
                <MudNavGroup Title="@s.Title" Icon="@s.Icon"
                             Expanded="@Nav.IsExpanded(s.Key)"
                             ExpandedChanged="@((bool v) => Nav.SetExpanded(s.Key, v))">
                    @foreach (var l in s.Links)
                    {
                        @NavItem(l)
                    }
                    @foreach (var sub in s.Sub)
                    {
                        <MudNavGroup Title="@sub.Title" Icon="@sub.Icon"
                                     Expanded="@Nav.IsExpanded(sub.Key)"
                                     ExpandedChanged="@((bool v) => Nav.SetExpanded(sub.Key, v))">
                            @foreach (var l in sub.Links)
                            {
                                @NavItem(l)
                            }
                        </MudNavGroup>
                    }
                </MudNavGroup>
            }
            <MudDivider Class="my-2" />
            <MudNavLink Href="@NavModel.Settings.Href" Match="@NavModel.Settings.Match" Icon="@NavModel.Settings.Icon">@NavModel.Settings.Label</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        @* MaxWidth.False removes the 1280px cap so panels grow with the viewport;
           the inline min-width keeps a horizontal scrollbar at the page level
           instead of cramping panels on narrow windows. *@
        <MudContainer MaxWidth="MaxWidth.False" Class="my-4" Style="min-width: 600px;">
            @if (_crumbs.Count > 0)
            {
                <MudBreadcrumbs Items="_crumbs" Class="px-1 mb-2" />
            }
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;
    private IReadOnlyList<NavSection> _sections = [];
    private List<BreadcrumbItem> _crumbs = new();

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    // One MudNavLink for a nav entry; external links open in a new tab (no Match).
    private RenderFragment NavItem(NavEntry l) => __builder =>
    {
        <MudNavLink Href="@l.Href"
                    Match="@l.Match"
                    Target="@(l.External ? "_blank" : null)"
                    Icon="@l.Icon">@l.Label</MudNavLink>
    };

    protected override void OnInitialized()
    {
        _sections = NavModel.Build(JenkinsOpts.BaseUrl);
        // Re-render on theme changes (Settings selector / initial load) and on nav-expansion changes.
        Theme.Changed += OnStateChanged;
        Nav.Changed += OnStateChanged;
        Navigation.LocationChanged += OnLocationChanged;
        BuildCrumbs();
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        BuildCrumbs();
        ExpandActiveSection();
        InvokeAsync(StateHasChanged);
    }

    private void BuildCrumbs() =>
        _crumbs = NavModel.Crumbs(Navigation.ToBaseRelativePath(Navigation.Uri))
            .Select(c => new BreadcrumbItem(c.Label, c.Href))
            .ToList();

    // Open (and remember) the group(s) the current route lives under. Safe to call only post-render — it persists
    // via localStorage — so it runs from OnAfterRenderAsync(firstRender) and LocationChanged, never during prerender.
    private void ExpandActiveSection()
    {
        foreach (var key in NavModel.ActiveKeys(Navigation.ToBaseRelativePath(Navigation.Uri)))
            Nav.SetExpanded(key, true);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Theme.InitializeAsync();   // localStorage is only available post-render
        await Nav.InitializeAsync();     // restore remembered group expansion
        ExpandActiveSection();           // ensure the current section is open
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Theme.Changed -= OnStateChanged;
        Nav.Changed -= OnStateChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
