{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Jenkins": {
    "Url": "http://jenkins:8080",
    "User": "admin",
    "ApiToken": "",
    "Health": {
      "PollIntervalSeconds": 30,
      "ProbeTimeoutSeconds": 5
    }
  },

  "BuildSync": {
    "Enabled": false,
    "Jobs": [ "cicd-build" ],
    "PollIntervalSeconds": 60,
    "BackfillCount": 100,
    "PerJobFetchCount": 25,
    "DbPath": "./data/builds.db",
    "ReconcileDeleted": false
  },

  "Nexus": {
    "Url": "http://nexus:8081",
    "User": "admin",
    "Password": "",
    "NuGetHostedRepository": "nuget-hosted",
    "DockerHostedRepository": "docker-private"
  },

  "Google": {
    "Projects": [
      {
        "Label": "egen-gcr / us-west1",
        "ProjectId": "egen-gcr",
        "Region": "us-west1",
        "ArtifactRegistry": "egen-cicd-net"
      }
    ]
  }
}
